// Test file for enhanced parser features
// This tests access specifiers, 'this' parameter, and parameter kinds

public mytype: type = {
    private data: std::string;
    protected counter: int = 0;
    
    // Test 'this' parameter with different kinds
    public get_data: (this) -> std::string = {
        return this.data;
    }
    
    protected set_data: (inout this, in new_data: std::string) = {
        this.data = new_data;
    }
    
    private increment: (this) -> int = {
        return ++this.counter;
    }
}

// Test namespace with access specifiers
public util: namespace = {
    private helper: (in value: int) -> int = {
        return value * 2;
    }
    
    public process: (inout data: std::vector<int>) = {
        for data do (inout x) {
            x = helper(x);
        }
    }
}

// Test regular function with parameter kinds
process_vector: (inout vec: std::vector<int>, out result: int) = {
    result = 0;
    for vec do (in value) {
        result += value;
    }
}