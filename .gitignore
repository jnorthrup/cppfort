# Ignore everything by default
/*

# Keep the .gitignore itself
!.gitignore

# Keep documentation
!/docs/
!/docs/**

# Allow src/ directory
!/src/

# Re-ignore everything under src by default
/src/**

# Whitelist stage folders
!/src/stage0/
!/src/stage0/**

!/src/stage1/
!/src/stage1/**

!/src/stage2/
!/src/stage2/**

!/src/stage3/
!/src/stage3/**

# Preserve top-level and important CMake files
!/CMakeLists.txt
!/src/CMakeLists.txt
!/src/stage0/CMakeLists.txt
!/src/stage1/CMakeLists.txt
!/src/stage2/CMakeLists.txt
!/src/stage3/CMakeLists.txt

# Preserve Ninja build files (root and under allowed src paths)
!/build.ninja
!/*.ninja
!/src/**/build.ninja
!/src/**/*.ninja

# Safety note: Everything else remains ignored (dotfiles, .bmad-*, .github/, tools/, examples/, etc.)
# Existing tracked files will remain tracked until you run `git rm --cached` if you choose to untrack them.