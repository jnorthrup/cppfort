# C++ build artifacts (turds)
*.o
*.a
*.so
*.dylib
*.exe
*.out
*.app
*.dSYM/

!.claude

docs/**/*.java
pom.xml
target/

# Build directories
/build/
/cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# IDE and editor files
!.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Temporary and backup files
*.tmp
*.bak
*.log

# BMAD: allow source templates and tracked files under .bmad-core but ignore runtime/cache and local secrets
# Keep templates and configs (commitable); ignore caches and local secrets
.bmad-core/cache/
.bmad-core/tmp/
.bmad-core/*.local
.bmad-core/*.secret
# Local encrypted audits and manifests
.bmad-core/audit/
manifests/