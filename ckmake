#!/usr/bin/env bash
# ckmake - clean build and test runner for cppfront
# Handles: fresh builds, pulling new hsutter versions, comprehensive testing

set -e

# =============================================================================
# CONFIGURATION
# =============================================================================
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="${BUILD_DIR:-$PROJECT_ROOT/build_clean}"
CPPFRONT_DIR="$PROJECT_ROOT/third_party/cppfront"
CPPFRONT_SRC="$CPPFRONT_DIR/source/cppfront.cpp"
CPPFRONT_BIN="$BUILD_DIR/bin/cppfront"
CPPFORT_BIN="${PROJECT_ROOT}/build/cppfort"
CORPUS_DIR="$PROJECT_ROOT/corpus"
WORK_DIR="$BUILD_DIR/test_work"

# Compiler settings
export HOMEBREW_LLVM_PREFIX="/opt/homebrew/opt/llvm"
export CC="${HOMEBREW_LLVM_PREFIX}/bin/clang"
export CXX="${HOMEBREW_LLVM_PREFIX}/bin/clang++"

# Compiler flags for cppfront (must match project CMakeLists.txt)
CPPFRONT_CXXFLAGS="-std=c++23 -stdlib=libc++ -O0 -ftemplate-depth=2048 \
    -ftemplate-backtrace-limit=0 -ferror-limit=10 -Wno-error \
    -Wno-unused-parameter -Wno-unused-variable -Wno-date-time"

CPPFRONT_LDFLAGS="-stdlib=libc++ -L${HOMEBREW_LLVM_PREFIX}/lib/c++ \
    -L${HOMEBREW_LLVM_PREFIX}/lib/unwind -lunwind"

# Timeouts
TIMEOUT_BUILD=${TIMEOUT_BUILD:-120}
TIMEOUT_COMPILE=${TIMEOUT_COMPILE:-30}
TIMEOUT_RUN=${TIMEOUT_RUN:-5}

# Anti-cheating gates
SIZE_RATIO_MIN=${SIZE_RATIO_MIN:-0.50}   # Gate 4: minimum output/reference code-line ratio
REFERENCE_DIR="$CPPFRONT_DIR/regression-tests/test-results"
REFERENCE_EXEC_DIR="$CPPFRONT_DIR/regression-tests/test-results/clang-19-c++23-libcpp"

# Compile/link flags for full compilation (not syntax-only)
FORT_CXXFLAGS="-std=c++23 -stdlib=libc++ -Wno-unused-parameter -Wno-unused-variable \
    -Wno-unused-but-set-variable -Wno-deprecated-declarations -Wno-nan-infinity-disabled \
    -ftemplate-depth=2048 -ferror-limit=10"
FORT_LDFLAGS="-stdlib=libc++ -L${HOMEBREW_LLVM_PREFIX}/lib/c++ \
    -L${HOMEBREW_LLVM_PREFIX}/lib/unwind -lunwind"

# Test source directories
REGRESSION_DIR="$CPPFRONT_DIR/regression-tests"
PASSROUGH_DIR="$CPPFRONT_DIR/passthrough-tests"

# =============================================================================
# COLORS AND OUTPUT
# =============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
log_ok()      { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*"; }
log_section() { echo ""; echo -e "${BLUE}==== $* ====${NC}"; }

# =============================================================================
# UTILITIES
# =============================================================================
check_dependencies() {
    local missing=()
    for cmd in "$CXX" cmake rsync shasum; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done
    if [ ${#missing[@]} -gt 0 ]; then
        log_error "Missing dependencies: ${missing[*]}"
        return 1
    fi
}

clean_build_dir() {
    log_info "Creating clean build directory: $BUILD_DIR"
    rm -rf "$BUILD_DIR"
    mkdir -p "$BUILD_DIR/bin"
    mkdir -p "$WORK_DIR"
}

# =============================================================================
# CPPFRONT BUILD
# =============================================================================
build_cppfront() {
    log_section "Building cppfront"

    if [ ! -f "$CPPFRONT_SRC" ]; then
        log_error "cppfront source not found at $CPPFRONT_SRC"
        log_info "Run '$0 update' to fetch latest cppfront"
        return 1
    fi

    local cmd="$CXX $CPPFRONT_CXXFLAGS -o $CPPFRONT_BIN $CPPFRONT_SRC $CPPFRONT_LDFLAGS"
    log_info "Compiling: $cmd"

    if timeout "$TIMEOUT_BUILD" bash -c "$cmd" 2>&1 | tee "$BUILD_DIR/compile.log"; then
        log_ok "cppfront built successfully: $CPPFRONT_BIN"
        return 0
    else
        log_error "cppfront build failed. Check $BUILD_DIR/compile.log"
        return 1
    fi
}

# =============================================================================
# CPPFRONT UPDATE
# =============================================================================
update_cppfront() {
    log_section "Updating cppfront from hsutter/cppfront"

    if [ -d "$CPPFRONT_DIR/.git" ]; then
        log_info "Pulling latest changes..."
        (cd "$CPPFRONT_DIR" && git fetch && git checkout main && git pull)
    else
        log_info "Cloning cppfront repository..."
        rm -rf "$CPPFRONT_DIR"
        git clone https://github.com/hsutter/cppfront "$CPPFRONT_DIR"
    fi

    local commit=$(cd "$CPPFRONT_DIR" && git rev-parse --short HEAD)
    local date=$(cd "$CPPFRONT_DIR" && git log -1 --format=%ci)
    log_ok "Updated to commit $commit ($date)"
}

# =============================================================================
# CPPFORT BUILD (new parser)
# =============================================================================
build_cppfort() {
    log_section "Building cppfort (new parser)"

    # Build using CMake
    local cmake_build="$BUILD_DIR/cppfort_cmake"
    mkdir -p "$cmake_build"
    cd "$cmake_build"

    local cmd="cmake $PROJECT_ROOT -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_COMPILER=$CXX -DCMAKE_C_COMPILER=$CC"
    log_info "Configuring: $cmd"

    if cmake "$PROJECT_ROOT" -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_CXX_COMPILER="$CXX" \
        -DCMAKE_C_COMPILER="$CC" \
        -DCMAKE_CXX_FLAGS="$CPPFRONT_CXXFLAGS" > "$BUILD_DIR/cppfort_cmake.log" 2>&1; then
        log_ok "CMake configured"
    else
        log_error "CMake configure failed"
        return 1
    fi

    if make cppfort -j$(sysctl -n hw.ncpu 2>/dev/null || echo 4) >> "$BUILD_DIR/cppfort_cmake.log" 2>&1; then
        # Copy to bin dir
        mkdir -p "$BUILD_DIR/bin"
        cp "$cmake_build/src/cppfort" "$CPPFORT_BIN" 2>/dev/null || \
        cp "$cmake_build/cppfort" "$CPPFORT_BIN" 2>/dev/null || true

        if [ -f "$CPPFORT_BIN" ]; then
            log_ok "cppfort built successfully: $CPPFORT_BIN"
            return 0
        else
            log_error "cppfort binary not found after build"
            return 1
        fi
    else
        log_error "cppfort build failed. Check $BUILD_DIR/cppfort_cmake.log"
        return 1
    fi
}

# =============================================================================
# ANTI-CHEATING GATES
# =============================================================================

# Count "code lines" in a .cpp file (strip includes, using, #line, blank, comments)
code_line_count() {
    grep -cvE '^\s*$|^\s*//|^#include|^#line |^using ' "$1" 2>/dev/null || echo 0
}

# Gate 4: Size gate - compare code-line count against reference
# Returns 0 (pass) or 1 (fail). Prints ratio to stdout.
check_size_gate() {
    local outfile="$1" reffile="$2"
    if [ ! -f "$reffile" ]; then
        echo "1.00"  # no reference = skip gate
        return 0
    fi
    local out_code ref_code ratio
    out_code=$(code_line_count "$outfile")
    ref_code=$(code_line_count "$reffile")
    if [ "$ref_code" -eq 0 ]; then
        echo "1.00"
        return 0
    fi
    ratio=$(echo "scale=2; $out_code / $ref_code" | bc 2>/dev/null || echo "0")
    echo "$ratio"
    if (( $(echo "$ratio < $SIZE_RATIO_MIN" | bc -l 2>/dev/null || echo 1) )); then
        return 1
    fi
    return 0
}

# Gate 1: Diff against cppfront reference output
# Prints similarity percentage (0-100). Higher = more similar.
compute_similarity() {
    local outfile="$1" reffile="$2"
    if [ ! -f "$reffile" ]; then
        echo "-"
        return
    fi
    local tmpout="/tmp/ckmake_out_$$" tmpref="/tmp/ckmake_ref_$$"
    # Strip boilerplate from both, sort for comm comparison
    grep -vE '^\s*$|^\s*//|^#include|^#line |^using ' "$outfile" 2>/dev/null | sort > "$tmpout"
    grep -vE '^\s*$|^\s*//|^#include|^#line |^using ' "$reffile" 2>/dev/null | sort > "$tmpref"
    local common ref_total
    common=$(comm -12 "$tmpout" "$tmpref" | wc -l | tr -d ' ')
    ref_total=$(wc -l < "$tmpref" | tr -d ' ')
    rm -f "$tmpout" "$tmpref"
    if [ "$ref_total" -eq 0 ]; then
        echo "100"
        return
    fi
    echo "scale=0; $common * 100 / $ref_total" | bc 2>/dev/null || echo "0"
}

# =============================================================================
# REGRESSION TESTS
# =============================================================================
# Anti-cheating: reset cppfront repo to clean state
reset_cppfront_repo() {
    log_info "Resetting cppfront repo to clean state..."
    (cd "$CPPFRONT_DIR" && git reset --hard HEAD 2>/dev/null)
    (cd "$CPPFRONT_DIR" && git clean -fdx 2>/dev/null)
}

# Anti-cheating: compute corpus SHA256 checksums
compute_corpus_sha256() {
    local checksums="$BUILD_DIR/corpus_sha256.txt"
    find "$REGRESSION_DIR" -name '*.cpp2' -type f | sort | xargs shasum -a 256 > "$checksums"
    echo "$checksums"
}

# Anti-cheating: verify corpus SHA256 checksums
verify_corpus_sha256() {
    local checksums="$1"
    if [ ! -f "$checksums" ]; then
        return 1
    fi
    (cd "$CPPFRONT_DIR" && shasum -a 256 -c "$checksums" --quiet 2>/dev/null)
}

# Anti-cheating: verify corpus integrity from git
verify_corpus_clean() {
    log_info "Verifying corpus integrity from git..."
    (cd "$CPPFRONT_DIR" && git diff --quiet -- regression-tests/ 2>/dev/null)
}

# Anti-cheating: reset corpus to git state before tests
checkout_corpus_clean() {
    log_info "Resetting corpus to git state (anti-cheating)..."
    (cd "$CPPFRONT_DIR" && git checkout -- regression-tests/ 2>/dev/null)
    (cd "$CPPFRONT_DIR" && git clean -fd -- regression-tests/ 2>/dev/null)
}

run_regression_tests() {
    local transpiler="${1:-$CPPFRONT_BIN}"
    local name_suffix=""
    local is_fort=false
    [ "$transpiler" = "$CPPFORT_BIN" ] && name_suffix="-fort" && is_fort=true

    log_section "Running cppfront regression tests using $(basename "$transpiler")$name_suffix"

    if [ ! -d "$REGRESSION_DIR" ]; then
        log_error "Regression tests not found: $REGRESSION_DIR"
        return 1
    fi

    # Anti-cheating: reset cppfront repo to known clean state
    reset_cppfront_repo

    # Anti-cheating: compute baseline SHA256 of corpus
    local baseline_checksums
    baseline_checksums=$(compute_corpus_sha256)
    log_info "Corpus provenance SHA256: $baseline_checksums"

    # Stage counters
    local tmpcounts="$BUILD_DIR/regression_counts.txt"
    echo "0 0 0" > "$tmpcounts"  # pass fail total

    local csv="$BUILD_DIR/regression_results.csv"
    echo "test,status,failed_stage,size_ratio,similarity,stages_reached" > "$csv"

    # Per-stage failure counters (written to temp files for subshell access)
    local stage_file="$BUILD_DIR/regression_stages.txt"
    : > "$stage_file"

    mkdir -p "$WORK_DIR/obj" "$WORK_DIR/bin" "$WORK_DIR/run"

    find "$REGRESSION_DIR" -name '*.cpp2' | sort | while read -r cpp2file; do
        [ -f "$cpp2file" ] || continue
        name=$(basename "$cpp2file" .cpp2)

        # Skip error tests (files ending with -error.cpp2)
        if [[ $name == *-error ]]; then
            echo "$name,SKIP,error_test,-,-,skip" >> "$csv"
            echo "skip" >> "$stage_file"
            continue
        fi

        cppfile="$WORK_DIR/${name}.cpp"
        objfile="$WORK_DIR/obj/${name}.o"
        binfile="$WORK_DIR/bin/${name}"
        ref_cpp="$REFERENCE_DIR/${name}.cpp"
        ref_output="$REFERENCE_EXEC_DIR/${name}.cpp.execution"
        status="FAIL"
        failed_stage=""
        size_ratio="-"
        similarity="-"
        stages_reached=""

        # ── Stage 1: Transpile ──────────────────────────────────────────
        local transpile_cmd=""
        if [ "$transpiler" = "$CPPFORT_BIN" ]; then
            transpile_cmd="timeout $TIMEOUT_COMPILE $transpiler $cpp2file $cppfile"
        else
            transpile_cmd="timeout $TIMEOUT_COMPILE $transpiler $cpp2file -o $cppfile"
        fi

        if ! eval "$transpile_cmd" 2> "$WORK_DIR/${name}_transpile.log"; then
            failed_stage="transpile"
            log_error "$name: transpile failed"
            echo "0 1 1" >> "$tmpcounts"
            echo "$name,$status,$failed_stage,$size_ratio,$similarity,$stages_reached" >> "$csv"
            echo "fail_transpile" >> "$stage_file"
            continue
        fi
        stages_reached="transpile"

        # ── Stage 2: Preprocess (strip cpp2util.h and #line noise) ──────
        gsed -i -e '/^#include "cpp2util.h"/d' -e '/^#line /d' "$cppfile" 2>/dev/null || true

        # ── Gate 4: Size gate (cppfort only) ────────────────────────────
        if $is_fort; then
            size_ratio=$(check_size_gate "$cppfile" "$ref_cpp") || true
            if [ "$size_ratio" != "1.00" ] && [ -f "$ref_cpp" ]; then
                if (( $(echo "$size_ratio < $SIZE_RATIO_MIN" | bc -l 2>/dev/null || echo 1) )); then
                    failed_stage="size_gate"
                    log_error "$name: STUB output (ratio=$size_ratio < $SIZE_RATIO_MIN)"
                    echo "0 1 1" >> "$tmpcounts"
                    echo "$name,$status,$failed_stage,$size_ratio,$similarity,$stages_reached" >> "$csv"
                    echo "fail_size_gate" >> "$stage_file"
                    continue
                fi
            fi
            stages_reached="$stages_reached+size_gate"
        fi

        # ── Gate 1: Diff similarity against reference (informational) ───
        if $is_fort; then
            similarity=$(compute_similarity "$cppfile" "$ref_cpp")
            stages_reached="$stages_reached+diff"
        fi

        # ── Gate 2: Full compile (not syntax-only) ──────────────────────
        local compile_flags
        if $is_fort; then
            compile_flags="$FORT_CXXFLAGS -I$PROJECT_ROOT/include -I$CPPFRONT_DIR/include"
        else
            compile_flags="-std=c++23 -I$PROJECT_ROOT/include -I$CPPFRONT_DIR/include"
        fi

        if ! timeout "$TIMEOUT_COMPILE" "$CXX" $compile_flags -c -o "$objfile" "$cppfile" \
            2> "$WORK_DIR/${name}_compile.log"; then
            failed_stage="compile"
            log_error "$name: compile failed"
            echo "0 1 1" >> "$tmpcounts"
            echo "$name,$status,$failed_stage,$size_ratio,$similarity,$stages_reached" >> "$csv"
            echo "fail_compile" >> "$stage_file"
            continue
        fi
        stages_reached="$stages_reached+compile"

        # ── Gate 3a: Link ───────────────────────────────────────────────
        local link_flags
        if $is_fort; then
            link_flags="$FORT_LDFLAGS"
        else
            link_flags="$CPPFRONT_LDFLAGS"
        fi

        if ! timeout "$TIMEOUT_COMPILE" "$CXX" $link_flags -o "$binfile" "$objfile" \
            2> "$WORK_DIR/${name}_link.log"; then
            failed_stage="link"
            log_warn "$name: link failed (compiled OK)"
            echo "0 1 1" >> "$tmpcounts"
            echo "$name,$status,$failed_stage,$size_ratio,$similarity,$stages_reached" >> "$csv"
            echo "fail_link" >> "$stage_file"
            continue
        fi
        stages_reached="$stages_reached+link"

        # ── Gate 3b: Runtime test (if expected output exists) ───────────
        if [ -f "$ref_output" ]; then
            local actual_output="$WORK_DIR/run/${name}.output"
            if timeout "$TIMEOUT_RUN" "$binfile" > "$actual_output" 2>&1; then
                if diff -q "$ref_output" "$actual_output" > /dev/null 2>&1; then
                    stages_reached="$stages_reached+run"
                else
                    failed_stage="run_mismatch"
                    local diff_lines
                    diff_lines=$(diff "$ref_output" "$actual_output" 2>/dev/null | grep -c '^[<>]' || echo "?")
                    log_warn "$name: runtime output mismatch ($diff_lines lines differ)"
                    echo "0 1 1" >> "$tmpcounts"
                    echo "$name,$status,$failed_stage,$size_ratio,$similarity,$stages_reached" >> "$csv"
                    echo "fail_run_mismatch" >> "$stage_file"
                    continue
                fi
            else
                local exit_code=$?
                if [ "$exit_code" -eq 124 ]; then
                    failed_stage="run_timeout"
                    log_warn "$name: runtime timeout (${TIMEOUT_RUN}s)"
                else
                    failed_stage="run_crash"
                    log_warn "$name: runtime crash (exit $exit_code)"
                fi
                echo "0 1 1" >> "$tmpcounts"
                echo "$name,$status,$failed_stage,$size_ratio,$similarity,$stages_reached" >> "$csv"
                echo "fail_$failed_stage" >> "$stage_file"
                continue
            fi
        else
            stages_reached="$stages_reached+run_skip"
        fi

        # ── PASS ────────────────────────────────────────────────────────
        status="PASS"
        log_ok "$name  (sim=${similarity}%)"
        echo "1 0 1" >> "$tmpcounts"
        echo "$name,$status,,$size_ratio,$similarity,$stages_reached" >> "$csv"
        echo "pass" >> "$stage_file"
    done

    # ── Summary ─────────────────────────────────────────────────────────
    local pass=0 fail=0 total=0
    while read -r p f t; do
        pass=$((pass + p))
        fail=$((fail + f))
        total=$((total + t))
    done < "$tmpcounts"

    local pct=$(echo "scale=1; $pass * 100 / $total" | bc 2>/dev/null || echo "0")

    # Per-stage breakdown
    local n_skip n_transpile n_size n_compile n_link n_run_mm n_run_crash n_run_to n_pass
    n_skip=$(grep -c '^skip$' "$stage_file" || true)
    n_transpile=$(grep -c '^fail_transpile$' "$stage_file" || true)
    n_size=$(grep -c '^fail_size_gate$' "$stage_file" || true)
    n_compile=$(grep -c '^fail_compile$' "$stage_file" || true)
    n_link=$(grep -c '^fail_link$' "$stage_file" || true)
    n_run_mm=$(grep -c '^fail_run_mismatch$' "$stage_file" || true)
    n_run_crash=$(grep -c '^fail_run_crash$' "$stage_file" || true)
    n_run_to=$(grep -c '^fail_run_timeout$' "$stage_file" || true)
    n_pass=$(grep -c '^pass$' "$stage_file" || true)

    log_section "Regression Results: $pass/$total passed ($pct%)"
    log_info "Results saved to: $csv"
    echo ""
    log_info "Stage breakdown:"
    log_info "  PASS:             $n_pass"
    [ "$n_skip" -gt 0 ]      && log_info "  SKIP (error):     $n_skip"
    [ "$n_transpile" -gt 0 ]  && log_info "  FAIL transpile:   $n_transpile"
    [ "$n_size" -gt 0 ]       && log_info "  FAIL size_gate:   $n_size  (output < ${SIZE_RATIO_MIN}x reference)"
    [ "$n_compile" -gt 0 ]    && log_info "  FAIL compile:     $n_compile"
    [ "$n_link" -gt 0 ]       && log_info "  FAIL link:        $n_link"
    [ "$n_run_mm" -gt 0 ]     && log_info "  FAIL run mismatch:$n_run_mm"
    [ "$n_run_crash" -gt 0 ]  && log_info "  FAIL run crash:   $n_run_crash"
    [ "$n_run_to" -gt 0 ]     && log_info "  FAIL run timeout: $n_run_to"

    # Anti-cheating: verify corpus SHA256 unchanged (detect LLM tampering)
    if ! verify_corpus_sha256 "$baseline_checksums"; then
        log_error "CHEATING DETECTED: corpus SHA256 mismatch - files modified during test run"
        log_info "Expected: $baseline_checksums"
        return 1
    fi
    log_ok "Corpus integrity verified: SHA256 unchanged"

    [ "$fail" -eq 0 ]
}

# =============================================================================
# PASSTHROUGH TESTS
# =============================================================================
run_passthrough_tests() {
    log_section "Running cppfront passthrough tests"

    if [ ! -d "$PASSROUGH_DIR" ]; then
        log_warn "Passthrough tests not found: $PASSROUGH_DIR"
        return 0
    fi

    local pass=0 fail=0

    for test_file in clang-12-libstdc++-e gcc-10-libstdc++-e msvc-msstl-e; do
        local cpp2file="$PASSROUGH_DIR/${test_file}.cpp2"
        local cppref="$PASSROUGH_DIR/${test_file}.cpp"
        local cppout="$WORK_DIR/${test_file}.cpp"

        if [ ! -f "$cpp2file" ] || [ ! -f "$cppref" ]; then
            log_warn "Skipping $test_file (files not found)"
            continue
        fi

        log_info "Testing: $test_file"

        if timeout "$TIMEOUT_COMPILE" "$CPPFRONT_BIN" "$cpp2file" -o "$cppout" 2>/dev/null; then
            if diff -q -w "$cppref" "$cppout" >/dev/null 2>&1; then
                log_ok "$test_file: PASSED"
                ((pass++))
            else
                log_error "$test_file: output mismatch"
                ((fail++))
            fi
        else
            log_error "$test_file: transpile failed"
            ((fail++))
        fi
    done

    log_section "Passthrough Results: $pass passed, $fail failed"
    [ "$fail" -eq 0 ]
}

# =============================================================================
# CORPUS TESTS
# =============================================================================
run_corpus_tests() {
    log_section "Running corpus tests"

    if [ ! -d "$CORPUS_DIR/inputs" ]; then
        log_warn "Corpus inputs not found: $CORPUS_DIR/inputs"
        log_info "Run 'scripts/import_cppfront_tests.sh --clone' to populate corpus"
        return 0
    fi

    local tmpcounts="$BUILD_DIR/corpus_counts.txt"
    echo "0 0 0" > "$tmpcounts"

    local csv="$BUILD_DIR/corpus_results.csv"
    echo "test,status" > "$csv"

    find "$CORPUS_DIR/inputs" -name '*.cpp2' 2>/dev/null | sort | while read -r cpp2file; do
        [ -f "$cpp2file" ] || continue
        name=$(basename "$cpp2file" .cpp2)
        cppfile="$WORK_DIR/corpus_${name}.cpp"

        if timeout "$TIMEOUT_COMPILE" "$CPPFRONT_BIN" "$cpp2file" -o "$cppfile" 2>/dev/null; then
            log_ok "$name"
            echo "$name,PASS" >> "$csv"
            echo "1 0 1" >> "$tmpcounts"
        else
            log_error "$name: transpile failed"
            echo "$name,FAIL" >> "$csv"
            echo "0 1 1" >> "$tmpcounts"
        fi
    done

    # Sum up counts
    local pass=0 fail=0 total=0
    while read -r p f t; do
        pass=$((pass + p))
        fail=$((fail + f))
        total=$((total + t))
    done < "$tmpcounts"

    local pct=$(echo "scale=1; $pass * 100 / $total" | bc 2>/dev/null || echo "0")
    log_section "Corpus Results: $pass/$total passed ($pct%)"
    log_info "Results saved to: $csv"

    [ "$fail" -eq 0 ]
}

# =============================================================================
# COMPARATIVE TESTS: cppfront vs cppfort (new parser)
# =============================================================================
run_comparative_tests() {
    local test_source="${1:-$REGRESSION_DIR}"
    local test_name="comparative"
    if [ "$1" = "corpus" ]; then
        test_source="$CORPUS_DIR/inputs"
        test_name="comparative_full_corpus"
    fi

    log_section "Comparative tests: cppfront vs cppfort ($test_name)"

    if [ ! -f "$CPPFRONT_BIN" ]; then
        log_error "cppfront not found. Run '$0 build' first."
        return 1
    fi

    if [ ! -f "$CPPFORT_BIN" ]; then
        log_error "cppfort not found. Run '$0 build-cppfort' first."
        return 1
    fi

    if [ ! -d "$test_source" ]; then
        log_error "Test source not found: $test_source"
        return 1
    fi

    local tmpcounts="$BUILD_DIR/${test_name}_counts.txt"
    echo "0 0 0" > "$tmpcounts"

    local csv="$BUILD_DIR/${test_name}_results.csv"
    echo "test,cppfront_status,cppfort_status,agreement" > "$csv"

    # Anti-cheating: reset and compute baseline SHA256
    if [ "$test_source" = "$REGRESSION_DIR" ]; then
        reset_cppfront_repo
        local baseline_checksums
        baseline_checksums=$(compute_corpus_sha256)
    fi

    local total=0

    find "$test_source" -name '*.cpp2' | sort | while read -r cpp2file; do
        [ -f "$cpp2file" ] || continue
        name=$(basename "$cpp2file" .cpp2)

        # Skip error tests
        if [[ $name == *-error ]]; then
            continue
        fi

        total=$((total + 1))

        local cppfront_cpp="$WORK_DIR/cppfront_${name}.cpp"
        local cppfort_cpp="$WORK_DIR/cppfort_${name}.cpp"
        local cppfront_status="FAIL" cppfort_status="FAIL"
        local agreement="disagree"

        # Test cppfront
        if timeout "$TIMEOUT_COMPILE" "$CPPFRONT_BIN" "$cpp2file" -o "$cppfront_cpp" 2>/dev/null; then
            gsed -i -e '/^#include "cpp2util.h"/d' -e '/^#line /d' "$cppfront_cpp" 2>/dev/null || true
            if timeout "$TIMEOUT_COMPILE" "$CXX" -std=c++23 -fsyntax-only "$cppfront_cpp" 2>/dev/null; then
                cppfront_status="PASS"
            fi
        fi

        # Test cppfort
        if timeout "$TIMEOUT_COMPILE" "$CPPFORT_BIN" "$cpp2file" "$cppfort_cpp" 2>/dev/null; then
            if timeout "$TIMEOUT_COMPILE" "$CXX" -std=c++23 -fsyntax-only "$cppfort_cpp" 2>/dev/null; then
                cppfort_status="PASS"
            fi
        fi

        # Determine agreement
        if [ "$cppfront_status" = "$cppfort_status" ]; then
            agreement="agree"
            if [ "$cppfront_status" = "PASS" ]; then
                echo "1 0 1" >> "$tmpcounts"
                log_ok "$name: BOTH PASS"
            else
                echo "0 0 1" >> "$tmpcounts"
            fi
        else
            echo "0 1 1" >> "$tmpcounts"
            if [ "$cppfront_status" = "PASS" ]; then
                log_warn "$name: cppfront PASS, cppfort FAIL"
            else
                log_info "$name: cppfront FAIL, cppfort PASS (new parser wins)"
            fi
        fi

        echo "$name,$cppfront_status,$cppfort_status,$agreement" >> "$csv"
    done

    # Sum up counts
    local pass=0 fail=0 disagree=0 total_tests=0
    while read -r p f d t; do
        pass=$((pass + p))
        fail=$((fail + f))
        disagree=$((disagree + d))
        total_tests=$((total_tests + t))
    done < "$tmpcounts"

    local pct_agree=$(echo "scale=1; ($pass + $fail) * 100 / $total_tests" | bc 2>/dev/null || echo "0")
    log_section "Comparative Results: $pass/$total_tests both pass, $disagree disagree ($pct_agree% agreement)"
    log_info "Results saved to: $csv"

    # Anti-cheating: verify SHA256 unchanged (only for regression tests)
    if [ "$test_source" = "$REGRESSION_DIR" ]; then
        if ! verify_corpus_sha256 "$baseline_checksums"; then
            log_error "CHEATING DETECTED: corpus SHA256 mismatch"
            return 1
        fi
    fi

    [ "$disagree" -eq 0 ]
}

# =============================================================================
# ALL TESTS
# =============================================================================
run_all_tests() {
    local all_pass=true

    run_regression_tests || all_pass=false
    run_passthrough_tests || all_pass=false
    run_corpus_tests || all_pass=false

    if $all_pass; then
        log_ok "All tests passed"
        return 0
    else
        log_error "Some tests failed"
        return 1
    fi
}

# =============================================================================
# MAIN
# =============================================================================
show_usage() {
    cat <<EOF
ckmake - clean build and test runner for cppfront/cppfort

Usage: $0 <command>

Commands:
    build       Clean build of cppfront
    build-cppfort   Build cppfort (new parser via CMake)
    update      Pull latest hsutter/cppfront version
    test        Run all tests (regression, passthrough, corpus)
    regression  Run regression tests only (using cppfront)
    regression-fort Run regression tests using cppfort (new parser)
    passthrough Run passthrough tests only
    corpus      Run corpus tests only
    compare     Comparative tests: cppfront vs cppfort (regression tests)
    compare-corpus Comparative tests: cppfront vs cppfort (full corpus)
    all         Update, build, and test (full cycle)
    clean       Remove build directory
    help        Show this message

Environment:
    BUILD_DIR   Build directory (default: project_root/build_clean)
    TIMEOUT_BUILD  Build timeout in seconds (default: 120)
    TIMEOUT_COMPILE Compile timeout in seconds (default: 30)
    TIMEOUT_RUN    Run timeout in seconds (default: 5)

Examples:
    $0 all              # Full cycle: update, build, test
    $0 build && $0 test # Build then test
    $0 build-cppfort && $0 compare  # Build new parser and compare
    $0 compare-corpus   # Run comparative tests on full corpus (190 tests)
    BUILD_DIR=/tmp/cp $0 all  # Use custom build directory
EOF
}

main() {
    local command="${1:-help}"

    check_dependencies || exit 1

    case "$command" in
        build)
            clean_build_dir
            build_cppfront
            ;;
        build-cppfort)
            build_cppfort
            ;;
        update)
            update_cppfront
            ;;
        test)
            run_all_tests
            ;;
        regression)
            run_regression_tests "$CPPFRONT_BIN"
            ;;
        regression-fort)
            run_regression_tests "$CPPFORT_BIN"
            ;;
        passthrough)
            run_passthrough_tests
            ;;
        corpus)
            run_corpus_tests
            ;;
        compare)
            run_comparative_tests
            ;;
        compare-corpus)
            run_comparative_tests corpus
            ;;
        all)
            update_cppfront
            clean_build_dir
            build_cppfront
            run_all_tests
            ;;
        clean)
            rm -rf "$BUILD_DIR"
            log_ok "Build directory removed"
            ;;
        help|--help|-h)
            show_usage
            ;;
        *)
            log_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

main "$@"
