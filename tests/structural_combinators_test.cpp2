#include "combinators/structural.hpp"
#include <iostream>
#include <vector>
#include <cassert>

test_take: () = {
    std::cout << "test_take\n";
    data: std::string = "0123456789";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // take first 5
    result := cpp2::combinators::take(buf, 5);
    count := 0;
    for result do (c) {
        count++;
    }
    assert(count == 5);
    
    // take more than available
    result2 := cpp2::combinators::take(buf, 100);
    count2 := 0;
    for result2 do (c) {
        count2++;
    }
    assert(count2 == 10);
    
    // take 0
    result3 := cpp2::combinators::take(buf, 0);
    count3 := 0;
    for result3 do (c) {
        count3++;
    }
    assert(count3 == 0);
    
    std::cout << "  PASS\n";
}

test_skip: () = {
    std::cout << "test_skip\n";
    data: std::string = "0123456789";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // skip first 5 -> should have 5 remaining
    result := cpp2::combinators::skip(buf, 5);
    count := 0;
    for result do (c) {
        count++;
    }
    assert(count == 5);
    
    // skip more than size -> empty
    result2 := cpp2::combinators::skip(buf, 100);
    count2 := 0;
    for result2 do (c) {
        count2++;
    }
    assert(count2 == 0);
    
    // skip 0 -> all 10
    result3 := cpp2::combinators::skip(buf, 0);
    count3 := 0;
    for result3 do (c) {
        count3++;
    }
    assert(count3 == 10);
    
    std::cout << "  PASS\n";
}

test_slice: () = {
    std::cout << "test_slice\n";
    data: std::string = "0123456789";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // slice(2, 7) -> 5 elements
    result := cpp2::combinators::slice(buf, 2, 7);
    count := 0;
    for result do (c) {
        count++;
    }
    assert(count == 5);
    
    // slice(0, 10) -> all 10
    result2 := cpp2::combinators::slice(buf, 0, 10);
    count2 := 0;
    for result2 do (c) {
        count2++;
    }
    assert(count2 == 10);
    
    // slice(5, 5) -> 0 elements
    result3 := cpp2::combinators::slice(buf, 5, 5);
    count3 := 0;
    for result3 do (c) {
        count3++;
    }
    assert(count3 == 0);
    
    std::cout << "  PASS\n";
}

test_split: () = {
    std::cout << "test_split\n";
    data: std::string = "hello world test";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // split by space -> 3 chunks
    space: char = 0x20;
    result := cpp2::combinators::split(buf, space);
    parts: std::vector<cpp2::ByteBuffer> = ();
    for result do (chunk) {
        parts.push_back(chunk);
    }
    
    assert(parts.size() == 3);
    assert(parts[0].size() == 5); // "hello"
    assert(parts[1].size() == 5); // "world"
    assert(parts[2].size() == 4); // "test"
    
    // Verify zero-copy: pointers point into original data
    assert(parts[0].data() == data.data());
    assert(parts[1].data() == data.data() + 6);
    
    std::cout << "  PASS\n";
}

test_split_edge_cases: () = {
    std::cout << "test_split_edge_cases\n";
    
    // Empty buffer
    empty: std::string = "";
    buf1: cpp2::ByteBuffer = (empty.data(), empty.size());
    comma: char = 0x2C;
    result1 := cpp2::combinators::split(buf1, comma);
    cnt1 := 0;
    for result1 do (chunk) {
        cnt1++;
    }
    assert(cnt1 == 1); // One empty chunk
    
    // No delimiter in buffer
    no_delim: std::string = "hello";
    buf2: cpp2::ByteBuffer = (no_delim.data(), no_delim.size());
    result2 := cpp2::combinators::split(buf2, comma);
    cnt2 := 0;
    for result2 do (chunk) {
        cnt2++;
    }
    assert(cnt2 == 1);
    
    // Consecutive delimiters
    consec: std::string = "a,,b";
    buf3: cpp2::ByteBuffer = (consec.data(), consec.size());
    result3 := cpp2::combinators::split(buf3, comma);
    cnt3 := 0;
    for result3 do (chunk) {
        cnt3++;
    }
    assert(cnt3 == 3); // "a", "", "b"
    
    std::cout << "  PASS\n";
}

test_chunk: () = {
    std::cout << "test_chunk\n";
    data: std::string = "0123456789";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // chunk(3) -> 4 chunks (3, 3, 3, 1)
    result := cpp2::combinators::chunk(buf, 3);
    chunks: std::vector<cpp2::ByteBuffer> = ();
    for result do (c) {
        chunks.push_back(c);
    }
    
    assert(chunks.size() == 4);
    assert(chunks[0].size() == 3);
    assert(chunks[1].size() == 3);
    assert(chunks[2].size() == 3);
    assert(chunks[3].size() == 1); // Last chunk smaller
    
    // Verify zero-copy
    assert(chunks[0].data() == data.data());
    assert(chunks[1].data() == data.data() + 3);
    
    std::cout << "  PASS\n";
}

test_chunk_edge_cases: () = {
    std::cout << "test_chunk_edge_cases\n";
    
    // Empty buffer
    empty: std::string = "";
    buf1: cpp2::ByteBuffer = (empty.data(), empty.size());
    result1 := cpp2::combinators::chunk(buf1, 3);
    cnt1 := 0;
    for result1 do (c) {
        cnt1++;
    }
    assert(cnt1 == 0);
    
    // Chunk size larger than buffer
    small: std::string = "ab";
    buf2: cpp2::ByteBuffer = (small.data(), small.size());
    result2 := cpp2::combinators::chunk(buf2, 10);
    cnt2 := 0;
    size2: size_t = 0;
    for result2 do (c) {
        cnt2++;
        size2 = c.size();
    }
    assert(cnt2 == 1);
    assert(size2 == 2);
    
    std::cout << "  PASS\n";
}

test_window: () = {
    std::cout << "test_window\n";
    data: std::string = "01234";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // window(3) -> 3 windows: [012], [123], [234]
    result := cpp2::combinators::window(buf, 3);
    windows: std::vector<cpp2::ByteBuffer> = ();
    for result do (w) {
        windows.push_back(w);
    }
    
    assert(windows.size() == 3);
    assert(windows[0].size() == 3);
    assert(windows[1].size() == 3);
    assert(windows[2].size() == 3);
    
    // Verify overlapping: windows overlap by (size-1)
    assert(windows[0].data() == data.data());
    assert(windows[1].data() == data.data() + 1);
    assert(windows[2].data() == data.data() + 2);
    
    std::cout << "  PASS\n";
}

test_window_edge_cases: () = {
    std::cout << "test_window_edge_cases\n";
    
    // Window larger than buffer -> no windows
    small: std::string = "ab";
    buf1: cpp2::ByteBuffer = (small.data(), small.size());
    result1 := cpp2::combinators::window(buf1, 5);
    cnt1 := 0;
    for result1 do (w) {
        cnt1++;
    }
    assert(cnt1 == 0);
    
    // Window same size as buffer -> 1 window
    exact: std::string = "abc";
    buf2: cpp2::ByteBuffer = (exact.data(), exact.size());
    result2 := cpp2::combinators::window(buf2, 3);
    cnt2 := 0;
    for result2 do (w) {
        cnt2++;
    }
    assert(cnt2 == 1);
    
    std::cout << "  PASS\n";
}

test_curried_pipe: () = {
    std::cout << "test_curried_pipe\n";
    data: std::string = "0123456789";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Use curried combinators with pipe operator
    skipped := cpp2::combinators::skip(buf, 2);
    result := cpp2::combinators::take(skipped, 5);
    cnt := 0;
    for result do (c) {
        cnt++;
    }
    assert(cnt == 5);
    
    std::cout << "  PASS\n";
}

test_zero_copy_invariant: () = {
    std::cout << "test_zero_copy_invariant\n";
    data: std::string = "hello world";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // All operations should return views pointing into original data
    // split
    space: char = 0x20;
    split_result := cpp2::combinators::split(buf, space);
    for split_result do (chunk) {
        // chunk.data() must be >= buf.data() and < buf.data() + buf.size()
        assert(chunk.data() >= buf.data());
        assert(chunk.data() <= buf.data() + buf.size());
    }
    
    // chunk
    chunk_res := cpp2::combinators::chunk(buf, 3);
    for chunk_res do (chunk) {
        assert(chunk.data() >= buf.data());
        assert(chunk.data() <= buf.data() + buf.size());
    }
    
    // window
    window_result := cpp2::combinators::window(buf, 3);
    for window_result do (w) {
        assert(w.data() >= buf.data());
        assert(w.data() <= buf.data() + buf.size());
    }
    
    std::cout << "  PASS\n";
}

main: () = {
    std::cout << "=== Structural Combinators Tests ===\n";
    
    test_take();
    test_skip();
    test_slice();
    test_split();
    test_split_edge_cases();
    test_chunk();
    test_chunk_edge_cases();
    test_window();
    test_window_edge_cases();
    test_curried_pipe();
    test_zero_copy_invariant();
    
    std::cout << "\nAll tests passed!\n";
}
