// selfhost_bbcursive_smoke.cpp2 — smoke test for bbcursive
// Pure cpp2.  No mixed cpp1.  Includes bbcursive.h2 for types.

#include "bbcursive.h2"

cpp2: namespace = {

test_tokenize: () -> bool = {
    tokens := lex("foo: int = 42;");
    word_count := 0;
    i: int = 0;
    while i < tokens.ssize() {
        if tokens[i].k == kind::word { word_count += 1; }
        i += 1;
    }
    return word_count == 2;
}

test_single_tag: () -> bool = {
    result := parse_source("my_tag: int = 42;");
    if !result.has_value() { return false; }
    nodes := result.value();
    return nodes.ssize() == 1 && nodes[0].semantic == "bootstrap_tag_declaration";
}

test_multiple_tags: () -> bool = {
    result := parse_source("alpha: int = 1;\nbeta: int = 2;\n");
    if !result.has_value() { return false; }
    return result.value().ssize() == 2;
}

test_comments_skipped: () -> bool = {
    result := parse_source("// comment\nvisible: int = 10;\n// hidden: int = 99;\nother: int = 20;\n");
    if !result.has_value() { return false; }
    return result.value().ssize() == 2;
}

test_struct_decl: () -> bool = {
    result := parse_source("my_type: @struct type = { field: int = 0; }");
    if !result.has_value() { return false; }
    nodes := result.value();
    return nodes.ssize() == 1 && nodes[0].semantic == "struct_declaration";
}

test_enum_decl: () -> bool = {
    result := parse_source("color: @enum type = { red; green; blue; }");
    if !result.has_value() { return false; }
    nodes := result.value();
    return nodes.ssize() == 1 && nodes[0].semantic == "enum";
}

test_function_decl: () -> bool = {
    result := parse_source("add: (x: int, y: int) -> int = { return x + y; }");
    if !result.has_value() { return false; }
    nodes := result.value();
    return nodes.ssize() == 1 && nodes[0].semantic == "function_declaration";
}

main: () -> int = {
    pass := 0;
    fail := 0;

    tests := :(name: std::string_view, fn: () -> bool) = {
        if fn() {
            std::cerr << "PASS: " << name << "\n";
            pass += 1;
        } else {
            std::cerr << "FAIL: " << name << "\n";
            fail += 1;
        }
    };

    tests("tokenize", test_tokenize);
    tests("single_tag", test_single_tag);
    tests("multiple_tags", test_multiple_tags);
    tests("comments_skipped", test_comments_skipped);
    tests("struct_decl", test_struct_decl);
    tests("enum_decl", test_enum_decl);
    tests("function_decl", test_function_decl);

    std::cerr << pass << " passed, " << fail << " failed\n";
    return fail > 0 ? 1 : 0;
}

}
