// Parsing Combinators Unit Tests
// Tests for byte parsers, endian readers, string parsers, validation predicates

#include "../include/bytebuffer.hpp"
#include "../include/combinators/parsing.hpp"
#include <vector>
#include <string>
#include <iostream>
#include <cassert>
#include <cstddef>
#include <cstdint>

// ============================================================================
// byte() tests
// ============================================================================

test_byte_basic: () -> void = {
    data: std::string = "ABC";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::byte(buf);
    
    assert(result.has_value());
    assert(result.value().value == 65);  // 'A'
    assert(result.value().remaining.size() == 2);
    
    std::cout << "test_byte_basic: PASS\n";
}

test_byte_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::byte(buf);
    
    assert(!result.has_value());
    std::cout << "test_byte_empty: PASS\n";
}

test_byte_chain: () -> void = {
    data: std::string = "ABC";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    r1 := cpp2::combinators::byte(buf);
    assert(r1.has_value() && r1.value().value == 65);
    
    r2 := cpp2::combinators::byte(r1.value().remaining);
    assert(r2.has_value() && r2.value().value == 66);
    
    r3 := cpp2::combinators::byte(r2.value().remaining);
    assert(r3.has_value() && r3.value().value == 67);
    
    r4 := cpp2::combinators::byte(r3.value().remaining);
    assert(!r4.has_value());  // Empty now
    
    std::cout << "test_byte_chain: PASS\n";
}

// ============================================================================
// bytes(n) tests
// ============================================================================

test_bytes_basic: () -> void = {
    data: std::string = "Hello World";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::bytes(buf, 5);
    
    assert(result.has_value());
    assert(result.value().value.size() == 5);
    assert(result.value().remaining.size() == 6);
    
    // Verify zero-copy
    assert(result.value().value.data() == buf.data());
    
    std::cout << "test_bytes_basic: PASS\n";
}

test_bytes_insufficient: () -> void = {
    data: std::string = "Hi";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::bytes(buf, 10);
    
    assert(!result.has_value());
    std::cout << "test_bytes_insufficient: PASS\n";
}

test_bytes_exact: () -> void = {
    data: std::string = "exact";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::bytes(buf, 5);
    
    assert(result.has_value());
    assert(result.value().value.size() == 5);
    assert(result.value().remaining.size() == 0);
    
    std::cout << "test_bytes_exact: PASS\n";
}

// ============================================================================
// until() tests
// ============================================================================

test_until_basic: () -> void = {
    terminator: uint8_t = 0x00;
    // "Hello\0" using hex codes
    hello: std::array<char, 6> = (0x48, 0x65, 0x6C, 0x6C, 0x6F, 0x00);
    buf: cpp2::ByteBuffer = (hello.data(), hello.size());
    
    result := cpp2::combinators::until(buf, terminator);
    
    assert(result.has_value());
    assert(result.value().value.size() == 5);  // "Hello"
    assert(result.value().remaining.size() == 0);  // After null
    
    std::cout << "test_until_basic: PASS\n";
}

test_until_not_found: () -> void = {
    data: std::string = "no terminator here";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::until(buf, 0x00);
    
    assert(!result.has_value());
    std::cout << "test_until_not_found: PASS\n";
}

test_until_at_start: () -> void = {
    terminator: uint8_t = 0x00;
    // "\0AB" using hex codes
    data: std::array<char, 3> = (0x00, 0x41, 0x42);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::until(buf, terminator);
    
    assert(result.has_value());
    assert(result.value().value.size() == 0);  // Empty before terminator
    assert(result.value().remaining.size() == 2);  // "AB"
    
    std::cout << "test_until_at_start: PASS\n";
}

// ============================================================================
// while_pred() tests
// ============================================================================

test_while_pred_digits: () -> void = {
    data: std::string = "12345abc";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::while_pred(buf, 
        :(b: uint8_t) -> bool = { return b >= 0x30 && b <= 0x39; });  // '0'-'9'
    
    assert(result.value.size() == 5);  // "12345"
    assert(result.remaining.size() == 3);  // "abc"
    
    std::cout << "test_while_pred_digits: PASS\n";
}

test_while_pred_none_match: () -> void = {
    data: std::string = "abc123";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::while_pred(buf, 
        :(b: uint8_t) -> bool = { return b >= 0x30 && b <= 0x39; });
    
    assert(result.value.size() == 0);  // No leading digits
    assert(result.remaining.size() == 6);
    
    std::cout << "test_while_pred_none_match: PASS\n";
}

test_while_pred_all_match: () -> void = {
    data: std::string = "12345";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::while_pred(buf, 
        :(b: uint8_t) -> bool = { return b >= 0x30 && b <= 0x39; });
    
    assert(result.value.size() == 5);
    assert(result.remaining.size() == 0);
    
    std::cout << "test_while_pred_all_match: PASS\n";
}

// ============================================================================
// Little-endian integer tests
// ============================================================================

test_le_u16: () -> void = {
    data: std::array<char, 4> = (0x34, 0x12, 0xFF as char, 0xFF as char);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::le_u16(buf);
    
    assert(result.has_value());
    assert(result.value().value == 0x1234);
    assert(result.value().remaining.size() == 2);
    
    std::cout << "test_le_u16: PASS\n";
}

test_le_u32: () -> void = {
    data: std::array<char, 4> = (0x78, 0x56, 0x34, 0x12);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::le_u32(buf);
    
    assert(result.has_value());
    assert(result.value().value == 0x12345678);
    
    std::cout << "test_le_u32: PASS\n";
}

test_le_u64: () -> void = {
    data: std::array<char, 8> = (0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::le_u64(buf);
    
    assert(result.has_value());
    assert(result.value().value == 0x0807060504030201);
    
    std::cout << "test_le_u64: PASS\n";
}

test_le_insufficient: () -> void = {
    single: char = 0x12;
    buf: cpp2::ByteBuffer = (single&, 1);
    
    r16 := cpp2::combinators::le_u16(buf);
    r32 := cpp2::combinators::le_u32(buf);
    r64 := cpp2::combinators::le_u64(buf);
    
    assert(!r16.has_value());
    assert(!r32.has_value());
    assert(!r64.has_value());
    
    std::cout << "test_le_insufficient: PASS\n";
}

// ============================================================================
// Big-endian integer tests
// ============================================================================

test_be_u16: () -> void = {
    data: std::array<char, 4> = (0x12, 0x34, 0xFF as char, 0xFF as char);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::be_u16(buf);
    
    assert(result.has_value());
    assert(result.value().value == 0x1234);
    
    std::cout << "test_be_u16: PASS\n";
}

test_be_u32: () -> void = {
    data: std::array<char, 4> = (0x12, 0x34, 0x56, 0x78);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::be_u32(buf);
    
    assert(result.has_value());
    assert(result.value().value == 0x12345678);
    
    std::cout << "test_be_u32: PASS\n";
}

test_be_u64: () -> void = {
    data: std::array<char, 8> = (0x08, 0x07, 0x06, 0x05, 0x04, 0x03, 0x02, 0x01);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::be_u64(buf);
    
    assert(result.has_value());
    assert(result.value().value == 0x0807060504030201);
    
    std::cout << "test_be_u64: PASS\n";
}

// ============================================================================
// Signed integer tests
// ============================================================================

test_signed_integers: () -> void = {
    // -1 in little-endian 16-bit
    neg_data: std::array<char, 2> = (0xFF as char, 0xFF as char);
    buf: cpp2::ByteBuffer = (neg_data.data(), neg_data.size());
    
    result := cpp2::combinators::le_i16(buf);
    
    assert(result.has_value());
    assert(result.value().value == -1);
    
    std::cout << "test_signed_integers: PASS\n";
}

// ============================================================================
// String parser tests
// ============================================================================

test_c_str: () -> void = {
    terminator: uint8_t = 0x00;
    // "Hello\0XYZ\0" using hex codes
    data: std::array<char, 10> = (0x48, 0x65, 0x6C, 0x6C, 0x6F, 0x00, 0x58, 0x59, 0x5A, 0x00);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::c_str(buf);
    
    assert(result.has_value());
    assert(result.value().value.size() == 5);  // "Hello"
    assert(result.value().remaining.size() == 4);  // "XYZ\0"
    
    std::cout << "test_c_str: PASS\n";
}

test_pascal_string: () -> void = {
    // Length byte (5) followed by "HelloXY" using hex codes
    data: std::array<char, 8> = (0x05, 0x48, 0x65, 0x6C, 0x6C, 0x6F, 0x58, 0x59);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::pascal_string(buf);
    
    assert(result.has_value());
    assert(result.value().value.size() == 5);  // "Hello"
    assert(result.value().remaining.size() == 2);  // "XY"
    
    std::cout << "test_pascal_string: PASS\n";
}

test_pascal_string_insufficient: () -> void = {
    // Length says 10, but only 3 bytes follow - "ABC" using hex
    data: std::array<char, 4> = (0x0A, 0x41, 0x42, 0x43);
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::pascal_string(buf);
    
    assert(!result.has_value());
    std::cout << "test_pascal_string_insufficient: PASS\n";
}

// ============================================================================
// Validation predicate tests
// ============================================================================

test_length_predicates: () -> void = {
    data: std::string = "Hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    assert(cpp2::combinators::length_eq(buf, 5) == true);
    assert(cpp2::combinators::length_eq(buf, 4) == false);
    assert(cpp2::combinators::length_ge(buf, 5) == true);
    assert(cpp2::combinators::length_ge(buf, 6) == false);
    assert(cpp2::combinators::length_le(buf, 5) == true);
    assert(cpp2::combinators::length_le(buf, 4) == false);
    assert(cpp2::combinators::length_between(buf, 3, 7) == true);
    assert(cpp2::combinators::length_between(buf, 6, 10) == false);
    
    std::cout << "test_length_predicates: PASS\n";
}

test_starts_ends_with: () -> void = {
    data: std::string = "Hello World";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    hello: std::string = "Hello";
    world: std::string = "World";
    xyz: std::string = "xyz";
    
    prefix: cpp2::ByteBuffer = (hello.data(), hello.size());
    suffix: cpp2::ByteBuffer = (world.data(), world.size());
    bad: cpp2::ByteBuffer = (xyz.data(), xyz.size());
    
    assert(cpp2::combinators::starts_with(buf, prefix) == true);
    assert(cpp2::combinators::starts_with(buf, bad) == false);
    assert(cpp2::combinators::ends_with(buf, suffix) == true);
    assert(cpp2::combinators::ends_with(buf, bad) == false);
    
    std::cout << "test_starts_ends_with: PASS\n";
}

test_contains: () -> void = {
    data: std::string = "Hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    assert(cpp2::combinators::contains(buf, 'e' as uint8_t) == true);
    assert(cpp2::combinators::contains(buf, 'x' as uint8_t) == false);
    
    std::cout << "test_contains: PASS\n";
}

test_is_sorted: () -> void = {
    sorted_data: std::string = "ABCDE";
    unsorted_data: std::string = "ACDBE";
    
    sorted_buf: cpp2::ByteBuffer = (sorted_data.data(), sorted_data.size());
    unsorted_buf: cpp2::ByteBuffer = (unsorted_data.data(), unsorted_data.size());
    
    assert(cpp2::combinators::is_sorted(sorted_buf) == true);
    assert(cpp2::combinators::is_sorted(unsorted_buf) == false);
    
    std::cout << "test_is_sorted: PASS\n";
}

test_is_unique: () -> void = {
    unique_data: std::string = "ABCDE";
    dup_data: std::string = "ABCDA";
    
    unique_buf: cpp2::ByteBuffer = (unique_data.data(), unique_data.size());
    dup_buf: cpp2::ByteBuffer = (dup_data.data(), dup_data.size());
    
    assert(cpp2::combinators::is_unique(unique_buf) == true);
    assert(cpp2::combinators::is_unique(dup_buf) == false);
    
    std::cout << "test_is_unique: PASS\n";
}

test_all_any_none: () -> void = {
    data: std::string = "ABC";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // All uppercase?
    assert(cpp2::combinators::all_of(buf, :(b: uint8_t) -> bool = { return b >= 0x41 && b <= 0x5A; }) == true);
    
    // Any lowercase?
    assert(cpp2::combinators::any_of(buf, :(b: uint8_t) -> bool = { return b >= 0x61 && b <= 0x7A; }) == false);
    
    // None lowercase?
    assert(cpp2::combinators::none_of(buf, :(b: uint8_t) -> bool = { return b >= 0x61 && b <= 0x7A; }) == true);
    
    std::cout << "test_all_any_none: PASS\n";
}

// ============================================================================
// Parser chaining tests
// ============================================================================

test_parser_chaining: () -> void = {
    // Simulate a simple binary header: 2-byte length (LE) + "Hello"
    header: std::array<char, 7> = (0x05, 0x00, 0x48, 0x65, 0x6C, 0x6C, 0x6F);
    buf: cpp2::ByteBuffer = (header.data(), header.size());
    
    // Parse length
    len_result := cpp2::combinators::le_u16(buf);
    assert(len_result.has_value());
    assert(len_result.value().value == 5);
    
    // Parse data
    data_result := cpp2::combinators::bytes(len_result.value().remaining, len_result.value().value);
    assert(data_result.has_value());
    assert(data_result.value().value.size() == 5);
    
    std::cout << "test_parser_chaining: PASS\n";
}

// ============================================================================
// Main
// ============================================================================

main: () -> int = {
    std::cout << "=== Parsing Combinators Tests ===\n\n";
    
    // byte tests
    test_byte_basic();
    test_byte_empty();
    test_byte_chain();
    
    // bytes tests
    test_bytes_basic();
    test_bytes_insufficient();
    test_bytes_exact();
    
    // until tests
    test_until_basic();
    test_until_not_found();
    test_until_at_start();
    
    // while_pred tests
    test_while_pred_digits();
    test_while_pred_none_match();
    test_while_pred_all_match();
    
    // little-endian tests
    test_le_u16();
    test_le_u32();
    test_le_u64();
    test_le_insufficient();
    
    // big-endian tests
    test_be_u16();
    test_be_u32();
    test_be_u64();
    
    // signed integer tests
    test_signed_integers();
    
    // string parser tests
    test_c_str();
    test_pascal_string();
    test_pascal_string_insufficient();
    
    // validation predicate tests
    test_length_predicates();
    test_starts_ends_with();
    test_contains();
    test_is_sorted();
    test_is_unique();
    test_all_any_none();
    
    // chaining tests
    test_parser_chaining();
    
    std::cout << "\n=== All parsing combinator tests passed! ===\n";
    return 0;
}
