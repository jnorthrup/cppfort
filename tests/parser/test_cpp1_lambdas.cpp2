// Test C++1 lambda parsing
// This should parse and transpile correctly

// Test 1: Simple lambda
auto test_simple() {
    return [](){ return 42; };
}

// Test 2: Lambda with capture
auto test_capture() {
    auto x = 10;
    return [=](){ return x; };
}

// Test 3: Lambda with params
auto test_params() {
    return [](int x){ return x * 2; };
}

// Test 4: Lambda with capture and params
auto test_full() {
    auto x = 10;
    return [=](int y){ return x + y; };
}

main: () -> int = {
    auto r1 = test_simple();
    auto r2 = test_capture();
    auto r3 = test_params(5);
    auto r4 = test_full(5);
    return 0;
}
