#include <cstdint>

// ============================================================================
// Recipe 1: HTTP Header Parsing
// ============================================================================

// Parse a single HTTP header line "Key: Value"
parse_header_line: (line: cpp2::ByteBuffer) -> std::optional<std::pair<std::string, std::string>> = {
    if line.empty() { return std::nullopt; }
    
    // Find colon separator
    data := line.data();
    size := line.size();
    colon_pos: size_t = 0;
    found := false;
    
    i := 0;
    while i < size {
        if data[i] == ':' {
            colon_pos = i;
            found = true;
            break;
        }
        i++;
    }
    
    if !found { return std::nullopt; }
    
    // Key is before colon
    key_buf := line.slice(0, colon_pos);
    
    // Value is after colon, skip leading space
    value_start := colon_pos + 1;
    while value_start < size && data[value_start] == ' ' {
        value_start++;
    }
    value_buf := line.slice(value_start, size);
    
    // Strip trailing whitespace from value
    value_end := value_buf.size();
    while value_end > 0 && (value_buf.data()[value_end - 1] == '\r' || value_buf.data()[value_end - 1] == '\n' || value_buf.data()[value_end - 1] == ' ') {
        value_end--;
    }
    
    key := std::string(key_buf.data(), key_buf.size());
    value := std::string(value_buf.data(), value_end);
    
    return std::make_pair(key, value);
}

// Parse HTTP headers from buffer
parse_http_headers: (buf: cpp2::ByteBuffer) -> std::map<std::string, std::string> = {
    result: std::map<std::string, std::string> = ();
    
    // Split by newline
    lines := cpp2::combinators::split(buf, '\n');
    
    for lines do (line) {
        header := parse_header_line(line);
        if header.has_value() {
            result[header.value().first] = header.value().second;
        }
    }
    
    return result;
}

test_http_header_parsing: () -> void = {
    std::cout << "test_http_header_parsing\n";
    
    http_data: std::string = "Content-Type: application/json\nContent-Length: 42\nX-Custom-Header: some value\n";
    buf: cpp2::ByteBuffer = (http_data.data(), http_data.size());
    
    headers := parse_http_headers(buf);
    
    assert(headers.size() == 3);
    assert(headers["Content-Type"] == "application/json");
    assert(headers["Content-Length"] == "42");
    assert(headers["X-Custom-Header"] == "some value");
    
    std::cout << "  PASS\n";
}

test_http_header_with_crlf: () -> void = {
    std::cout << "test_http_header_with_crlf\n";
    
    http_data: std::string = "Host: example.com\r\nUser-Agent: test\r\n\r\n";
    buf: cpp2::ByteBuffer = (http_data.data(), http_data.size());
    
    headers := parse_http_headers(buf);
    
    assert(headers.size() >= 2);
    assert(headers["Host"] == "example.com");
    assert(headers["User-Agent"] == "test");
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 2: Null-Terminated String
// ============================================================================

// Read null-terminated C string
read_c_string: (buf: cpp2::ByteBuffer) -> cpp2::ByteBuffer = {
    data := buf.data();
    size := buf.size();
    
    // Find null terminator
    null_pos: size_t = 0;
    while null_pos < size && data[null_pos] != '\0' {
        null_pos++;
    }
    
    return buf.slice(0, null_pos);
}

test_c_string_parsing: () -> void = {
    std::cout << "test_c_string_parsing\n";
    
    // Buffer with null-terminated string followed by garbage
    data: std::array<char, 15> = ('H', 'e', 'l', 'l', 'o', '\0', 'g', 'a', 'r', 'b', 'a', 'g', 'e', '!', '!');
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    str := read_c_string(buf);
    
    assert(str.size() == 5);
    result := std::string(str.data(), str.size());
    assert(result == "Hello");
    
    std::cout << "  PASS\n";
}

test_c_string_no_null: () -> void = {
    std::cout << "test_c_string_no_null\n";
    
    // Buffer without null terminator - should return entire buffer
    data: std::string = "NoNull";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    str := read_c_string(buf);
    
    assert(str.size() == 6);
    
    std::cout << "  PASS\n";
}

test_c_string_empty: () -> void = {
    std::cout << "test_c_string_empty\n";
    
    // Empty string (just null)
    data: std::array<char, 3> = ('\0', 'x', 'y');
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    str := read_c_string(buf);
    
    assert(str.empty());
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 3: Binary Protocol Parsing (Length-Prefixed Messages)
// ============================================================================

Message: @struct type = {
    msg_type: uint8_t;
    payload: cpp2::ByteBuffer;
}

// Parse a message with format: [type:1][length:2 LE][payload:length]
parse_message: (buf: cpp2::ByteBuffer) -> std::optional<std::pair<Message, cpp2::ByteBuffer>> = {
    if buf.size() < 3 { return std::nullopt; }  // Need at least type + length
    
    data := buf.data();
    
    // Read type byte
    msg_type := data[0] as uint8_t;
    
    // Read length (little-endian 16-bit)
    length := ((data[2] as uint16_t) << 8) | (data[1] as uint16_t);
    
    // Check if we have enough data
    if buf.size() < 3 + length { return std::nullopt; }
    
    // Extract payload
    payload := buf.slice(3, 3 + length);
    remaining := buf.slice(3 + length, buf.size());
    
    msg: Message = (msg_type, payload);
    return std::make_pair(msg, remaining);
}

test_binary_message_parsing: () -> void = {
    std::cout << "test_binary_message_parsing\n";
    
    // Message type 0x01, length 5 (LE: 05 00), payload "Hello"
    data: std::array<char, 13> = (
        0x01,       // type
        0x05, 0x00, // length (5, little-endian)
        'H', 'e', 'l', 'l', 'o',  // payload
        0x02,       // next message type
        0x02, 0x00, // length (2)
        'O', 'K'    // payload
    );
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Parse first message
    result1 := parse_message(buf);
    assert(result1.has_value());
    assert(result1.value().first.msg_type == 1);
    assert(result1.value().first.payload.size() == 5);
    payload1 := std::string(result1.value().first.payload.data(), result1.value().first.payload.size());
    assert(payload1 == "Hello");
    
    // Parse second message
    result2 := parse_message(result1.value().second);
    assert(result2.has_value());
    assert(result2.value().first.msg_type == 2);
    assert(result2.value().first.payload.size() == 2);
    payload2 := std::string(result2.value().first.payload.data(), result2.value().first.payload.size());
    assert(payload2 == "OK");
    
    // No more messages
    assert(result2.value().second.empty());
    
    std::cout << "  PASS\n";
}

test_binary_message_truncated: () -> void = {
    std::cout << "test_binary_message_truncated\n";
    
    // Message claims 10 bytes but only 3 available
    data: std::array<char, 6> = (0x01, 0x0A, 0x00, 'a', 'b', 'c');
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := parse_message(buf);
    assert(!result.has_value());  // Not enough data
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 4: CSV Line Parsing
// ============================================================================

parse_csv_line: (line: cpp2::ByteBuffer) -> std::vector<std::string> = {
    result: std::vector<std::string> = ();
    
    // Split by comma
    fields := cpp2::combinators::split(line, ',');
    
    for fields do (field) {
        // Trim whitespace
        start: size_t = 0;
        end: size_t = field.size();
        
        while start < end && (field.data()[start] == ' ' || field.data()[start] == '\t') {
            start++;
        }
        while end > start && (field.data()[end - 1] == ' ' || field.data()[end - 1] == '\t') {
            end--;
        }
        
        if end > start {
            result.push_back(std::string(field.data() + start, end - start));
        } else {
            result.push_back("");
        }
    }
    
    return result;
}

test_csv_parsing: () -> void = {
    std::cout << "test_csv_parsing\n";
    
    line: std::string = "name, age, city";
    buf: cpp2::ByteBuffer = (line.data(), line.size());
    
    fields := parse_csv_line(buf);
    
    assert(fields.size() == 3);
    assert(fields[0] == "name");
    assert(fields[1] == "age");
    assert(fields[2] == "city");
    
    std::cout << "  PASS\n";
}

test_csv_with_empty_fields: () -> void = {
    std::cout << "test_csv_with_empty_fields\n";
    
    line: std::string = "a,,c";
    buf: cpp2::ByteBuffer = (line.data(), line.size());
    
    fields := parse_csv_line(buf);
    
    assert(fields.size() == 3);
    assert(fields[0] == "a");
    assert(fields[1] == "");
    assert(fields[2] == "c");
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 5: Log Entry Parsing
// ============================================================================

LogEntry: @struct type = {
    timestamp: std::string;
    level: std::string;
    message: std::string;
}

// Parse log line: "[timestamp] LEVEL: message"
parse_log_entry: (line: cpp2::ByteBuffer) -> std::optional<LogEntry> = {
    if line.size() < 5 { return std::nullopt; }
    
    data := line.data();
    size := line.size();
    
    // Find timestamp in brackets
    if data[0] != '[' { return std::nullopt; }
    
    bracket_end: size_t = 1;
    while bracket_end < size && data[bracket_end] != ']' {
        bracket_end++;
    }
    if bracket_end >= size { return std::nullopt; }
    
    timestamp := std::string(data + 1, bracket_end - 1);
    
    // Skip "] "
    pos := bracket_end + 1;
    while pos < size && data[pos] == ' ' {
        pos++;
    }
    
    // Find level (until colon)
    level_start := pos;
    while pos < size && data[pos] != ':' {
        pos++;
    }
    if pos >= size { return std::nullopt; }
    
    level := std::string(data + level_start, pos - level_start);
    
    // Skip ": "
    pos++;
    while pos < size && data[pos] == ' ' {
        pos++;
    }
    
    // Rest is message
    message := std::string(data + pos, size - pos);
    
    // Trim trailing newline
    while !message.empty() && (message.back() == '\n' || message.back() == '\r') {
        message.pop_back();
    }
    
    return LogEntry(timestamp, level, message);
}

test_log_parsing: () -> void = {
    std::cout << "test_log_parsing\n";
    
    line: std::string = "[2024-01-15 10:30:45] INFO: Server started\n";
    buf: cpp2::ByteBuffer = (line.data(), line.size());
    
    entry := parse_log_entry(buf);
    
    assert(entry.has_value());
    assert(entry.value().timestamp == "2024-01-15 10:30:45");
    assert(entry.value().level == "INFO");
    assert(entry.value().message == "Server started");
    
    std::cout << "  PASS\n";
}

test_log_parsing_multiline: () -> void = {
    std::cout << "test_log_parsing_multiline\n";
    
    logs: std::string = "[2024-01-15 10:30:45] INFO: Starting\n[2024-01-15 10:30:46] ERROR: Failed\n[2024-01-15 10:30:47] DEBUG: Retrying\n";
    buf: cpp2::ByteBuffer = (logs.data(), logs.size());
    
    entries: std::vector<LogEntry> = ();
    
    lines := cpp2::combinators::split(buf, '\n');
    for lines do (line) {
        if !line.empty() {
            entry := parse_log_entry(line);
            if entry.has_value() {
                entries.push_back(entry.value());
            }
        }
    }
    
    assert(entries.size() == 3);
    assert(entries[0].level == "INFO");
    assert(entries[1].level == "ERROR");
    assert(entries[2].level == "DEBUG");
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 6: Pipeline Composition for Data Transformation
// ============================================================================

test_word_count_pipeline: () -> void = {
    std::cout << "test_word_count_pipeline\n";
    
    text: std::string = "hello world hello cpp2 world world";
    buf: cpp2::ByteBuffer = (text.data(), text.size());
    
    // Split by space
    words := cpp2::combinators::split(buf, ' ');
    
    // Count words
    counts: std::map<std::string, int> = ();
    for words do (word) {
        if !word.empty() {
            w := std::string(word.data(), word.size());
            counts[w]++;
        }
    }
    
    assert(counts["hello"] == 2);
    assert(counts["world"] == 3);
    assert(counts["cpp2"] == 1);
    
    std::cout << "  PASS\n";
}

test_filter_transform_pipeline: () -> void = {
    std::cout << "test_filter_transform_pipeline\n";
    
    data: std::string = "a1B2c3D4e5F6";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Filter letters, transform to uppercase, collect
    letters := cpp2::combinators::from(buf)
        | cpp2::combinators::curried::filter(:(c: char) -> bool = std::isalpha(c) != 0)
        | cpp2::combinators::curried::map(:(c: char) -> char = std::toupper(c) as char);
    
    result: std::string = "";
    for letters do (c) {
        result += c;
    }
    
    assert(result == "ABCDEF");
    
    std::cout << "  PASS\n";
}

test_skip_take_sum_pipeline: () -> void = {
    std::cout << "test_skip_take_sum_pipeline\n";
    
    // Sum of digits in "01234567" after skip(2) take(4) -> "2345" -> 2+3+4+5=14
    data: std::string = "01234567";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    selected := cpp2::combinators::from(buf)
        | cpp2::combinators::curried::skip(2)
        | cpp2::combinators::curried::take(4);
    
    sum := 0;
    for selected do (c) {
        sum += c - '0';
    }
    
    assert(sum == 14);  // 2+3+4+5
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 7: Configuration File Parsing
// ============================================================================

parse_config: (buf: cpp2::ByteBuffer) -> std::map<std::string, std::string> = {
    result: std::map<std::string, std::string> = ();
    
    lines := cpp2::combinators::split(buf, '\n');
    
    for lines do (line) {
        if line.empty() { continue; }
        
        // Skip comments
        if line.data()[0] == '#' { continue; }
        
        // Find '='
        data := line.data();
        size := line.size();
        eq_pos: size_t = 0;
        found := false;
        
        i := 0;
        while i < size {
            if data[i] == '=' {
                eq_pos = i;
                found = true;
                break;
            }
            i++;
        }
        
        if found {
            key := std::string(data, eq_pos);
            value := std::string(data + eq_pos + 1, size - eq_pos - 1);
            
            // Trim trailing CR/LF
            while !value.empty() && (value.back() == '\r' || value.back() == '\n') {
                value.pop_back();
            }
            
            result[key] = value;
        }
    }
    
    return result;
}

test_config_file_parsing: () -> void = {
    std::cout << "test_config_file_parsing\n";
    
    config: std::string = "# Configuration file\nhost=localhost\nport=8080\ndebug=true\n";
    buf: cpp2::ByteBuffer = (config.data(), config.size());
    
    settings := parse_config(buf);
    
    assert(settings.size() == 3);
    assert(settings["host"] == "localhost");
    assert(settings["port"] == "8080");
    assert(settings["debug"] == "true");
    
    std::cout << "  PASS\n";
}

// ============================================================================
// Recipe 8: Find Patterns in Data
// ============================================================================

test_find_pattern: () -> void = {
    std::cout << "test_find_pattern\n";
    
    data: std::string = "The quick brown fox jumps over the lazy dog";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Find first vowel
    found_vowel := cpp2::combinators::reduce_from(buf)
        .find(:(c: char) -> bool = c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u');
    
    assert(found_vowel.has_value());
    assert(found_vowel.value() == 'e');  // First vowel in "The"
    
    // Find index of 'q'
    q_index := cpp2::combinators::reduce_from(buf)
        .find_index(:(c: char) -> bool = c == 'q');
    
    assert(q_index.has_value());
    assert(q_index.value() == 4);  // "The q..."
    
    std::cout << "  PASS\n";
}

test_any_all_predicates: () -> void = {
    std::cout << "test_any_all_predicates\n";
    
    digits: std::string = "1234567890";
    buf1: cpp2::ByteBuffer = (digits.data(), digits.size());
    
    // All are digits
    all_digits := cpp2::combinators::reduce_from(buf1)
        .all(:(c: char) -> bool = std::isdigit(c) != 0);
    assert(all_digits);
    
    // Any is even digit
    buf2: cpp2::ByteBuffer = (digits.data(), digits.size());
    any_even := cpp2::combinators::reduce_from(buf2)
        .any(:(c: char) -> bool = (c - '0') % 2 == 0);
    assert(any_even);
    
    std::cout << "  PASS\n";
}

// ============================================================================
// MAIN
// ============================================================================

main: () -> int = {
    std::cout << "=== Combinator Integration Tests ===\n";
    std::cout << "Real-world parsing scenarios\n\n";
    
    std::cout << "--- HTTP Header Parsing ---\n";
    test_http_header_parsing();
    test_http_header_with_crlf();
    
    std::cout << "\n--- Null-Terminated Strings ---\n";
    test_c_string_parsing();
    test_c_string_no_null();
    test_c_string_empty();
    
    std::cout << "\n--- Binary Protocol ---\n";
    test_binary_message_parsing();
    test_binary_message_truncated();
    
    std::cout << "\n--- CSV Parsing ---\n";
    test_csv_parsing();
    test_csv_with_empty_fields();
    
    std::cout << "\n--- Log Parsing ---\n";
    test_log_parsing();
    test_log_parsing_multiline();
    
    std::cout << "\n--- Pipeline Composition ---\n";
    test_word_count_pipeline();
    test_filter_transform_pipeline();
    test_skip_take_sum_pipeline();
    
    std::cout << "\n--- Configuration Files ---\n";
    test_config_file_parsing();
    
    std::cout << "\n--- Pattern Finding ---\n";
    test_find_pattern();
    test_any_all_predicates();
    
    std::cout << "\n=== All Integration Tests PASSED ===\n";
    return 0;
}
