// Reduction Combinators Unit Tests
// Tests for fold, reduce, scan, find, find_index, all, any, none, count

#include "../include/bytebuffer.hpp"
#include "../include/strview.hpp"
#include "../include/combinators/structural.hpp"
#include "../include/combinators/transformation.hpp"
#include "../include/combinators/reduction.hpp"
#include <vector>
#include <string>
#include <iostream>
#include <cassert>
#include <cstddef>

// ============================================================================
// fold() tests
// ============================================================================

test_fold_sum: () -> void = {
    data: std::string = "12345";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Fold to sum ASCII values
    sum := cpp2::combinators::reduce_from(buf)
        .fold(0, :(acc: int, c: char) -> int = { return acc + (c as int); });
    
    // '1'=49, '2'=50, '3'=51, '4'=52, '5'=53 -> sum = 255
    assert(sum == 255);
    std::cout << "test_fold_sum: PASS\n";
}

test_fold_string_concat: () -> void = {
    data: std::string = "abc";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Fold to concatenate with separator
    result := cpp2::combinators::reduce_from(buf)
        .fold(std::string(""), :(acc: std::string, c: char) -> std::string = { 
            if acc.empty() { return std::string(1, c); }
            return acc + "-" + c; 
        });
    
    assert(result == "a-b-c");
    std::cout << "test_fold_string_concat: PASS\n";
}

test_fold_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    sum := cpp2::combinators::reduce_from(buf)
        .fold(42, :(acc: int, c: char) -> int = { return acc + 1; });
    
    // Empty sequence returns init value
    assert(sum == 42);
    std::cout << "test_fold_empty: PASS\n";
}

// ============================================================================
// reduce() tests
// ============================================================================

test_reduce_max: () -> void = {
    data: std::string = "bcaed";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Reduce to find max char
    max_char := cpp2::combinators::reduce_from(buf)
        .reduce(:(a: char, b: char) -> char = { 
            if a > b { return a; }
            return b;
        });
    
    assert(max_char.has_value());
    assert(max_char.value() == 'e');
    std::cout << "test_reduce_max: PASS\n";
}

test_reduce_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::reduce_from(buf)
        .reduce(:(a: char, b: char) -> char = { return a; });
    
    // Empty sequence returns nullopt
    assert(!result.has_value());
    std::cout << "test_reduce_empty: PASS\n";
}

test_reduce_single: () -> void = {
    data: std::string = "x";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    result := cpp2::combinators::reduce_from(buf)
        .reduce(:(a: char, b: char) -> char = { return a; });
    
    // Single element returns that element
    assert(result.has_value() && result.value() == 'x');
    std::cout << "test_reduce_single: PASS\n";
}

// ============================================================================
// scan() tests
// ============================================================================

test_scan_running_sum: () -> void = {
    data: std::string = "123";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    zero_char: char = 0x30;  // '0' as hex
    
    // Scan for running sum of digit values
    running := cpp2::combinators::reduce_from(buf)
        .scan(0, :(acc: int, c: char) -> int = { return acc + (c - 0x30); });
    
    sums: std::vector<int> = ();
    for running do (v) {
        sums.push_back(v);
    }
    
    // '1'->1, '2'->1+2=3, '3'->1+2+3=6
    assert(sums.size() == 3);
    assert(sums[0] == 1);
    assert(sums[1] == 3);
    assert(sums[2] == 6);
    std::cout << "test_scan_running_sum: PASS\n";
}

test_scan_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    running := cpp2::combinators::reduce_from(buf)
        .scan(0, :(acc: int, c: char) -> int = { return acc + 1; });
    
    cnt: int = 0;
    for running do (v) {
        cnt++;
    }
    
    assert(cnt == 0);
    std::cout << "test_scan_empty: PASS\n";
}

// ============================================================================
// find() tests
// ============================================================================

test_find_basic: () -> void = {
    data: std::string = "hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Find first 'l' (0x6C)
    found := cpp2::combinators::reduce_from(buf)
        .find(:(c: char) -> bool = { return c == 0x6C; });
    
    assert(found.has_value() && found.value() == 'l');
    std::cout << "test_find_basic: PASS\n";
}

test_find_not_found: () -> void = {
    data: std::string = "hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Find 'x' (0x78) (doesn't exist)
    found := cpp2::combinators::reduce_from(buf)
        .find(:(c: char) -> bool = { return c == 0x78; });
    
    assert(!found.has_value());
    std::cout << "test_find_not_found: PASS\n";
}

test_find_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    found := cpp2::combinators::reduce_from(buf)
        .find(:(c: char) -> bool = { return true; });
    
    assert(!found.has_value());
    std::cout << "test_find_empty: PASS\n";
}

// ============================================================================
// find_index() tests
// ============================================================================

test_find_index_basic: () -> void = {
    data: std::string = "hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Find index of first 'l' (0x6C)
    idx := cpp2::combinators::reduce_from(buf)
        .find_index(:(c: char) -> bool = { return c == 0x6C; });
    
    assert(idx.has_value() && idx.value() == 2);
    std::cout << "test_find_index_basic: PASS\n";
}

test_find_index_not_found: () -> void = {
    data: std::string = "hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    idx := cpp2::combinators::reduce_from(buf)
        .find_index(:(c: char) -> bool = { return c == 0x78; });
    
    assert(!idx.has_value());
    std::cout << "test_find_index_not_found: PASS\n";
}

// ============================================================================
// all() tests
// ============================================================================

test_all_true: () -> void = {
    data: std::string = "ABCDE";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // All uppercase?
    result := cpp2::combinators::reduce_from(buf)
        .all(:(c: char) -> bool = { return std::isupper(c) != 0; });
    
    assert(result == true);
    std::cout << "test_all_true: PASS\n";
}

test_all_false: () -> void = {
    data: std::string = "ABcDE";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // All uppercase? (no - 'c' is lowercase)
    result := cpp2::combinators::reduce_from(buf)
        .all(:(c: char) -> bool = { return std::isupper(c) != 0; });
    
    assert(result == false);
    std::cout << "test_all_false: PASS\n";
}

test_all_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Vacuous truth - all() on empty is true
    result := cpp2::combinators::reduce_from(buf)
        .all(:(c: char) -> bool = { return false; });
    
    assert(result == true);
    std::cout << "test_all_empty: PASS\n";
}

// ============================================================================
// any() tests
// ============================================================================

test_any_true: () -> void = {
    data: std::string = "abc1def";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Any digit?
    result := cpp2::combinators::reduce_from(buf)
        .any(:(c: char) -> bool = { return std::isdigit(c) != 0; });
    
    assert(result == true);
    std::cout << "test_any_true: PASS\n";
}

test_any_false: () -> void = {
    data: std::string = "abcdef";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Any digit? (no)
    result := cpp2::combinators::reduce_from(buf)
        .any(:(c: char) -> bool = { return std::isdigit(c) != 0; });
    
    assert(result == false);
    std::cout << "test_any_false: PASS\n";
}

test_any_empty: () -> void = {
    data: std::string = "";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // any() on empty is false
    result := cpp2::combinators::reduce_from(buf)
        .any(:(c: char) -> bool = { return true; });
    
    assert(result == false);
    std::cout << "test_any_empty: PASS\n";
}

// ============================================================================
// none() tests
// ============================================================================

test_none_true: () -> void = {
    data: std::string = "abcdef";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // No digits?
    result := cpp2::combinators::reduce_from(buf)
        .none(:(c: char) -> bool = { return std::isdigit(c) != 0; });
    
    assert(result == true);
    std::cout << "test_none_true: PASS\n";
}

test_none_false: () -> void = {
    data: std::string = "abc1def";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // No digits? (false - has '1')
    result := cpp2::combinators::reduce_from(buf)
        .none(:(c: char) -> bool = { return std::isdigit(c) != 0; });
    
    assert(result == false);
    std::cout << "test_none_false: PASS\n";
}

// ============================================================================
// count() tests
// ============================================================================

test_count_basic: () -> void = {
    data: std::string = "hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Count 'l' (0x6C) occurrences
    cnt := cpp2::combinators::reduce_from(buf)
        .count(:(c: char) -> bool = { return c == 0x6C; });
    
    assert(cnt == 2);
    std::cout << "test_count_basic: PASS\n";
}

test_count_none: () -> void = {
    data: std::string = "hello";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Count 'x' (0x78) occurrences
    cnt := cpp2::combinators::reduce_from(buf)
        .count(:(c: char) -> bool = { return c == 0x78; });
    
    assert(cnt == 0);
    std::cout << "test_count_none: PASS\n";
}

test_count_all: () -> void = {
    data: std::string = "aaa";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    cnt := cpp2::combinators::reduce_from(buf)
        .count_all();
    
    assert(cnt == 3);
    std::cout << "test_count_all: PASS\n";
}

// ============================================================================
// first(), last(), nth() tests
// ============================================================================

test_first_last_nth: () -> void = {
    data: std::string = "abcde";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    range := cpp2::combinators::reduce_from(buf);
    
    f := range.first();
    l := range.last();
    n := range.nth(2);
    
    assert(f.has_value() && f.value() == 'a');
    assert(l.has_value() && l.value() == 'e');
    assert(n.has_value() && n.value() == 'c');
    
    // Out of bounds
    oob := range.nth(10);
    assert(!oob.has_value());
    
    std::cout << "test_first_last_nth: PASS\n";
}

// ============================================================================
// sum(), product(), min(), max() tests
// ============================================================================

test_numeric_reductions: () -> void = {
    // Use a vector of ints for numeric tests
    nums: std::vector<int> = (1, 2, 3, 4, 5);
    
    range := cpp2::combinators::reduce_from(nums);
    
    s := range.sum();
    p := range.product();
    mn := range.min();
    mx := range.max();
    
    assert(s == 15);
    assert(p == 120);
    assert(mn.has_value() && mn.value() == 1);
    assert(mx.has_value() && mx.value() == 5);
    
    std::cout << "test_numeric_reductions: PASS\n";
}

// ============================================================================
// Pipeline integration tests
// ============================================================================

test_map_then_reduce: () -> void = {
    data: std::string = "123";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Map chars to digit values, then sum ('0' = 0x30)
    sum := cpp2::combinators::fold(
        cpp2::combinators::from(buf) 
            | cpp2::combinators::curried::map(:(c: char) -> int = { return c - 0x30; }),
        0,
        :(a: int, b: int) -> int = { return a + b; }
    );
    
    assert(sum == 6);  // 1 + 2 + 3
    std::cout << "test_map_then_reduce: PASS\n";
}

test_filter_then_count: () -> void = {
    data: std::string = "a1b2c3";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Filter to letters, then count
    cnt := cpp2::combinators::count(
        cpp2::combinators::from(buf)
            | cpp2::combinators::curried::filter(:(c: char) -> bool = { return std::isalpha(c) != 0; }),
        :(c: char) -> bool = { return true; }
    );
    
    assert(cnt == 3);
    std::cout << "test_filter_then_count: PASS\n";
}

test_complex_pipeline: () -> void = {
    data: std::string = "The Quick Brown Fox";
    buf: cpp2::ByteBuffer = (data.data(), data.size());
    
    // Count uppercase letters
    uppercase_count := cpp2::combinators::count(
        buf,
        :(c: char) -> bool = { return std::isupper(c) != 0; }
    );
    
    assert(uppercase_count == 4);  // T, Q, B, F
    std::cout << "test_complex_pipeline: PASS\n";
}

// ============================================================================
// Main
// ============================================================================

main: () -> int = {
    std::cout << "=== Reduction Combinators Tests ===\n\n";
    
    // fold tests
    test_fold_sum();
    test_fold_string_concat();
    test_fold_empty();
    
    // reduce tests
    test_reduce_max();
    test_reduce_empty();
    test_reduce_single();
    
    // scan tests
    test_scan_running_sum();
    test_scan_empty();
    
    // find tests
    test_find_basic();
    test_find_not_found();
    test_find_empty();
    
    // find_index tests
    test_find_index_basic();
    test_find_index_not_found();
    
    // all tests
    test_all_true();
    test_all_false();
    test_all_empty();
    
    // any tests
    test_any_true();
    test_any_false();
    test_any_empty();
    
    // none tests
    test_none_true();
    test_none_false();
    
    // count tests
    test_count_basic();
    test_count_none();
    test_count_all();
    
    // first/last/nth tests
    test_first_last_nth();
    
    // numeric reductions
    test_numeric_reductions();
    
    // pipeline integration
    test_map_then_reduce();
    test_filter_then_count();
    test_complex_pipeline();
    
    std::cout << "\n=== All reduction combinator tests passed! ===\n";
    return 0;
}
