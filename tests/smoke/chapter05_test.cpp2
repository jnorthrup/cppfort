// Chapter 5: If/Else Statements with Control Flow Test
// Tests for sea-of-nodes chapter 05 implementation

// Test 1: Basic if/else with arithmetic
int a = 1;
if (arg == 1)
    a = arg + 2;
else {
    a = arg - 3;
}
return a;

// Test 2: Nested if/else
int c = 3;
int b = 2;
if (arg == 1) {
    b = 3;
    c = 4;
}
return c;

// Test 3: If/else with return statements
if (arg == 1)
    return 3;
else
    return 4;

// Test 4: Complex if/else merging
int a = arg + 1;
int b = 0;
if (arg == 1)
    b = a;
else
    b = a + 1;
return a + b;

// Test 5: Another complex merge
int a = arg + 1;
int b = arg + 2;
if (arg == 1)
    b = b + a;
else
    a = b + 1;
return a + b;

// Test 6: Nested ifs
int a = 1;
if (arg == 1)
    if (arg == 2)
        a = 2;
    else
        a = 3;
else if (arg == 3)
    a = 4;
else
    a = 5;
return a;

// Test 7: Multiple independent ifs
int a = 0;
int b = 0;
if (arg)
    a = 1;
if (arg == 0)
    b = 2;
return arg + a + b;

// Test 8: Boolean expression in if
int a = arg == 2;
if (arg == 1) {
    a = arg == 3;
}
return a;

// Test 9: True literal
return true;

