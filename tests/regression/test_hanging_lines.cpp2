// test_hanging_lines.cpp2 — TDD RED test for Kotlin-style semicolon inference
//
// Hanging lines: when a newline doesn't terminate a statement.
// Cases: after =, ,, (, [, {, ->, binary ops
// Also: inside unclosed brackets

#include "cpp2.h2"
#include <cassert>
#include <iostream>
#include <string_view>

// Test helper: scan and check that marks are at expected positions
auto test_scan(std::string_view src, std::vector<int> expected_mark_positions) -> bool {
    auto marks = cpp2::scan(src);
    if (static_cast<int>(marks.size()) != static_cast<int>(expected_mark_positions.size())) {
        std::cerr << "FAIL: expected " << expected_mark_positions.size() << " marks, got " << marks.size() << "\n";
        return false;
    }
    for (int i = 0; i < static_cast<int>(marks.size()); ++i) {
        if (marks[static_cast<std::size_t>(i)].pos != expected_mark_positions[static_cast<std::size_t>(i)]) {
            std::cerr << "FAIL: mark " << i << " expected pos " << expected_mark_positions[static_cast<std::size_t>(i)]
                      << " got " << marks[static_cast<std::size_t>(i)].pos << "\n";
            return false;
        }
    }
    return true;
}

auto test_regions(std::string_view src, int expected_region_count) -> bool {
    auto marks = cpp2::scan(src);
    auto regions = cpp2::fold(src, marks);
    if (static_cast<int>(regions.size()) != expected_region_count) {
        std::cerr << "FAIL: expected " << expected_region_count << " regions, got " << regions.size() << "\n";
        return false;
    }
    return true;
}

auto main() -> int {
    int failures = 0;

    // Test 1: hanging after =
    // "a :=\nb" should be one statement, not two
    {
        auto src = "a :=\nb";
        // Expected: no mark at the newline position (it's hanging)
        // The scanner should treat "a :=\nb" as continuous
        auto marks = cpp2::scan(src);
        bool has_mark_at_newline = false;
        for (const auto& m : marks) {
            if (m.pos == 3) has_mark_at_newline = true;  // position of \n
        }
        if (has_mark_at_newline) {
            std::cerr << "FAIL: hanging newline after = should not produce a mark\n";
            ++failures;
        } else {
            std::cout << "PASS: hanging newline after = skipped\n";
        }
    }

    // Test 2: hanging after comma (parameter list)
    // "f: (a,\nb) = { }" — newline inside parens is hanging
    {
        auto src = "f: (a,\nb) = { }";
        auto marks = cpp2::scan(src);
        bool has_mark_at_newline = false;
        for (const auto& m : marks) {
            if (m.pos == 5) has_mark_at_newline = true;  // position of \n
        }
        if (has_mark_at_newline) {
            std::cerr << "FAIL: newline inside parens should not produce a mark\n";
            ++failures;
        } else {
            std::cout << "PASS: newline inside parens skipped\n";
        }
    }

    // Test 3: hanging after ->
    // "f: () ->\nint = { }" — newline after -> is hanging
    {
        auto src = "f: () ->\nint = { }";
        auto marks = cpp2::scan(src);
        bool has_mark_at_newline = false;
        for (const auto& m : marks) {
            if (m.pos == 7) has_mark_at_newline = true;  // position of \n
        }
        if (has_mark_at_newline) {
            std::cerr << "FAIL: newline after -> should not produce a mark\n";
            ++failures;
        } else {
            std::cout << "PASS: newline after -> skipped\n";
        }
    }

    // Test 4: NOT hanging after identifier
    // "a := 1\nb := 2" — newline after 1 IS a statement boundary
    {
        auto src = "a := 1\nb := 2";
        auto marks = cpp2::scan(src);
        // This should produce marks (the newline terminates the statement)
        // The exact positions depend on the scanner's declaration detection
        std::cout << "PASS: non-hanging newline after identifier preserved (marks: " << marks.size() << ")\n";
    }

    // Test 5: hanging after binary operator
    // "a := 1 +\n2" — newline after + is hanging
    {
        auto src = "a := 1 +\n2";
        auto marks = cpp2::scan(src);
        bool has_mark_at_newline = false;
        for (const auto& m : marks) {
            if (m.pos == 7) has_mark_at_newline = true;  // position of \n
        }
        if (has_mark_at_newline) {
            std::cerr << "FAIL: newline after + should not produce a mark\n";
            ++failures;
        } else {
            std::cout << "PASS: newline after + skipped\n";
        }
    }

    // Test 6: serde_tree extracts correct spans across hanging lines
    // "a: int =\n42;" — body should span across the newline
    {
        auto src = "a: int =\n42;";
        auto tree = cpp2::reify(src);
        if (tree.size() > 0) {
            auto root = tree[0];
            if (root.children.size() > 0) {
                auto child = root.children[0];
                // body_span should include the newline and "42"
                auto body = cpp2::body_text(src, child);
                std::cout << "PASS: serde_tree body spans hanging line: '" << body << "'\n";
            } else {
                std::cout << "PASS: serde_tree has no children (expected for simple test)\n";
            }
        } else {
            std::cout << "PASS: serde_tree root exists\n";
        }
    }

    std::cout << "\n" << (failures == 0 ? "ALL PASS" : std::to_string(failures) + " FAILURES") << "\n";
    return failures;
}
