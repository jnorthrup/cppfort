// stage0.cpp2 — minimal selfhost test (self-contained)
//
// Pattern: ~/work/Trikeshed/src/commonMain/kotlin/borg/trikeshed/parse/json/
// Stage0: verify cpp2 bitmap scanner works on simple input

#include <string_view>
#include <vector>
#include <string>
#include <iostream>

cpp2: namespace = {

// from trikeshed.h2
char_series: type = {
    src: std::string_view = ();
    pos: int = 0;
    lim: int = 0;
    operator=: (out this, s: std::string_view) = {
        src = s; pos = 0; lim = unchecked_narrow<int>(s.ssize());
    }
    res: (this) -> int == lim - pos;
    hasRemaining: (this) -> bool == pos < lim;
    get: (this) -> char == src[pos];
    trim: (inout this) = { while pos < lim && std::isspace(src[pos]) != 0 { pos += 1; } }
    seekTo: (inout this, c: char) -> bool = {
        while pos < lim { if src[pos] == c { pos += 1; return true; } pos += 1; }
        return false;
    }
    slice: (this) -> std::string_view = { return src.substr(pos, lim - pos); }
    asString: (this) -> std::string = { return std::string(src.substr(pos, lim - pos)); }
}

// from cpp2.h2 — types
struct_event: @enum type = { unchanged; scope_open; scope_close; decl_delim; }
lexer_event: @enum type = { unchanged; string_delim; escape; comment_start; }
pixel: @struct type = { se: struct_event = (); le: lexer_event = (); }
bitmap: @struct type = {
    src: std::string_view = ();
    scope_opens: std::vector<int> = ();
    scope_closes: std::vector<int> = ();
    decl_delims: std::vector<int> = ();
    string_opens: std::vector<int> = ();
    string_closes: std::vector<int> = ();
    comment_starts: std::vector<int> = ();
    comment_ends: std::vector<int> = ();
}
decl_boundary: @struct type = { lo: int = 0; hi: int = 0; depth: int = 0; }
value_kind: @enum type = { word; num; str; }
tag_decl: @struct type = { name: std::string_view = (); type_name: std::string_view = (); val: value_kind = (); }
namespace_decl: @struct type = { name: std::string_view = (); }
type_decl: @struct type = { name: std::string_view = (); metafunc: std::string_view = (); }
type_alias: @struct type = { name: std::string_view = (); value: std::string_view = (); }
func_decl: @struct type = { name: std::string_view = (); return_type: std::string_view = (); }
decl_kind: @enum type = { tag_kind; ns_kind; type_kind; alias_kind; func_kind; unknown_kind; }
decl: @struct type = {
    kind: decl_kind = ();
    tag: tag_decl = ();
    ns: namespace_decl = ();
    tp: type_decl = ();
    al: type_alias = ();
    fn: func_decl = ();
    lo: int = 0;
    hi: int = 0;
}

// from cpp2.cpp2 — functions
classify_se: (c: char) -> struct_event = {
    return inspect c -> struct_event {
        is '{' = struct_event::scope_open;
        is '(' = struct_event::scope_open;
        is '[' = struct_event::scope_open;
        is '}' = struct_event::scope_close;
        is ')' = struct_event::scope_close;
        is ']' = struct_event::scope_close;
        is ';' = struct_event::decl_delim;
        is ',' = struct_event::decl_delim;
        is _ = struct_event::unchanged;
    };
}

classify_le: (c: char) -> lexer_event = {
    return inspect c -> lexer_event {
        is '"' = lexer_event::string_delim;
        is '`' = lexer_event::string_delim;
        is '\\' = lexer_event::escape;
        is '/' = lexer_event::comment_start;
        is _ = lexer_event::unchanged;
    };
}

encode_byte: (c: char) -> pixel = { return (classify_se(c), classify_le(c)); }

encode: (src: std::string_view) -> std::vector<pixel> = {
    r: std::vector<pixel> = ();
    r.reserve(src.size());
    for 0..<src.ssize() do (i) { r.push_back(encode_byte(src[i])); }
    return r;
}

decode: (src: std::string_view) -> bitmap = {
    pixels := encode(src);
    bmp: bitmap = ();
    bmp.src = src;
    in_string := false;
    escape_next := false;
    in_comment := false;
    string_idx := 0;
    comment_idx := 0;
    for 0..<pixels.ssize() do (i) {
        p := pixels[i];
        if in_comment {
            if src[i] == '\n' { in_comment = false; bmp.comment_ends.push_back(i); }
            continue;
        }
        if in_string {
            if escape_next { escape_next = false; continue; }
            if p.le == lexer_event::escape { escape_next = true; continue; }
            if p.le == lexer_event::string_delim { in_string = false; bmp.string_closes.push_back(i); string_idx += 1; }
            continue;
        }
        if p.le == lexer_event::string_delim { in_string = true; bmp.string_opens.push_back(i); string_idx += 1; continue; }
        if p.le == lexer_event::comment_start && i+1 < src.ssize() && src[i+1] == '/' {
            in_comment = true; bmp.comment_starts.push_back(i); comment_idx += 1; continue;
        }
        if p.se == struct_event::scope_open { bmp.scope_opens.push_back(i); }
        else if p.se == struct_event::scope_close { bmp.scope_closes.push_back(i); }
        else if p.se == struct_event::decl_delim { bmp.decl_delims.push_back(i); }
    }
    return bmp;
}

process_char: (c: char, inout depth: int, inout decl_start: int, inout decls: std::vector<decl_boundary>, i: int) = {
    if c == '{' || c == '(' || c == '[' { depth += 1; }
    else if c == '}' {
        depth -= 1;
        if depth == 0 && i > decl_start {
            b: decl_boundary = (); b.lo = decl_start; b.hi = i+1; b.depth = depth; decls.push_back(b);
            decl_start = i + 1;
        }
    }
    else if c == ')' || c == ']' { depth -= 1; }
    else if c == ';' {
        if depth == 0 && i > decl_start {
            b: decl_boundary = (); b.lo = decl_start; b.hi = i+1; b.depth = depth; decls.push_back(b);
            decl_start = i + 1;
        }
    }
}

index_decls: (bmp: bitmap) -> std::vector<decl_boundary> = {
    decls: std::vector<decl_boundary> = ();
    depth := 0;
    decl_start := 0;
    for 0..<bmp.src.ssize() do (i) {
        c := bmp.src[i];
        if c == '{' || c == '(' || c == '[' { depth += 1; }
        else if c == '}' {
            depth -= 1;
            if depth == 0 && i > decl_start {
                b: decl_boundary = (); b.lo = decl_start; b.hi = i+1; b.depth = depth; decls.push_back(b);
                decl_start = i + 1;
            }
            // also find declarations inside namespace/type bodies
            if depth == 1 && i > decl_start {
                b: decl_boundary = (); b.lo = decl_start; b.hi = i+1; b.depth = depth; decls.push_back(b);
                decl_start = i + 1;
            }
        }
        else if c == ')' || c == ']' { depth -= 1; }
        else if c == ';' {
            if depth == 0 && i > decl_start {
                b: decl_boundary = (); b.lo = decl_start; b.hi = i+1; b.depth = depth; decls.push_back(b);
                decl_start = i + 1;
            }
            // also find declarations inside namespace/type bodies
            if depth == 1 && i > decl_start {
                b: decl_boundary = (); b.lo = decl_start; b.hi = i+1; b.depth = depth; decls.push_back(b);
                decl_start = i + 1;
            }
        }
    }
    if decl_start < bmp.src.ssize() {
        b: decl_boundary = (); b.lo = decl_start; b.hi = unchecked_narrow<int>(bmp.src.ssize()); b.depth = depth; decls.push_back(b);
    }
    return decls;
}

skip_ws: (src: std::string_view, p: int) -> int = {
    cur := p;
    while cur < src.ssize() {
        c := src[cur];
        if c == ' ' || c == '\t' || c == '\n' || c == '\r' { cur += 1; continue; }
        if c == '/' && cur+1 < src.ssize() && src[cur+1] == '/' {
            cur += 2;
            while cur < src.ssize() && src[cur] != '\n' { cur += 1; }
            continue;
        }
        break;
    }
    return cur;
}

read_word: (src: std::string_view, p: int) -> std::string_view = {
    start := p; cur := p;
    if cur < src.ssize() && src[cur] == '@' { cur += 1; }
    while cur < src.ssize() {
        c := src[cur];
        if std::isalnum(c) != 0 || c == '_' || c == '.' || c == '-' { cur += 1; } else { break; }
    }
    return src.substr(start, cur - start);
}

find_at_depth: (src: std::string_view, target: char, p: int) -> int = {
    depth := 0; in_string := false; i := p;
    while i < src.ssize() {
        c := src[i];
        if in_string {
            if c == '\\' { i += 2; continue; }
            if c == '"' { in_string = false; }
            i += 1; continue;
        }
        if c == '"' { in_string = true; i += 1; continue; }
        if c == '{' || c == '(' || c == '[' { depth += 1; }
        if c == '}' || c == ')' || c == ']' { depth -= 1; }
        if depth == 0 && c == target { return i; }
        i += 1;
    }
    return -1;
}

reify: (src: std::string_view, boundary: decl_boundary) -> decl = {
    p := skip_ws(src, boundary.lo);
    if p >= boundary.hi { return (); }
    d: decl = ();
    d.lo = boundary.lo; d.hi = boundary.hi;
    name := read_word(src, p);
    if name.ssize() == 0 { d.kind = decl_kind::unknown_kind; return d; }
    p += unchecked_narrow<int>(name.ssize());
    p = skip_ws(src, p);
    if p >= boundary.hi || src[p] != ':' { d.kind = decl_kind::unknown_kind; return d; }
    p += 1; p = skip_ws(src, p);
    if p + 9 <= boundary.hi && src.substr(p, 9) == "namespace" {
        d.kind = decl_kind::ns_kind; d.ns.name = name; return d;
    }
    if p < boundary.hi && src[p] == '@' {
        metafunc := read_word(src, p);
        p += unchecked_narrow<int>(metafunc.ssize()); p = skip_ws(src, p);
        if p + 4 <= boundary.hi && src.substr(p, 4) == "type" {
            d.kind = decl_kind::type_kind; d.tp.name = name; d.tp.metafunc = metafunc; return d;
        }
    }
    if p + 4 <= boundary.hi && src.substr(p, 4) == "type" {
        p += 4; p = skip_ws(src, p);
        if p + 2 <= boundary.hi && src.substr(p, 2) == "==" {
            p += 2; p = skip_ws(src, p);
            val := read_word(src, p);
            d.kind = decl_kind::alias_kind; d.al.name = name; d.al.value = val; return d;
        }
        d.kind = decl_kind::type_kind; d.tp.name = name; return d;
    }
    if p < boundary.hi && src[p] == '(' {
        d.kind = decl_kind::func_kind; d.fn.name = name;
        close := find_at_depth(src, ')', p);
        if close > 0 {
            p = close + 1; p = skip_ws(src, p);
            if p + 2 <= boundary.hi && src.substr(p, 2) == "->" {
                p += 2; p = skip_ws(src, p);
                ret := read_word(src, p);
                d.fn.return_type = ret;
            }
        }
        return d;
    }
    type_name := read_word(src, p);
    if type_name.ssize() > 0 {
        p += unchecked_narrow<int>(type_name.ssize()); p = skip_ws(src, p);
        if p < boundary.hi && src[p] == '=' {
            d.kind = decl_kind::tag_kind; d.tag.name = name; d.tag.type_name = type_name; return d;
        }
    }
    d.kind = decl_kind::unknown_kind;
    return d;
}

parse: (src: std::string_view) -> std::vector<decl> = {
    bmp := decode(src);
    boundaries := index_decls(bmp);
    decls: std::vector<decl> = ();
    for 0..<boundaries.ssize() do (i) {
        d := reify(src, boundaries[i]);
        if d.kind != decl_kind::unknown_kind {
            decls.push_back(d);
            // recurse into namespace and type bodies
            if d.kind == decl_kind::ns_kind || d.kind == decl_kind::type_kind {
                inner_src := src.substr(d.lo, d.hi - d.lo);
                inner_bmp := decode(inner_src);
                inner_bounds := index_decls(inner_bmp);
                for 0..<inner_bounds.ssize() do (j) {
                    inner_d := reify(inner_src, inner_bounds[j]);
                    if inner_d.kind != decl_kind::unknown_kind {
                        inner_d.lo += d.lo;
                        inner_d.hi += d.lo;
                        decls.push_back(inner_d);
                    }
                }
            }
        }
    }
    return decls;
}

// test
main: () -> int = {
    src := "x: int = 42;\nname: string = \"hello\";\nf: (a: int) -> int = { return a; }";
    std::cerr << "=== stage0: bitmap scanner test ===\n";
    bmp := decode(src);
    std::cerr << "decode: " << bmp.scope_opens.ssize() << " opens, "
              << bmp.scope_closes.ssize() << " closes, "
              << bmp.decl_delims.ssize() << " delims\n";
    boundaries := index_decls(bmp);
    std::cerr << "index: " << boundaries.ssize() << " declarations\n";
    for 0..<boundaries.ssize() do (i) {
        b := boundaries[i];
        d := reify(src, b);
        kind_s := "unknown";
        if d.kind == decl_kind::tag_kind { kind_s = "tag"; }
        else if d.kind == decl_kind::ns_kind { kind_s = "namespace"; }
        else if d.kind == decl_kind::type_kind { kind_s = "type"; }
        else if d.kind == decl_kind::alias_kind { kind_s = "alias"; }
        else if d.kind == decl_kind::func_kind { kind_s = "func"; }
        std::cerr << "  [" << i << "] " << kind_s << "\n";
    }
    decls := parse(src);
    std::cerr << "\nparse(): " << decls.ssize() << " declarations\n";
    return 0;
}

}
