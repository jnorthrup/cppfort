#include "bytebuffer.hpp"
#include <iostream>

main: () = {
    s: std::string = "hello world";
    // Construct ByteBuffer types
    // We expect this to fail initially
    bb: cpp2::ByteBuffer = (s.data(), s.size());
    
    std::cout << "ByteBuffer size: " << bb.size() << "\n";
    
    // Slice test
    slice := bb.slice(0, 5);
    std::cout << "Slice size: " << slice.size() << "\n";
}
