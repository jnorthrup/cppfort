#include "strview.hpp"
#include <iostream>
#include <string>

main: () = {
    // UTF-8 string: "He" + Euro sign (U+20AC) + "lo"
    // Euro is E2 82 AC in UTF-8
    utf8_data: std::string = "He\xE2\x82\xAClo";
    
    sv: cpp2::StrView = (utf8_data.data(), utf8_data.size());
    
    std::cout << "size: " << sv.size() << "\n";

    // Test chars() - manual iteration for now if for-loop support is tricky without LazyIterator
    // But we expect standard C++ range support
    // for sv.chars() do (c) ... 
    
    // Test trim
    padded: std::string = "  foo  ";
    sv_padded: cpp2::StrView = (padded.data(), padded.size());
    trimmed := sv_padded.trim();
    
    // Expect "foo", size 3
    std::cout << "trimmed size: " << trimmed.size() << "\n";
}
