// Test helper for external variables
struct ExternalVar {
    std::string name;
    int value;
};

// Test fixture for external variable tests
class ExternalVarTest {
    std::vector<ExternalVar> globals;
    
public:
    void add_global(std::string name, int value) {
        globals.emplace_back(name, value);
    }
    
    [[nodiscard]] auto find_global(std::string_view name) const -> std::optional<int> {
        for (const auto& var : globals) {
            if (var.name == name) {
                return var.value;
            }
        }
        return std::nullopt;
    }
};

