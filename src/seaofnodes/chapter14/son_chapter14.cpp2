test_f32_type: () -> bool = {
    println("Test 6: f32 type support");

    f: type_lattice = make_f32_const(1.5);

    if f.kind != type_kind::TYPE_F32 {
        println("  FAIL: f32 type not recognized");
        return false;
    }

    if not f.const_float_val || f.const_float_val* != 1.5 {
        println("  FAIL: f32 constant value incorrect");
        return false;
    }

    println("  PASS: f32 type works");
    return true;
}

