zero_extend_to_64: (val: ulong, bits: int) -> ulong = {
    // Zero-extend a value of given bits to 64-bit
    if bits == 64 {
        return val;
    }
    
    mask: ulong = (1UL << bits) - 1;
    return val & mask;
}

