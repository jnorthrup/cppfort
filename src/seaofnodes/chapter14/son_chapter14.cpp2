// ============================================================================
// TYPE LATTICE - Extended for Chapter 14
// ============================================================================

type_kind: @enum type = {
    TYPE_CONTROL;
    TYPE_INTEGER;
    TYPE_STRUCT;
    TYPE_POINTER;
    TYPE_MEMORY;
    TYPE_BOTTOM;
    TYPE_TOP;
    TYPE_FLOAT;  // Chapter 12: Float type
    // Chapter 14: Narrow types
    TYPE_I8;
    TYPE_I16;
    TYPE_I32;
    TYPE_I64;
    TYPE_U8;
    TYPE_U16;
    TYPE_U32;
    TYPE_U64;
    TYPE_I1;
    TYPE_U1;
    TYPE_BOOL;
    TYPE_F32;
}

type_lattice: @struct type = {
    kind: type_kind = ();
    is_nullable: bool = false;
    const_int_val: std::optional<long> = std::nullopt;
    const_float_val: std::optional<double> = std::nullopt;
    const_bool_val: std::optional<bool> = std::nullopt;  // Chapter 14
}

// Type check helpers
is_float: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_FLOAT;
}

is_integer: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_INTEGER;
}

is_i8: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_I8;
}

is_u8: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_U8;
}

is_i16: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_I16;
}

is_u16: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_U16;
}

is_bool: (t: type_lattice) -> bool = {
    return t.kind == type_kind::TYPE_BOOL;
}

// Narrow type constructors
make_i8_const: (val: long) -> type_lattice = {
    result: type_lattice = ();
    result.kind = type_kind::TYPE_I8;
    result.const_int_val = val;
    return result;
}

make_u8_const: (val: ulong) -> type_lattice = {
    result: type_lattice = ();
    result.kind = type_kind::TYPE_U8;
    result.const_int_val = val;
    return result;
}

make_i16_const: (val: long) -> type_lattice = {
    result: type_lattice = ();
    result.kind = type_kind::TYPE_I16;
    result.const_int_val = val;
    return result;
}

make_u16_const: (val: ulong) -> type_lattice = {
    result: type_lattice = ();
    result.kind = type_kind::TYPE_U16;
    result.const_int_val = val;
    return result;
}

// Float type constructors (from chapter 12)
make_float_const: (val: double) -> type_lattice = {
    result: type_lattice = ();
    result.kind = type_kind::TYPE_FLOAT;
    result.const_float_val = val;
    return result;
}

make_f32_const: (val: double) -> type_lattice = {
    result: type_lattice = ();
    result.kind = type_kind::TYPE_F32;
    result.const_float_val = val;
    return result;
}

// ============================================================================
// TRUNCATION AND EXTENSION
// ============================================================================

truncate_to_i8: (val: long) -> long = {
    // Truncate to 8-bit signed: -128 to 127
    mask: long = 0xFF;
    result: long = val & mask;
    
    // Sign-extend if negative (bit 7 set)
    if result & 0x80 {
        result = result | 0xFFFFFFFFFFFFFF00;
    }
    
    return result;
}

truncate_to_i16: (val: long) -> long = {
    // Truncate to 16-bit signed: -32768 to 32767
    mask: long = 0xFFFF;
    result: long = val & mask;
    
    // Sign-extend if negative (bit 15 set)
    if result & 0x8000 {
        result = result | 0xFFFFFFFFFFFF0000;
    }
    
    return result;
}

truncate_to_u8: (val: ulong) -> ulong = {
    // Truncate to 8-bit unsigned: 0 to 255
    return val & 0xFF;
}

truncate_to_u16: (val: ulong) -> ulong = {
    // Truncate to 16-bit unsigned: 0 to 65535
    return val & 0xFFFF;
}

sign_extend_to_64: (val: long, bits: int) -> long = {
    // Sign-extend a value of given bits to 64-bit
    if bits == 64 {
