main: () -> int = {
    println("=== Sea of Nodes Chapter 08: Lazy Phis, Break, Continue, and Evaluator ===");
    println("");
    
    test_lazy_phi();
    test_break_statement();
    // test_continue_statement();  // TODO: Fix continue statement handling
