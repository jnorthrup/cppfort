// ============================================================================
// Canonical AST Node
// The small, repo-owned representation that all lowering targets
// ============================================================================

canonical_node: @struct type = {
    tag: int = ();
    source_start: int = 0;
    source_stop: int = 0;
    semantic: std::string = ();
    children: std::vector<canonical_node> = ();
}

// ============================================================================
// Feature Stream → Canonical AST
// Converts parser features to canonical nodes
// ============================================================================

