pure2_chart_body: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_body",
                    start,
                    0,
                    scan_signal::need_more,
                    "chart body expected"
                );
            }

            if input[start] != '{' {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_body",
                    start,
                    0,
                    scan_signal::reject,
                    "chart body expected"
                );
            }

            cursor := start + 1;
            while true {
                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input,
                        session,
                        "pure2_chart_body",
                        start,
                        total,
                        scan_signal::need_more,
                        "chart body incomplete"
                    );
                }

                if input[cursor] == '}' {
                    stop := cursor + 1;
                    emit_trace(
                        session,
                        "pure2_chart_body",
                        start,
                        stop,
                        scan_signal::accept
                    );
                    record_feature(session, feature_kind::group, start, stop, "chart_body");
                    return accept_result<std::string_view>(
                        input.substr(start, stop - start),
                        stop - start
                    );
                }

                clause: parser_of<std::string_view> = ();
                if keyword_or_prefix_at(input, cursor, "contains") {
                    clause = pure2_chart_contains_clause();
                }
                else if keyword_or_prefix_at(input, cursor, "project") {
                    clause = pure2_chart_project_clause();
                }
                else if keyword_or_prefix_at(input, cursor, "embed") {
                    clause = pure2_chart_embed_clause();
                }
                else {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input,
                        session,
                        "pure2_chart_body",
                        start,
                        total,
                        scan_signal::reject,
                        "chart clause expected"
                    );
                }

                clause_result := clause(input, cursor, session);
                total := cursor - start + clause_result.consumed;
                if clause_result.outcome != scan_signal::accept {
                    emit_trace(
                        session,
                        "pure2_chart_body",
                        start,
                        clamp_stop(input, start, total),
                        clause_result.outcome
                    );
                    if clause_result.outcome == scan_signal::need_more {
                        return need_more_result<std::string_view>(
                            total,
                            clause_result.message
                        );
                    }
                    return reject_result<std::string_view>(
                        clause_result.message,
                        total
                    );
                }

                cursor = cursor + clause_result.consumed;
            }
        }
    );
}

