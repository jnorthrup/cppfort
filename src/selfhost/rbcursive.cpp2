pure2_chart_embed_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            local_literal := trimmed<std::string_view>(
                "chart_embed_local_literal",
                pure2_local_literal()
            );

            if cursor < input.ssize() && keyword_or_prefix_at(input, cursor, "local") {
                local_r := expect_trace(cursor, input, session, start, local_literal, "pure2_chart_embed_expression");
                if local_r.outcome != scan_signal::accept { return local_r; }
                total := cursor - start + local_r.consumed;

                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() ||
                   input[cursor] == '\n' ||
                   input[cursor] == '\r' ||
                   input[cursor] == '}' {
                    total := cursor - start;
                    emit_trace(
                        session,
                        "pure2_chart_embed_expression",
                        start,
                        start + total,
                        scan_signal::accept
                    );
                    return accept_result<std::string_view>(
                        input.substr(start, total),
                        total
                    );
                }

                tail := line_expression_surface(
                    "chart_embed_expression_tail_surface",
                    "chart_embed_expression_tail"
                );
                tail_result := tail(input, cursor, session);
                total = cursor - start + tail_result.consumed;
                if tail_result.outcome != scan_signal::accept {
                    message: std::string_view = "embed expression tail expected";
                    if tail_result.message == "expression group incomplete" {
                        message = "embed expression tail incomplete";
                    }

                    return surface_failure_result<std::string_view>(
                        input,
                        session,
                        "pure2_chart_embed_expression",
                        start,
                        total,
                        tail_result.outcome,
                        message
                    );
                }

                emit_trace(
                    session,
                    "pure2_chart_embed_expression",
                    start,
                    start + total,
                    scan_signal::accept
                );
                return accept_result<std::string_view>(
                    input.substr(start, total),
                    total
                );
            }

            if transition_candidate_at(input, cursor) {
                transition := trimmed<std::string_view>(
                    "chart_embed_transition_expression",
                    pure2_transition_expression()
                );
                transition_result := transition(input, cursor, session);
                total := cursor - start + transition_result.consumed;
                if transition_result.outcome == scan_signal::accept {
                    emit_trace(
                        session,
                        "pure2_chart_embed_expression",
                        start,
                        start + total,
                        scan_signal::accept
                    );
                    return accept_result<std::string_view>(
                        input.substr(start, total),
                        total
                    );
                }

                emit_trace(
                    session,
                    "pure2_chart_embed_expression",
                    start,
                    clamp_stop(input, start, total),
                    transition_result.outcome
                );
                return transition_result;
            }

            if join_candidate_at(input, cursor) {
                join_expression := pure2_join_expression();
                join_result := join_expression(input, cursor, session);
                total := cursor - start + join_result.consumed;
                if join_result.outcome == scan_signal::accept {
                    emit_trace(
                        session,
                        "pure2_chart_embed_expression",
                        start,
                        start + total,
                        scan_signal::accept
                    );
                    return accept_result<std::string_view>(
                        input.substr(start, total),
                        total
                    );
                }

                emit_trace(
                    session,
                    "pure2_chart_embed_expression",
                    start,
                    clamp_stop(input, start, total),
                    join_result.outcome
                );
                if join_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        join_result.message
                    );
                }
                return reject_result<std::string_view>(
                    join_result.message,
                    total
                );
            }

            if alpha_candidate_at(input, cursor) {
                alpha_expression := pure2_alpha_expression();
                alpha_result := alpha_expression(input, cursor, session);
                total := cursor - start + alpha_result.consumed;
                if alpha_result.outcome == scan_signal::accept {
                    emit_trace(
                        session,
                        "pure2_chart_embed_expression",
                        start,
                        start + total,
                        scan_signal::accept
                    );
                    return accept_result<std::string_view>(
                        input.substr(start, total),
                        total
                    );
                }

                emit_trace(
                    session,
                    "pure2_chart_embed_expression",
                    start,
                    clamp_stop(input, start, total),
                    alpha_result.outcome
                );
                if alpha_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        alpha_result.message
                    );
                }
                return reject_result<std::string_view>(
                    alpha_result.message,
                    total
                );
            }

            expression := trimmed<std::string_view>(
                "chart_embed_expression_surface",
                line_expression_surface(
                    "chart_embed_expression_surface",
                    "chart_embed_expression"
                )
            );
            expression_r := expect_map(cursor, input, session, start, expression, "pure2_chart_embed_expression",
                :(result: scan_result<std::string_view>) -> std::string_view = {
                    if result.message == "expression group incomplete" {
                        return "embed expression incomplete";
                    }
                    return "embed expression expected";
                }
            );
            if expression_r.outcome != scan_signal::accept { return expression_r; }
            total := cursor - start;

            emit_trace(
                session,
                "pure2_chart_embed_expression",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_chart_embed_clause: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "chart_embed_keyword",
                literal("chart_embed_literal", "embed", "embed")
            );
            bindings := trimmed<std::string_view>(
                "chart_embed_bindings",
                balanced_group('(', ')', "chart_embed_binding_group", "chart_embed_parameters")
            );
            arrow := trimmed<std::string_view>(
                "chart_embed_arrow",
                arrow_parser("chart_embed_arrow_token")
            );
            expression := trimmed<std::string_view>(
                "chart_embed_expression",
                pure2_chart_embed_expression()
            );

            keyword_r := expect(cursor, input, session, start, keyword, "embed keyword expected", "embed keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            bindings_r := expect_diff(cursor, input, session, start, bindings, "pure2_chart_embed_clause", "embed parameter group incomplete", "embed parameter group expected");
            if bindings_r.outcome != scan_signal::accept { return bindings_r; }

            arrow_r := expect(cursor, input, session, start, arrow, "embed arrow expected", "embed arrow expected");            if arrow_r.outcome != scan_signal::accept { return arrow_r; }
            expression_r := finish_trace(input, session, start, cursor, expression, "pure2_chart_embed_clause");
            if expression_r.outcome != scan_signal::accept { return expression_r; }

            emit_trace(
                session,
                "pure2_chart_embed_clause",
                start,
                start + cursor - start + expression_r.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start + expression_r.consumed),
                cursor - start + expression_r.consumed
            );
        }
    );
}

pure2_chart_body: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_body",
                    start,
                    0,
                    scan_signal::need_more,
                    "chart body expected"
                );
            }

            if input[start] != '{' {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_body",
                    start,
                    0,
                    scan_signal::reject,
                    "chart body expected"
                );
            }

            cursor := start + 1;
            while true {
                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input,
                        session,
                        "pure2_chart_body",
                        start,
                        total,
                        scan_signal::need_more,
                        "chart body incomplete"
                    );
                }

                if input[cursor] == '}' {
                    stop := cursor + 1;
                    emit_trace(
                        session,
                        "pure2_chart_body",
                        start,
                        stop,
                        scan_signal::accept
                    );
                    record_feature(session, feature_kind::group, start, stop, "chart_body");
                    return accept_result<std::string_view>(
                        input.substr(start, stop - start),
                        stop - start
                    );
                }

                clause: parser_of<std::string_view> = ();
                if keyword_or_prefix_at(input, cursor, "contains") {
                    clause = pure2_chart_contains_clause();
                }
                else if keyword_or_prefix_at(input, cursor, "project") {
                    clause = pure2_chart_project_clause();
                }
                else if keyword_or_prefix_at(input, cursor, "embed") {
                    clause = pure2_chart_embed_clause();
                }
                else {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input,
                        session,
                        "pure2_chart_body",
                        start,
                        total,
                        scan_signal::reject,
                        "chart clause expected"
                    );
                }

                clause_r := expect_trace(cursor, input, session, start, clause, "pure2_chart_body");
                if clause_r.outcome != scan_signal::accept { return clause_r; }
            }
        }
    );
}

pure2_atlas_element: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            element := identifier_parser();
            element_result := element(input, start, session);
            if element_result.outcome != scan_signal::accept {
                emit_trace(
                    session,
                    "pure2_atlas_element",
                    start,
                    clamp_stop(input, start, element_result.consumed),
                    element_result.outcome
                );
                if element_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        element_result.consumed,
                        "atlas element expected"
                    );
                }
                return reject_result<std::string_view>(
                    "atlas element expected",
                    element_result.consumed
                );
            }

            emit_trace(
                session,
                "pure2_atlas_element",
                start,
                start + element_result.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                element_result.value.value(),
                element_result.consumed
            );
        }
    );
}

