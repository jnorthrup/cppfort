pure2_local_element: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            head := choice<std::string_view>(
                "local_element_head",
                integer_parser(),
                identifier_parser()
            );

            head_result := head(input, cursor, session);
            if head_result.outcome != scan_signal::accept {
                total := cursor - start + head_result.consumed;
                emit_trace(
                    session,
                    "pure2_local_element",
                    start,
                    clamp_stop(input, start, total),
                    head_result.outcome
                );
                if head_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        "local element expected"
                    );
                }
                return reject_result<std::string_view>(
                    "local element expected",
                    total
                );
            }
            cursor = cursor + head_result.consumed;

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() ||
               input[cursor] == ',' ||
               input[cursor] == ']' ||
               classify_delimiter_event(input[cursor]) == delimiter_event::group_close {
                total := cursor - start;
                emit_trace(
                    session,
                    "pure2_local_element",
                    start,
                    start + total,
                    scan_signal::accept
                );
                return accept_result<std::string_view>(
                    input.substr(start, total),
                    total
                );
            }

            tail := bracket_element_tail_surface(
                "local_element_tail_surface",
                "local_element_tail",
                "local element tail expected",
                "local element tail incomplete"
            );
            tail_result := tail(input, cursor, session);
            total := cursor - start + tail_result.consumed;
            if tail_result.outcome != scan_signal::accept {
                emit_trace(
                    session,
                    "pure2_local_element",
                    start,
                    clamp_stop(input, start, total),
                    tail_result.outcome
                );
                if tail_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        tail_result.message
                    );
                }
                return reject_result<std::string_view>(
                    tail_result.message,
                    total
                );
            }

            emit_trace(
                session,
                "pure2_local_element",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

