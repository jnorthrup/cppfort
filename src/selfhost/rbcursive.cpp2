series_literal_candidate_at: (
    input: std::string_view,
    cursor: int
) -> bool = {
    if cursor < 0 || cursor >= input.ssize() {
        return false;
    }
    if cursor + 1 >= input.ssize() {
        return false;
    }
    return input[cursor] == '_' && input[cursor + 1] == 's';
}

cursor_type_candidate_at: (
    input: std::string_view,
    cursor: int
) -> bool = {
    if cursor < 0 || cursor >= input.ssize() {
        return false;
    }
    if !keyword_or_prefix_at(input, cursor, "series") {
        return false;
    }

    scan_cursor := cursor + 6;
    while scan_cursor < input.ssize() && is_space(input[scan_cursor]) {
        scan_cursor = scan_cursor + 1;
    }

    if scan_cursor >= input.ssize() {
        return false;
    }

    return input[scan_cursor] == '<';
}

project_series_literal_feature_stream: (input: std::string_view, inout session: scan_session) -> scan_result<std::string_view> = {
    surface := pure2_series_literal();
    return surface(input, 0, session);
}

pure2_cursor_type: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;

            keyword := trimmed<std::string_view>(
                "cursor_type_keyword",
                keyword_parser("series")
            );
            open := trimmed<std::string_view>(
                "cursor_type_open_angle",
                open_angle_parser()
            );
            inner := trimmed<std::string_view>(
                "cursor_type_inner_keyword",
                keyword_parser("series")
            );
            close := trimmed<std::string_view>(
                "cursor_type_close_angle",
                close_angle_parser()
            );

            keyword_r := expect(cursor, input, session, start, keyword, "cursor type keyword expected", "cursor type keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            open_r := expect(cursor, input, session, start, open, "cursor type '<' expected", "cursor type '<' expected");            if open_r.outcome != scan_signal::accept { return open_r; }
            inner_r := expect(cursor, input, session, start, inner, "cursor type argument expected", "cursor type argument expected");            if inner_r.outcome != scan_signal::accept { return inner_r; }
            close_r := expect(cursor, input, session, start, close, "cursor type '>' expected", "cursor type '>' expected");            if close_r.outcome != scan_signal::accept { return close_r; }
            total := cursor - start;
            emit_trace(
                session,
                "pure2_cursor_type",
                start,
                start + total,
                scan_signal::accept
            );
            record_feature(session, feature_kind::surface, start, start + total, "cursor_type");
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_local_element: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            head := choice<std::string_view>(
                "local_element_head",
                integer_parser(),
                identifier_parser()
            );

            head_r := expect_trace(cursor, input, session, start, head, "pure2_local_element");
            if head_r.outcome != scan_signal::accept { return head_r; }

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() ||
               input[cursor] == ',' ||
               input[cursor] == ']' ||
               classify_delimiter_event(input[cursor]) == delimiter_event::group_close {
                total := cursor - start;
                emit_trace(
                    session,
                    "pure2_local_element",
                    start,
                    start + total,
                    scan_signal::accept
                );
                return accept_result<std::string_view>(
                    input.substr(start, total),
                    total
                );
            }

            tail := bracket_element_tail_surface(
                "local_element_tail_surface",
                "local_element_tail",
                "local element tail expected",
                "local element tail incomplete"
            );
            tail_r := finish_trace(input, session, start, cursor, tail, "pure2_local_element");
            if tail_r.outcome != scan_signal::accept { return tail_r; }

            emit_trace(
                session,
                "pure2_local_element",
                start,
                start + cursor - start + tail_r.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start + tail_r.consumed),
                cursor - start + tail_r.consumed
            );
        }
    );
}

pure2_local_literal: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "local_literal_keyword",
                keyword_parser("local")
            );
            elements := trimmed<std::string_view>(
                "local_literal_elements",
                feature_list_square_group(
                    "local_literal_group",
                    "local_elements",
                    pure2_local_element(),
                    "local element group expected",
                    "local element group incomplete",
                    "local element separator expected",
                    "local element expected"
                )
            );

            keyword_r := expect(cursor, input, session, start, keyword, "local keyword expected", "local keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            element_result := elements(input, cursor, session);
            total := cursor - start + element_result.consumed;
            if element_result.outcome != scan_signal::accept {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_local_literal",
                    start,
                    total,
                    element_result.outcome,
                    element_result.message
                );
            }

            emit_trace(
                session,
                "pure2_local_literal",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_join_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            lhs := trimmed<std::string_view>("join_lhs", identifier_parser());
            join_op := trimmed<std::string_view>("join_op", join_operator_parser("join_operator_token"));
            rhs := trimmed<std::string_view>("join_rhs", identifier_parser());

            r := expect(cursor, input, session, start, lhs, "pure2_join_expression", "join lhs expected");
            if r.outcome != scan_signal::accept { return r; }
            r = expect(cursor, input, session, start, join_op, "pure2_join_expression", "join operator expected");
            if r.outcome != scan_signal::accept { return r; }
            r = expect(cursor, input, session, start, rhs, "pure2_join_expression", "join rhs expected");
            if r.outcome != scan_signal::accept { return r; }

            // tail boundary check
            while cursor < input.ssize() && (input[cursor] == ' ' || input[cursor] == '\t') {
                cursor = cursor + 1;
            }
            if cursor < input.ssize() &&
               input[cursor] != '\n' && input[cursor] != '\r' &&
               input[cursor] != '}' && input[cursor] != ')' &&
               input[cursor] != ']' && input[cursor] != ',' {
                return surface_failure_result<std::string_view>(
                    input, session, "pure2_join_expression", start,
                    cursor - start, scan_signal::reject, "join tail unexpected"
                );
            }

            emit_trace(session, "pure2_join_expression", start, cursor, scan_signal::accept);
            return accept_result<std::string_view>(
                input.substr(start, cursor - start), cursor - start
            );
        }
    );
}

pure2_indexed_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
