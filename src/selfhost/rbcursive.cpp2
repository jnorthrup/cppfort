comparison_operator_parser: (
    rule: std::string_view = "comparison_operator"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start >= input.ssize() {
            emit_trace(session, rule$, start, start, scan_signal::need_more);
            return need_more_result<std::string_view>(0, "comparison operator expected");
        }

        stop := start;
        ch := input[start];
        if ch == '<' || ch == '>' {
            if start + 1 >= input.ssize() {
                emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
                return need_more_result<std::string_view>(0, "comparison operator expected");
            }

            stop = start + 1;
            if input[start + 1] == '=' {
                stop = stop + 1;
            }
        }
        else if ch == '=' || ch == '!' {
            if start + 1 >= input.ssize() {
                emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
                return need_more_result<std::string_view>(0, "comparison operator expected");
            }

            if input[start + 1] != '=' {
                emit_trace(session, rule$, start, start, scan_signal::reject);
                return reject_result<std::string_view>("comparison operator expected");
            }

            stop = start + 2;
        }
        else {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("comparison operator expected");
        }

        relation := input.substr(start, stop - start);
        emit_trace(session, rule$, start, stop, scan_signal::accept);
        record_feature(session, feature_kind::relation, start, stop, relation);
        return accept_result<std::string_view>(
            relation,
            stop - start
        );
    };
}

join_operator_parser: (
    rule: std::string_view = "join_operator"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start >= input.ssize() {
            emit_trace(session, rule$, start, start, scan_signal::need_more);
            return need_more_result<std::string_view>(0, "join operator expected");
        }

        if input[start] != 'j' {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("join operator expected");
        }

        stop := start + 1;
        if stop < input.ssize() && is_identifier_tail(input[stop]) {
            emit_trace(session, rule$, start, stop, scan_signal::reject);
            return reject_result<std::string_view>(
                "join operator expected",
                1
            );
        }

        emit_trace(session, rule$, start, stop, scan_signal::accept);
        record_feature(session, feature_kind::operator_token, start, stop, "join");
        return accept_result<std::string_view>(
            input.substr(start, 1),
            1
        );
    };
}

balanced_group: (
    open: char,
    close: char,
    rule: std::string_view = "balanced_group",
    semantic: std::string_view = "balanced_group"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start >= input.ssize() {
            emit_trace(session, rule$, start, start, scan_signal::need_more);
            return need_more_result<std::string_view>(0, "group open delimiter missing");
        }

        if classify_delimiter_event(input[start]) != delimiter_event::group_open || input[start] != open$ {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("unexpected group opener");
        }

        depth := 1;
        cursor := start + 1;
        while cursor < input.ssize() {
            if input[cursor] == open$ {
                depth = depth + 1;
            }
            else if input[cursor] == close$ {
                depth = depth - 1;
                if depth == 0 {
                    stop := cursor + 1;
                    emit_trace(session, rule$, start, stop, scan_signal::accept);
                    record_feature(session, feature_kind::group, start, stop, semantic$);
                    return accept_result<std::string_view>(
                        input.substr(start, stop - start),
                        stop - start
                    );
                }
            }
            cursor = cursor + 1;
        }

        emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
        return need_more_result<std::string_view>(
            input.ssize() - start,
            "group close delimiter missing"
        );
    };
}

line_expression_surface: (
    rule: std::string_view,
    semantic: std::string_view
) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            round_depth := 0;
            square_depth := 0;
            brace_depth := 0;
            stop := start;
            saw_payload := false;

            while cursor < input.ssize() {
                ch := input[cursor];
                if (ch == '\n' || ch == '\r') &&
                   round_depth == 0 &&
                   square_depth == 0 &&
                   brace_depth == 0 {
                    break;
                }

                if ch == '}' &&
                   round_depth == 0 &&
                   square_depth == 0 &&
                   brace_depth == 0 {
                    break;
                }

                if !is_space(ch) {
                    saw_payload = true;
                    stop = cursor + 1;
                }

                if ch == '(' {
                    round_depth = round_depth + 1;
                }
                else if ch == ')' {
                    if round_depth == 0 {
                        break;
                    }
                    round_depth = round_depth - 1;
                }
                else if ch == '[' {
                    square_depth = square_depth + 1;
                }
                else if ch == ']' {
                    if square_depth == 0 {
                        break;
                    }
                    square_depth = square_depth - 1;
                }
                else if ch == '{' {
                    brace_depth = brace_depth + 1;
                }
                else if ch == '}' {
                    if brace_depth == 0 {
                        break;
                    }
                    brace_depth = brace_depth - 1;
                }

                cursor = cursor + 1;
            }

            consumed := cursor - start;
            if round_depth != 0 || square_depth != 0 || brace_depth != 0 {
                emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                return need_more_result<std::string_view>(
                    consumed,
                    "expression group incomplete"
                );
            }

            if !saw_payload {
                outcome := scan_signal::reject;
                if cursor >= input.ssize() {
                    outcome = scan_signal::need_more;
                }

                emit_trace(session, rule$, start, cursor, outcome);
                if outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        consumed,
                        "clause expression expected"
                    );
                }

                return reject_result<std::string_view>(
                    "clause expression expected",
                    consumed
                );
            }

            emit_trace(session, rule$, start, cursor, scan_signal::accept);
            record_feature(session, feature_kind::surface, start, stop, semantic$);
            return accept_result<std::string_view>(
                input.substr(start, stop - start),
                consumed
            );
        }
    );
}

// ============================================================================
// COMBINATORS
// ============================================================================

with_traits: <T: type>(
    traits: trace_trait,
    p: parser_of<T>
) -> parser_of<T> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<T> = {
        saved := session.active_traits;
        session.active_traits = saved | traits$;
        result := p$(input, start, session);
        session.active_traits = saved;
        return result;
    };
}

choice: <T: type>(
    rule: std::string_view,
    left: parser_of<T>,
    right: parser_of<T>
) -> parser_of<T> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<T> = {
        first := left$(input, start, session);
        if first.outcome != scan_signal::reject {
            emit_trace(session, rule$, start, start + first.consumed, first.outcome);
            return first;
        }

        second := right$(input, start, session);
        emit_trace(session, rule$, start, start + second.consumed, second.outcome);
        return second;
    };
}

followed_by: <L: type, R: type>(
    rule: std::string_view,
    left: parser_of<L>,
    right: parser_of<R>
) -> parser_of<R> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<R> = {
        first := left$(input, start, session);
        if first.outcome == scan_signal::need_more {
            emit_trace(session, rule$, start, start + first.consumed, scan_signal::need_more);
            return need_more_result<R>(first.consumed, first.message);
        }
        if first.outcome == scan_signal::reject {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<R>(first.message, first.consumed);
        }

        second := right$(input, start + first.consumed, session);
        total := first.consumed + second.consumed;

        if second.outcome == scan_signal::accept {
            emit_trace(session, rule$, start, start + total, scan_signal::accept);
            return accept_result<R>(second.value.value(), total, second.message);
        }
        if second.outcome == scan_signal::need_more {
            emit_trace(session, rule$, start, start + total, scan_signal::need_more);
            return need_more_result<R>(total, second.message);
        }

        emit_trace(session, rule$, start, start + total, scan_signal::reject);
        return reject_result<R>(second.message, total);
    };
}

trimmed: <T: type>(
    rule: std::string_view,
    p: parser_of<T>
) -> parser_of<T> = {
    return with_traits<T>(
        trace_trait::skipper,
        followed_by<std::string_view, T>(rule, skip_ws(), p)
    );
}

// ============================================================================
// DRY COMBINATORS — one channel, eliminate repetition
// ============================================================================

// silent: run a parser without recording features (for sub-components)
// Captures feature count before, restores after — inner parser's features are discarded
silent: <T: type>(
    p: parser_of<T>
) -> parser_of<T> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<T> = {
        before := session.features.size();
        result := p$(input, start, session);
        // Trim features added by inner parser
        while session.features.size() > before {
            session.features.pop_back();
        }
        return result;
    };
}

// silent_trimmed: skip whitespace then parse silently (no sub-features)
silent_trimmed: <T: type>(
    p: parser_of<T>
) -> parser_of<T> = {
    return followed_by<std::string_view, T>(
        "silent_trimmed",
        skip_ws(),
        silent<T>(p)
    );
}

// run: skip whitespace, run parser, advance cursor or fail
run_ws: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    p: parser_of<std::string_view>
) -> scan_result<std::string_view> = {
    ws := skip_ws()(input, cursor, session);
    cursor = cursor + ws.consumed;
    return p(input, cursor, session);
}

// chain: run parser at cursor, advance on accept, reject on failure
chain: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    p: parser_of<std::string_view>
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
    }
    return result;
}

// chain_ws: skip whitespace, then chain
chain_ws: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    p: parser_of<std::string_view>
) -> scan_result<std::string_view> = {
    ws := skip_ws()(input, cursor, session);
    cursor = cursor + ws.consumed;
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
    }
    return result;
}

// expect: chain a parser, return structured failure on reject/need_more
// Advances cursor on accept and need_more (partial progress preserved)
expect: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    start: int,
    p: parser_of<std::string_view>,
    ctx: std::string_view,
    msg: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
        return result;
    }
    // Advance cursor on need_more (partial progress) but not on reject
    if result.outcome == scan_signal::need_more {
        cursor = cursor + result.consumed;
    }
    total := cursor - start;
    return surface_failure_result<std::string_view>(
        input, session, ctx, start, total, result.outcome, msg
    );
}

// expect_ws: skip whitespace, then expect
expect_ws: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    start: int,
    p: parser_of<std::string_view>,
    ctx: std::string_view,
    msg: std::string_view
) -> scan_result<std::string_view> = {
    ws := skip_ws()(input, cursor, session);
    cursor = cursor + ws.consumed;
    return expect(cursor, input, session, start, p, ctx, msg);
}

// expect_trace: chain parser, emit trace on failure, branch need_more/reject
expect_trace: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    start: int,
    p: parser_of<std::string_view>,
    rule: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
        return result;
    }
    total := cursor - start + result.consumed;
    emit_trace(session, rule, start, clamp_stop(input, start, total), result.outcome);
    if result.outcome == scan_signal::need_more {
        return need_more_result<std::string_view>(total, result.message);
    }
    return reject_result<std::string_view>(result.message, total);
}

// finish_trace: terminal parser — run from cursor, trace on failure, return on success
// Use when this is the LAST parser in a function (no cursor advance after)
// Caller computes total := cursor - start + result.consumed from returned result
finish_trace: (
    input: std::string_view,
    inout session: scan_session,
    start: int,
    cursor: int,
    p: parser_of<std::string_view>,
    rule: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome != scan_signal::accept {
        total := cursor - start + result.consumed;
        emit_trace(session, rule, start, clamp_stop(input, start, total), result.outcome);
        if result.outcome == scan_signal::need_more {
            return need_more_result<std::string_view>(total, result.message);
        }
        return reject_result<std::string_view>(result.message, total);
    }
    return result;
}

// finish_surface: terminal parser — return structured surface failure with one message
finish_surface: (
    input: std::string_view,
    inout session: scan_session,
    start: int,
    cursor: int,
    p: parser_of<std::string_view>,
    ctx: std::string_view,
    msg: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome != scan_signal::accept {
        return surface_failure_result<std::string_view>(
            input, session, ctx, start, cursor - start + result.consumed,
            result.outcome, msg
        );
    }
    return result;
}

// expect_map: like expect but message is computed from result
expect_map: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    start: int,
    p: parser_of<std::string_view>,
    ctx: std::string_view,
    msg_fn: std::function<(result: scan_result<std::string_view>) -> std::string_view>
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
        return result;
    }
    total := cursor - start + result.consumed;
    return surface_failure_result<std::string_view>(
        input, session, ctx, start, total, result.outcome, msg_fn(result)
    );
}

// finish_surface_passthrough: terminal parser — preserve parser-provided message
finish_surface_passthrough: (
    input: std::string_view,
    inout session: scan_session,
    start: int,
    cursor: int,
    p: parser_of<std::string_view>,
    ctx: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome != scan_signal::accept {
        return surface_failure_result<std::string_view>(
            input, session, ctx, start, cursor - start + result.consumed,
            result.outcome, result.message
        );
    }
    return result;
}

expect_diff: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    start: int,
    p: parser_of<std::string_view>,
    ctx: std::string_view,
    incomplete_msg: std::string_view,
    reject_msg: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
        return result;
    }
    if result.outcome == scan_signal::need_more {
        cursor = cursor + result.consumed;
        return surface_failure_result<std::string_view>(
            input, session, ctx, start, cursor - start,
            scan_signal::need_more, incomplete_msg
        );
    }
    return surface_failure_result<std::string_view>(
        input, session, ctx, start, cursor - start,
        scan_signal::reject, reject_msg
    );
}

// try_parse: run parser, return reject_result on failure (simpler than expect)
try_parse: (
    inout cursor: int,
    input: std::string_view,
    inout session: scan_session,
    p: parser_of<std::string_view>,
    msg: std::string_view
) -> scan_result<std::string_view> = {
    result := p(input, cursor, session);
    if result.outcome == scan_signal::accept {
        cursor = cursor + result.consumed;
        return result;
    }
    return reject_result<std::string_view>(msg, result.consumed);
}

// emit_accept: record a feature and return accept
// Replaces the 40x "record_feature(...); return accept_result<...>(...)" pattern
emit_accept: (
    input: std::string_view,
    inout session: scan_session,
    kind: feature_kind,
    start: int,
    stop: int,
    semantic: std::string_view
) -> scan_result<std::string_view> = {
    record_feature(session, kind, start, stop, semantic);
    return accept_result<std::string_view>(
        input.substr(start, stop - start),
        stop - start
    );
}

many: <T: type>(
    rule: std::string_view,
    p: parser_of<T>
) -> parser_of<std::vector<T>> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::vector<T>> = {
        values: std::vector<T> = ();
        cursor := start;

        while cursor < input.ssize() {
            next := p$(input, cursor, session);
            if next.outcome == scan_signal::accept {
                if next.consumed == 0 {
                    emit_trace(session, rule$, start, cursor, scan_signal::reject);
                    return reject_result<std::vector<T>>("many() inner parser consumed nothing");
                }
                values.push_back(next.value.value());
                cursor = cursor + next.consumed;
            }
            else if next.outcome == scan_signal::need_more {
                emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                return need_more_result<std::vector<T>>(cursor - start, next.message);
            }
            else {
                break;
            }
        }

        emit_trace(session, rule$, start, cursor, scan_signal::accept);
        return accept_result<std::vector<T>>(values, cursor - start);
    };
}

// ============================================================================
// PURE2-FIRST SCANNER SURFACES
// Feature stream first, richer retained tree later, mixed mode later still.
// ============================================================================

identifier_parser: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                emit_trace(session, "identifier", start, start, scan_signal::need_more);
                return need_more_result<std::string_view>(0, "identifier head expected");
            }

            if !is_identifier_head(input[start]) {
                emit_trace(session, "identifier", start, start, scan_signal::reject);
                return reject_result<std::string_view>("identifier head expected");
            }

            cursor := start + 1;
            while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
                cursor = cursor + 1;
            }

            slice := input.substr(start, cursor - start);
            emit_trace(session, "identifier", start, cursor, scan_signal::accept);
            record_feature(session, feature_kind::identifier, start, cursor, slice);
            return accept_result<std::string_view>(slice, cursor - start);
        }
    );
}

integer_parser: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                emit_trace(session, "integer", start, start, scan_signal::need_more);
                return need_more_result<std::string_view>(0, "integer digits expected");
            }

            cursor := start;
            if classify_lexer_event(input[cursor]) == lexer_event::sign {
                cursor = cursor + 1;
            }

            digits_start := cursor;
            while cursor < input.ssize() && is_digit(input[cursor]) {
                cursor = cursor + 1;
            }

            if digits_start == cursor {
                emit_trace(session, "integer", start, start, scan_signal::reject);
                return reject_result<std::string_view>("integer digits expected");
            }

            if cursor < input.ssize() && input[cursor] == '.' {
                emit_trace(session, "integer", start, cursor, scan_signal::reject);
                return reject_result<std::string_view>(
                    "integer digits expected",
                    cursor - start
                );
            }

            slice := input.substr(start, cursor - start);
            emit_trace(session, "integer", start, cursor, scan_signal::accept);
            record_feature(session, feature_kind::integer, start, cursor, slice);
            return accept_result<std::string_view>(slice, cursor - start);
        }
    );
}

scalar_literal_parser: (
    rule: std::string_view = "scalar_literal",
    semantic: std::string_view = ""
) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                emit_trace(session, rule$, start, start, scan_signal::need_more);
                return need_more_result<std::string_view>(0, "scalar digits expected");
            }

            cursor := start;
            if classify_lexer_event(input[cursor]) == lexer_event::sign {
                cursor = cursor + 1;
                if cursor >= input.ssize() {
                    emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
                    return need_more_result<std::string_view>(
                        cursor - start,
                        "scalar digits expected"
                    );
                }
            }

            digits_start := cursor;
            while cursor < input.ssize() && is_digit(input[cursor]) {
                cursor = cursor + 1;
            }

            if digits_start == cursor {
                emit_trace(session, rule$, start, cursor, scan_signal::reject);
                return reject_result<std::string_view>(
                    "scalar digits expected",
                    cursor - start
                );
            }

            if cursor < input.ssize() && input[cursor] == '.' {
                cursor = cursor + 1;
                if cursor >= input.ssize() {
                    emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
                    return need_more_result<std::string_view>(
                        cursor - start,
                        "scalar fractional digits expected"
                    );
                }

                fraction_start := cursor;
                while cursor < input.ssize() && is_digit(input[cursor]) {
                    cursor = cursor + 1;
                }

                if fraction_start == cursor {
                    emit_trace(session, rule$, start, cursor, scan_signal::reject);
                    return reject_result<std::string_view>(
                        "scalar fractional digits expected",
                        cursor - start
                    );
                }
            }

            slice := input.substr(start, cursor - start);
            emit_trace(session, rule$, start, cursor, scan_signal::accept);
            label: std::string_view = semantic$;
            if label.empty() {
                label = slice;
            }
            record_feature(session, feature_kind::scalar, start, cursor, label);
            return accept_result<std::string_view>(slice, cursor - start);
        }
    );
}

string_literal_parser: (
    rule: std::string_view = "string_literal",
    semantic: std::string_view = ""
) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                emit_trace(session, rule$, start, start, scan_signal::need_more);
                return need_more_result<std::string_view>(0, "string literal expected");
            }

            if input[start] != '"' {
                emit_trace(session, rule$, start, start, scan_signal::reject);
                return reject_result<std::string_view>("string literal expected");
            }

            cursor := start + 1;
            while cursor < input.ssize() {
                if input[cursor] == '\\' {
                    if cursor + 1 >= input.ssize() {
                        emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
                        return need_more_result<std::string_view>(
                            input.ssize() - start,
                            "string literal incomplete"
                        );
                    }
                    cursor = cursor + 2;
                    continue;
                }

                if input[cursor] == '"' {
                    stop := cursor + 1;
                    label := input.substr(start, stop - start);
                    if semantic$.empty() {
                        label = input.substr(start + 1, stop - start - 2);
                    }
                    else {
                        label = semantic$;
                    }
                    emit_trace(session, rule$, start, stop, scan_signal::accept);
                    record_feature(session, feature_kind::surface, start, stop, label);
                    return accept_result<std::string_view>(
                        input.substr(start, stop - start),
                        stop - start
                    );
                }

                if input[cursor] == '\n' || input[cursor] == '\r' {
                    emit_trace(session, rule$, start, cursor, scan_signal::reject);
                    return reject_result<std::string_view>(
                        "string literal incomplete",
                        cursor - start
                    );
                }

                cursor = cursor + 1;
            }

            emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
            return need_more_result<std::string_view>(
                input.ssize() - start,
                "string literal incomplete"
            );
        }
    );
}

bracket_element_tail_surface: (
    rule: std::string_view,
    semantic: std::string_view,
    expected_message: std::string_view,
    incomplete_message: std::string_view
) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            round_depth := 0;
            square_depth := 0;
            brace_depth := 0;
            stop := start;
            saw_payload := false;

            while cursor < input.ssize() {
                ch := input[cursor];
                if ch == ',' &&
                   round_depth == 0 &&
                   square_depth == 0 &&
                   brace_depth == 0 {
                    break;
                }

                if ch == ']' &&
                   round_depth == 0 &&
                   square_depth == 0 &&
                   brace_depth == 0 {
                    break;
                }

                if ch == ')' && round_depth == 0 {
                    break;
                }

                if ch == '}' && brace_depth == 0 {
                    break;
                }

                if !is_space(ch) {
                    saw_payload = true;
                    stop = cursor + 1;
                }

                if ch == '(' {
                    round_depth = round_depth + 1;
                }
                else if ch == ')' {
                    round_depth = round_depth - 1;
                }
                else if ch == '[' {
                    square_depth = square_depth + 1;
                }
                else if ch == ']' {
                    if square_depth == 0 {
                        break;
                    }
                    square_depth = square_depth - 1;
                }
                else if ch == '{' {
                    brace_depth = brace_depth + 1;
                }
                else if ch == '}' {
                    brace_depth = brace_depth - 1;
                }

                cursor = cursor + 1;
            }

            consumed := cursor - start;
            if round_depth != 0 || square_depth != 0 || brace_depth != 0 {
                emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                return need_more_result<std::string_view>(
                    consumed,
                    incomplete_message$
                );
            }

            if !saw_payload {
                outcome := scan_signal::reject;
                if cursor >= input.ssize() {
                    outcome = scan_signal::need_more;
                }

                emit_trace(session, rule$, start, cursor, outcome);
                if outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        consumed,
                        expected_message$
                    );
                }

                return reject_result<std::string_view>(
                    expected_message$,
                    consumed
                );
            }

            emit_trace(session, rule$, start, cursor, scan_signal::accept);
            record_feature(session, feature_kind::surface, start, stop, semantic$);
            return accept_result<std::string_view>(
                input.substr(start, stop - start),
                consumed
            );
        }
    );
}

feature_list_square_group: (
    rule: std::string_view,
    semantic: std::string_view,
    element: parser_of<std::string_view>,
    group_expected_message: std::string_view,
    group_incomplete_message: std::string_view,
    separator_expected_message: std::string_view,
    element_expected_message: std::string_view
) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() {
                emit_trace(session, rule$, start, start, scan_signal::need_more);
                return need_more_result<std::string_view>(0, group_incomplete_message$);
            }

            if input[start] != '[' {
                emit_trace(session, rule$, start, start, scan_signal::reject);
                return reject_result<std::string_view>(group_expected_message$);
            }

            cursor := start + 1;
            saw_element := false;
            expect_element := true;

            while true {
                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                    return need_more_result<std::string_view>(
                        cursor - start,
                        group_incomplete_message$
                    );
                }

                if input[cursor] == ']' {
                    if expect_element && saw_element {
                        emit_trace(session, rule$, start, cursor, scan_signal::reject);
                        return reject_result<std::string_view>(
                            element_expected_message$,
                            cursor - start
                        );
                    }

                    stop := cursor + 1;
                    emit_trace(session, rule$, start, stop, scan_signal::accept);
                    record_feature(session, feature_kind::group, start, stop, semantic$);
                    return accept_result<std::string_view>(
                        input.substr(start, stop - start),
                        stop - start
                    );
                }

                if classify_delimiter_event(input[cursor]) == delimiter_event::group_close {
                    emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                    return need_more_result<std::string_view>(
                        cursor - start,
                        group_incomplete_message$
                    );
                }

                if expect_element {
                    element_result := element$(input, cursor, session);
                    total := cursor - start + element_result.consumed;
                    if element_result.outcome != scan_signal::accept {
                        emit_trace(
                            session,
                            rule$,
                            start,
                            clamp_stop(input, start, total),
                            element_result.outcome
                        );
                        if element_result.outcome == scan_signal::need_more {
                            return need_more_result<std::string_view>(
                                total,
                                element_result.message
                            );
                        }
                        return reject_result<std::string_view>(
                            element_result.message,
                            total
                        );
                    }

                    cursor = cursor + element_result.consumed;
                    saw_element = true;
                    expect_element = false;
                    continue;
                }

                if input[cursor] == ',' {
                    cursor = cursor + 1;
                    expect_element = true;
                    continue;
                }

                if classify_delimiter_event(input[cursor]) == delimiter_event::group_close {
                    emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                    return need_more_result<std::string_view>(
                        cursor - start,
                        group_incomplete_message$
                    );
                }

                emit_trace(session, rule$, start, cursor, scan_signal::reject);
                return reject_result<std::string_view>(
                    separator_expected_message$,
                    cursor - start
                );
            }
        }
    );
}

keyword_parser: (keyword: std::string_view) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        literal("keyword", keyword, keyword)
    );
}

pure2_surface_head: () -> parser_of<std::string_view> = {
    return trimmed<std::string_view>(
        "pure2_surface_head",
        choice<std::string_view>(
            "surface_head_choice",
            keyword_parser("chart"),
            choice<std::string_view>(
                "surface_head_tail",
                keyword_parser("atlas"),
                keyword_parser("manifold")
            )
        )
    );
}

pure2_keyword_group: (keyword: std::string_view) -> parser_of<std::string_view> = {
    return followed_by<std::string_view, std::string_view>(
        "pure2_keyword_group",
        trimmed<std::string_view>("pure2_keyword", keyword_parser(keyword)),
        trimmed<std::string_view>("pure2_group", balanced_group('(', ')'))
    );
}

// ============================================================================
// CONFIRMED SURFACE GRAMMAR
// This is the active grammar carried by the JSON feature-stream scanner below.
// Keep this block aligned with the pure2_* surfaces and the selfhost smoke test.
//
// translation_unit    ::= { top_level }
// top_level           ::= chart_definition
//                       | manifold_decl
//                       | atlas_literal
//                       | coords_literal
//                       | transition_expr
//                       | join_expr
//                       | alpha_expr
//                       | indexed_expr
//                       | fold_expr
//                       | slice_expr
//                       | tag_declaration
//
// chart_definition    ::= chart_decl chart_body
// chart_decl          ::= "chart" identifier "(" parameter_text ")"
// chart_body          ::= "{" { chart_clause } "}"
// chart_clause        ::= contains_clause | project_clause | embed_clause
// contains_clause     ::= "contains" identifier relation scalar
// project_clause      ::= "project" "->" coords_literal
// embed_clause        ::= "embed" "(" identifier ")" "->" embed_expr
// embed_expr          ::= transition_expr | join_expr | alpha_expr | line_expr
//
// atlas_literal       ::= "atlas" "[" identifier { "," identifier } "]"
// manifold_decl       ::= "manifold" identifier "=" atlas_literal
// coords_literal      ::= "coords" "[" coords_element { "," coords_element } "]"
// coords_element      ::= scalar | line_expr
// join_expr           ::= identifier "j" identifier
// transition_expr     ::= identifier "." "transition"
//                         "(" string "," string "," coords_literal ")"
// alpha_expr          ::= "series" "α" "(" identifier ")" "=>" expression
// cursor_type         ::= "series" "<" "series" ">"
// slice_expr          ::= identifier "[" expression ".." expression "]"
// tag_declaration     ::= identifier ":" "int" "=" integer ";"
// ============================================================================

pure2_chart_declaration_head: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "chart_decl_keyword",
                keyword_parser("chart")
            );
            name := trimmed<std::string_view>(
                "chart_decl_name",
                identifier_parser()
            );
            parameters := trimmed<std::string_view>(
                "chart_decl_parameters",
                balanced_group('(', ')', "chart_decl_parameter_group", "chart_parameters")
            );

            keyword_r := expect(cursor, input, session, start, keyword, "pure2_chart_declaration_head", "chart keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            name_r := expect(cursor, input, session, start, name, "pure2_chart_declaration_head", "chart name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            parameter_r := expect_diff(cursor, input, session, start, parameters, "pure2_chart_declaration_head", "chart parameter group incomplete", "chart parameter group expected");
            if parameter_r.outcome != scan_signal::accept { return parameter_r; }
            total := cursor - start;

            emit_trace(
                session,
                "pure2_chart_declaration_head",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_chart_definition: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            head := pure2_chart_declaration_head();
            body := trimmed<std::string_view>(
                "chart_decl_body",
                pure2_chart_body()
            );

            head_r := expect_trace(cursor, input, session, start, head, "pure2_chart_definition");
            if head_r.outcome != scan_signal::accept { return head_r; }

            body_r := finish_trace(input, session, start, cursor, body, "pure2_chart_definition");
            if body_r.outcome != scan_signal::accept { return body_r; }

            emit_trace(
                session,
                "pure2_chart_definition",
                start,
                start + cursor - start + body_r.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start + body_r.consumed),
                cursor - start + body_r.consumed
            );
        }
    );
}

pure2_namespace_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            is_alias := false;

            name := trimmed<std::string_view>("namespace_name", identifier_parser());
            name_r := expect(cursor, input, session, start, name, "namespace name expected", "namespace name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            colon := trimmed<std::string_view>("namespace_colon", colon_parser("namespace_colon"));
            colon_r := expect(cursor, input, session, start, colon, "namespace ':' expected", "namespace ':' expected");            if colon_r.outcome != scan_signal::accept { return colon_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            ns_keyword := trimmed<std::string_view>("namespace_keyword", keyword_parser("namespace"));
            ns_keyword_r := expect(cursor, input, session, start, ns_keyword, "namespace 'namespace' keyword expected", "namespace 'namespace' keyword expected");            if ns_keyword_r.outcome != scan_signal::accept { return ns_keyword_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            assign_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '=' {
                if cursor + 1 < input.ssize() && input[cursor + 1] == '=' {
                    double_equals := trimmed<std::string_view>("namespace_double_equals", double_equals_parser("namespace_double_equals"));
                    de_result := double_equals(input, cursor, session);
                    if de_result.outcome == scan_signal::accept {
                        assign_consumed = de_result.consumed;
                        is_alias = true;
                        emit_trace(session, "namespace_double_equals", cursor, cursor + assign_consumed, scan_signal::accept);
                    }
                }
            }
            
            if assign_consumed == 0 {
                assign := trimmed<std::string_view>("namespace_assign", equals_parser("namespace_assign"));
                assign_r := expect(cursor, input, session, start, assign, "namespace '=' or '==' expected", "namespace '=' or '==' expected");                if assign_r.outcome != scan_signal::accept { return assign_r; }            }
            cursor = cursor + assign_consumed;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if is_alias {
                target := line_expression_surface("namespace_target_surface", "namespace_target");
                target_r := expect(cursor, input, session, start, target, "namespace alias target expected", "namespace alias target expected");
                if target_r.outcome != scan_signal::accept { return target_r; }
                total := cursor - start;
                
                emit_trace(
                    session,
                    "pure2_namespace_declaration",
                    start,
                    start + total,
                    scan_signal::accept
                );
                record_feature(
                    session,
                    feature_kind::group,
                    start,
                    start + total,
                    "namespace_alias"
                );
                
                return accept_result<std::string_view>(
                    input.substr(start, total),
                    total
                );
            }
            
            body := trimmed<std::string_view>(
                "namespace_body",
                balanced_group('{', '}', "namespace_body_group", "namespace_body")
            );
            body_result := body(input, cursor, session);
            total := cursor - start + body_result.consumed;
            if body_result.outcome != scan_signal::accept {
                message: std::string_view = "namespace body incomplete";
                if body_result.outcome == scan_signal::reject {
                    message = "namespace body '{ ... }' expected";
                }
                return surface_failure_result<std::string_view>(
                    input, session, "pure2_namespace_declaration", start, total,
                    body_result.outcome, message
                );
            }

            emit_trace(
                session,
                "pure2_namespace_declaration",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

param_kind_keyword: (keyword: std::string_view) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        trimmed<std::string_view>("param_kind", keyword_parser(keyword))
    );
}

pure2_param_kind: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            p1 := param_kind_keyword("in");
            r1 := p1(input, start, session);
            if r1.outcome == scan_signal::accept {
                return r1;
            }

            p2 := param_kind_keyword("inout");
            r2 := p2(input, start, session);
            if r2.outcome == scan_signal::accept {
                return r2;
            }

            p3 := param_kind_keyword("out");
            r3 := p3(input, start, session);
            if r3.outcome == scan_signal::accept {
                return r3;
            }

            p4 := param_kind_keyword("copy");
            r4 := p4(input, start, session);
            if r4.outcome == scan_signal::accept {
                return r4;
            }

            p5 := param_kind_keyword("move");
            r5 := p5(input, start, session);
            if r5.outcome == scan_signal::accept {
                return r5;
            }

            p6 := param_kind_keyword("forward");
            r6 := p6(input, start, session);
            emit_trace(session, "param_kind_choice", start, start + r6.consumed, r6.outcome);
            return r6;
        }
    );
}

pure2_return_modifier: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            p1 := trimmed<std::string_view>("return_move", keyword_parser("move"));
            r1 := p1(input, start, session);
            if r1.outcome == scan_signal::accept {
                return r1;
            }

            p2 := trimmed<std::string_view>("return_forward", keyword_parser("forward"));
            r2 := p2(input, start, session);
            emit_trace(session, "return_modifier_choice", start, start + r2.consumed, r2.outcome);
            return r2;
        }
    );
}

pure2_virtual_modifier: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            p1 := trimmed<std::string_view>("virtual_keyword", keyword_parser("virtual"));
            r1 := p1(input, start, session);
            if r1.outcome == scan_signal::accept {
                return r1;
            }

            p2 := trimmed<std::string_view>("override_keyword", keyword_parser("override"));
            r2 := p2(input, start, session);
            if r2.outcome == scan_signal::accept {
                return r2;
            }

            p3 := trimmed<std::string_view>("final_keyword", keyword_parser("final"));
            r3 := p3(input, start, session);
            emit_trace(session, "virtual_modifier_choice", start, start + r3.consumed, r3.outcome);
            return r3;
        }
    );
}

pure2_string_interpolation: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            if cursor >= input.ssize() || input[cursor] != '$' {
                return reject_result<std::string_view>("string interpolation start expected", 0);
            }
            cursor = cursor + 1;
            
            if cursor >= input.ssize() || input[cursor] != '"' {
                return reject_result<std::string_view>("string interpolation quote expected", 1);
            }
            cursor = cursor + 1;
            
            while cursor < input.ssize() {
                ch := input[cursor];
                if ch == '"' {
                    cursor = cursor + 1;
                    consumed := cursor - start;
                    emit_trace(session, "string_interpolation", start, cursor, scan_signal::accept);
                    record_feature(session, feature_kind::surface, start, cursor, "string_interpolation");
                    return accept_result<std::string_view>(input.substr(start, consumed), consumed);
                }
                if ch == '\\' && cursor + 1 < input.ssize() {
                    cursor = cursor + 2;
                }
                else {
                    cursor = cursor + 1;
                }
            }
            
            emit_trace(session, "string_interpolation", start, cursor, scan_signal::need_more);
            return need_more_result<std::string_view>(cursor - start, "string interpolation incomplete");
        }
    );
}

pure2_inspect_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            
            inspect_kw := trimmed<std::string_view>("inspect_keyword", keyword_parser("inspect"));
            inspect_kw_r := try_parse(cursor, input, session, inspect_kw, "inspect keyword expected");
            if inspect_kw_r.outcome != scan_signal::accept { return inspect_kw_r; }
            
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            
            open_paren := trimmed<std::string_view>("inspect_open_paren", open_paren_parser());
            open_paren_r := try_parse(cursor, input, session, open_paren, "inspect '(' expected");
            if open_paren_r.outcome != scan_signal::accept { return open_paren_r; }
            
            expr := line_expression_surface("inspect_expr_surface", "inspect_expr");
            expr_result := expr(input, cursor, session);
            cursor = cursor + expr_result.consumed;
            
            close_paren := trimmed<std::string_view>("inspect_close_paren", close_paren_parser());
            close_paren_r := try_parse(cursor, input, session, close_paren, "inspect ')' expected");
            if close_paren_r.outcome != scan_signal::accept { return close_paren_r; }
            
            consumed := cursor - start;
            emit_trace(session, "inspect_expression", start, cursor, scan_signal::accept);
            record_feature(session, feature_kind::surface, start, consumed, "inspect_expression");
            return accept_result<std::string_view>(input.substr(start, consumed), consumed);
        }
    );
}

function_declaration_candidate_at: (input: std::string_view, cursor: int) -> bool = {
    remaining: std::string_view = input.substr(cursor);
    if remaining.ssize() < 5 {
        return false;
    }
    
    i: int = 0;
    while i < remaining.ssize() && (remaining[i] == ' ' || remaining[i] == '\t' || remaining[i] == '\n' || remaining[i] == '\r') {
        i += 1;
    }
    
    if i >= remaining.ssize() {
        return false;
    }
    
    if (remaining[i] >= 'a' && remaining[i] <= 'z') || (remaining[i] >= 'A' && remaining[i] <= 'Z') || remaining[i] == '_' {
        name_end := i + 1;
        while name_end < remaining.ssize() && ((remaining[name_end] >= 'a' && remaining[name_end] <= 'z') || 
               (remaining[name_end] >= 'A' && remaining[name_end] <= 'Z') || 
               (remaining[name_end] >= '0' && remaining[name_end] <= '9') || 
               remaining[name_end] == '_') {
            name_end += 1;
        }
        
        j: int = name_end;
        while j < remaining.ssize() && (remaining[j] == ' ' || remaining[j] == '\t' || remaining[j] == '\n' || remaining[j] == '\r') {
            j += 1;
        }
        
        if j < remaining.ssize() && remaining[j] == ':' {
            j += 1;
            while j < remaining.ssize() && (remaining[j] == ' ' || remaining[j] == '\t' || remaining[j] == '\n' || remaining[j] == '\r') {
                j += 1;
            }
            
            if j < remaining.ssize() && remaining[j] == '(' {
                return true;
            }
        }
        
        if j < remaining.ssize() && remaining[j] == '<' {
            k: int = j + 1;
            while k < remaining.ssize() && (remaining[k] == ' ' || remaining[k] == '\t' || remaining[k] == '\n' || remaining[k] == '\r') {
                k += 1;
            }
            
            if k < remaining.ssize() {
                if remaining[k] == ':' {
                    k += 1;
                    while k < remaining.ssize() && (remaining[k] == ' ' || remaining[k] == '\t' || remaining[k] == '\n' || remaining[k] == '\r') {
                        k += 1;
                    }
                    
                    if k < remaining.ssize() && remaining[k] == '(' {
                        return true;
                    }
                }
                else if (remaining[k] >= 'a' && remaining[k] <= 'z') || (remaining[k] >= 'A' && remaining[k] <= 'Z') || remaining[k] == '_' {
                    tp_name_end := k + 1;
                    while tp_name_end < remaining.ssize() && ((remaining[tp_name_end] >= 'a' && remaining[tp_name_end] <= 'z') || 
                           (remaining[tp_name_end] >= 'A' && remaining[tp_name_end] <= 'Z') || 
                           (remaining[tp_name_end] >= '0' && remaining[tp_name_end] <= '9') || 
                           remaining[tp_name_end] == '_') {
                        tp_name_end += 1;
                    }
                    
                    m: int = tp_name_end;
                    while m < remaining.ssize() && (remaining[m] == ' ' || remaining[m] == '\t' || remaining[m] == '\n' || remaining[m] == '\r') {
                        m += 1;
                    }
                    
                    if m < remaining.ssize() && remaining[m] == ':' {
                        m += 1;
                        while m < remaining.ssize() && (remaining[m] == ' ' || remaining[m] == '\t' || remaining[m] == '\n' || remaining[m] == '\r') {
                            m += 1;
                        }
                        
                        if m < remaining.ssize() && remaining[m] == '(' {
                            return true;
                        }
                    }
                    
                    if m < remaining.ssize() && remaining[m] == '>' {
                        m += 1;
                        while m < remaining.ssize() && (remaining[m] == ' ' || remaining[m] == '\t' || remaining[m] == '\n' || remaining[m] == '\r') {
                            m += 1;
                        }
                        
                        if m < remaining.ssize() && remaining[m] == ':' {
                            m += 1;
                            while m < remaining.ssize() && (remaining[m] == ' ' || remaining[m] == '\t' || remaining[m] == '\n' || remaining[m] == '\r') {
                                m += 1;
                            }
                            
                            if m < remaining.ssize() && remaining[m] == '(' {
                                return true;
                            }
                        }
                    }
                }
            }
        }
    }
    return false;
}

pure2_function_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            is_alias := false;

            name := trimmed<std::string_view>("func_name", identifier_parser());
            name_r := expect(cursor, input, session, start, name, "function name expected", "function name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            type_params_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '<' {
                type_params := pure2_type_parameters();
                type_params_result := type_params(input, cursor, session);
                if type_params_result.outcome == scan_signal::accept {
                    type_params_consumed = type_params_result.consumed;
                    cursor = cursor + type_params_consumed;
                    
                    ws_result = skip_ws()(input, cursor, session);
                    cursor = cursor + ws_result.consumed;
                }
            }

            colon := trimmed<std::string_view>("func_colon", colon_parser("func_colon"));
            colon_r := expect(cursor, input, session, start, colon, "function ':' expected", "function ':' expected");            if colon_r.outcome != scan_signal::accept { return colon_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            open_paren := trimmed<std::string_view>("func_open_paren", open_paren_parser());
            open_paren_r := expect(cursor, input, session, start, open_paren, "function parameters '(' expected", "function parameters '(' expected");            if open_paren_r.outcome != scan_signal::accept { return open_paren_r; }
            params_consumed := 0;
            if cursor < input.ssize() && input[cursor] != ')' {
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;
                
                if cursor < input.ssize() {
                    params := line_expression_surface("func_params_surface", "func_params");
                    params_result := params(input, cursor, session);
                    params_consumed = params_result.consumed;
                    cursor = cursor + params_consumed;
                }
            }

            close_paren := trimmed<std::string_view>("func_close_paren", close_paren_parser());
            close_paren_r := expect(cursor, input, session, start, close_paren, "function parameters ')' expected", "function parameters ')' expected");            if close_paren_r.outcome != scan_signal::accept { return close_paren_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            return_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '-' && cursor + 1 < input.ssize() && input[cursor + 1] == '>' {
                emit_trace(session, "func_return_arrow", cursor, cursor + 2, scan_signal::accept);
                cursor = cursor + 2;
                
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;
                
                return_type := line_expression_surface("func_return_type_surface", "func_return_type");
                return_result := return_type(input, cursor, session);
                return_consumed = return_result.consumed;
                cursor = cursor + return_consumed;
            }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            equals_consumed := 0;
            
            if cursor < input.ssize() && input[cursor] == '=' {
                if cursor + 1 < input.ssize() && input[cursor + 1] == '=' {
                    double_equals := trimmed<std::string_view>("func_double_equals", double_equals_parser("func_double_equals"));
                    de_result := double_equals(input, cursor, session);
                    if de_result.outcome == scan_signal::accept {
                        equals_consumed = de_result.consumed;
                        is_alias = true;
                        emit_trace(session, "func_double_equals", cursor, cursor + equals_consumed, scan_signal::accept);
                    }
                }
            }
            
            if equals_consumed == 0 {
                equals := trimmed<std::string_view>("func_equals", equals_parser("func_equals"));
                equals_r := expect(cursor, input, session, start, equals, "function '=' or '==' expected", "function '=' or '==' expected");                if equals_r.outcome != scan_signal::accept { return equals_r; }            }
            cursor = cursor + equals_consumed;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            body_consumed := 0;
            if cursor < input.ssize() {
                if input[cursor] == '{' {
                    body := balanced_group('{', '}');
                    body_result := body(input, cursor, session);
                    body_consumed = body_result.consumed;
                    cursor = cursor + body_consumed;
                }
                else {
                    body_expr := line_expression_surface("func_body_surface", "func_body");
                    body_result := body_expr(input, cursor, session);
                    body_consumed = body_result.consumed;
                    cursor = cursor + body_consumed;
                    
                    if is_alias {
                        ws_result = skip_ws()(input, cursor, session);
                        cursor = cursor + ws_result.consumed;
                        
                        if cursor < input.ssize() && input[cursor] == ';' {
                            body_consumed = body_consumed + 1;
                            cursor = cursor + 1;
                        }
                    }
                }
            }

            total := cursor - start;
            
            emit_trace(
                session,
                "pure2_function_declaration",
                start,
                start + total,
                scan_signal::accept
            );
            if is_alias {
                record_feature(
                    session,
                    feature_kind::group,
                    start,
                    start + total,
                    "function_alias"
                );
            }
            else {
                record_feature(
                    session,
                    feature_kind::group,
                    start,
                    start + total,
                    "function_declaration"
                );
            }
            
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

type_param_candidate_at: (input: std::string_view, cursor: int) -> bool = {
    remaining: std::string_view = input.substr(cursor);
    if remaining.ssize() < 2 {
        return false;
    }
    
    i: int = 0;
    while i < remaining.ssize() && (remaining[i] == ' ' || remaining[i] == '\t' || remaining[i] == '\n' || remaining[i] == '\r') {
        i += 1;
    }
    
    if i >= remaining.ssize() {
        return false;
    }
    
    if (remaining[i] >= 'a' && remaining[i] <= 'z') || (remaining[i] >= 'A' && remaining[i] <= 'Z') || remaining[i] == '_' {
        return true;
    }
    return false;
}

pure2_type_parameters: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;

            open_angle := trimmed<std::string_view>("tp_open_angle", open_angle_parser());
            open_angle_r := expect(cursor, input, session, start, open_angle, "type parameters '<' expected", "type parameters '<' expected");            if open_angle_r.outcome != scan_signal::accept { return open_angle_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            param_count: int = 0;
            while cursor < input.ssize() && input[cursor] != '>' {
                if param_count > 0 {
                    comma := trimmed<std::string_view>("tp_param_comma", comma_parser());
                    comma_r := expect(cursor, input, session, start, comma, "type parameter ',' expected", "type parameter ',' expected");                    if comma_r.outcome != scan_signal::accept { return comma_r; }                    
                    ws_result = skip_ws()(input, cursor, session);
                    cursor = cursor + ws_result.consumed;
                }
                
                if !type_param_candidate_at(input, cursor) {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input, session, "pure2_type_parameters", start, total,
                        scan_signal::reject, "type parameter expected"
                    );
                }
                
                name := trimmed<std::string_view>("tp_param_name", identifier_parser());
                name_r := expect(cursor, input, session, start, name, "type parameter name expected", "type parameter name expected");                if name_r.outcome != scan_signal::accept { return name_r; }                
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;
                
                if cursor < input.ssize() && input[cursor] == ':' {
                    colon := trimmed<std::string_view>("tp_param_colon", colon_parser("tp_param_colon"));
                    colon_result := colon(input, cursor, session);
                    if colon_result.outcome == scan_signal::accept {
                        cursor = cursor + colon_result.consumed;
                        
                        ws_result = skip_ws()(input, cursor, session);
                        cursor = cursor + ws_result.consumed;
                        
                        remaining: std::string_view = input.substr(cursor);
                        requires_idx: int = -1;
                        j: int = 0;
                        while j < remaining.ssize() && j < 20 {
                            if remaining[j] == 'r' && j + 7 <= remaining.ssize() {
                                if remaining.substr(j, 8) == "requires " || remaining.substr(j, 7) == "requires" {
                                    requires_idx = j;
                                    break;
                                }
                            }
                            j += 1;
                        }
                        
                        if requires_idx >= 0 && requires_idx < 20 {
                            req_kw := trimmed<std::string_view>("tp_requires_kw", keyword_parser("requires"));
                            req_result := req_kw(input, cursor, session);
                            if req_result.outcome == scan_signal::accept {
                                cursor = cursor + req_result.consumed;
                                
                                ws_result = skip_ws()(input, cursor, session);
                                cursor = cursor + ws_result.consumed;
                                
                                constraint_expr := line_expression_surface("tp_constraint", "tp_constraint");
                                constraint_result := constraint_expr(input, cursor, session);
                                if constraint_result.outcome == scan_signal::accept {
                                    cursor = cursor + constraint_result.consumed;
                                }
                            }
                        }
                        else {
                            type_expr := line_expression_surface("tp_type_constraint", "tp_type_constraint");
                            type_result := type_expr(input, cursor, session);
                            if type_result.outcome == scan_signal::accept {
                                cursor = cursor + type_result.consumed;
                            }
                        }
                        
                        ws_result = skip_ws()(input, cursor, session);
                        cursor = cursor + ws_result.consumed;
                    }
                }
                
                param_count += 1;
            }

            close_angle := trimmed<std::string_view>("tp_close_angle", close_angle_parser());
            close_angle_r := expect(cursor, input, session, start, close_angle, "type parameters '>' expected", "type parameters '>' expected");            if close_angle_r.outcome != scan_signal::accept { return close_angle_r; }
            total := cursor - start;
            emit_trace(
                session,
                "pure2_type_parameters",
                start,
                start + total,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::group,
                start,
                start + total,
                "type_parameters"
            );
            
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_type_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            is_alias := false;

            name := trimmed<std::string_view>("type_name", identifier_parser());
            name_r := expect(cursor, input, session, start, name, "type name expected", "type name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            type_params_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '<' {
                type_params := pure2_type_parameters();
                type_params_result := type_params(input, cursor, session);
                if type_params_result.outcome == scan_signal::accept {
                    type_params_consumed = type_params_result.consumed;
                    cursor = cursor + type_params_consumed;
                    
                    ws_result = skip_ws()(input, cursor, session);
                    cursor = cursor + ws_result.consumed;
                }
            }

            colon := trimmed<std::string_view>("type_colon", colon_parser("type_colon"));
            colon_r := expect(cursor, input, session, start, colon, "type ':' expected", "type ':' expected");            if colon_r.outcome != scan_signal::accept { return colon_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            type_keyword := trimmed<std::string_view>("type_keyword", keyword_parser("type"));
            type_keyword_r := expect(cursor, input, session, start, type_keyword, "type 'type' keyword expected", "type 'type' keyword expected");            if type_keyword_r.outcome != scan_signal::accept { return type_keyword_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            equals_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '=' {
                if cursor + 1 < input.ssize() && input[cursor + 1] == '=' {
                    double_equals := trimmed<std::string_view>("type_double_equals", double_equals_parser("type_double_equals"));
                    de_result := double_equals(input, cursor, session);
                    if de_result.outcome == scan_signal::accept {
                        equals_consumed = de_result.consumed;
                        is_alias = true;
                        emit_trace(session, "type_double_equals", cursor, cursor + equals_consumed, scan_signal::accept);
                    }
                }
            }
            
            if equals_consumed == 0 {
                equals := trimmed<std::string_view>("type_equals", equals_parser("type_equals"));
                equals_r := expect(cursor, input, session, start, equals, "type '=' or '==' expected", "type '=' or '==' expected");                if equals_r.outcome != scan_signal::accept { return equals_r; }            }
            cursor = cursor + equals_consumed;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            body_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '{' {
                body := balanced_group('{', '}');
                body_result := body(input, cursor, session);
                body_consumed = body_result.consumed;
                cursor = cursor + body_consumed;
            }
            else if is_alias && cursor < input.ssize() {
                alias_expr := line_expression_surface("type_alias_expr_surface", "type_alias_expr");
                alias_result := alias_expr(input, cursor, session);
                body_consumed = alias_result.consumed;
                cursor = cursor + body_consumed;
                
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;
                
                if cursor < input.ssize() && input[cursor] == ';' {
                    body_consumed = body_consumed + 1;
                    cursor = cursor + 1;
                }
            }

            total := cursor - start;
            
            emit_trace(
                session,
                "pure2_type_declaration",
                start,
                start + total,
                scan_signal::accept
            );
            if is_alias {
                record_feature(
                    session,
                    feature_kind::group,
                    start,
                    start + total,
                    "type_alias"
                );
            }
            else {
                record_feature(
                    session,
                    feature_kind::group,
                    start,
                    start + total,
                    "type_declaration"
                );
            }
            
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

contract_precondition_candidate_at: (input: std::string_view, cursor: int) -> bool = {
    remaining: std::string_view = input.substr(cursor);
    if remaining.ssize() < 5 {
        return false;
    }
    
    i: int = 0;
    while i < remaining.ssize() && (remaining[i] == ' ' || remaining[i] == '\t' || remaining[i] == '\n' || remaining[i] == '\r') {
        i += 1;
    }
    
    if i + 3 <= remaining.ssize() {
        if remaining[i] == 'p' && remaining[i+1] == 'r' && remaining[i+2] == 'e' && 
           (i + 3 == remaining.ssize() || remaining[i+3] == '(' || remaining[i+3] == ' ') {
            return true;
        }
    }
    return false;
}

