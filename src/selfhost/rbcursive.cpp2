pure2_alpha_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            series_keyword := trimmed<std::string_view>(
                "alpha_series_keyword",
                keyword_parser("series")
            );
            alpha_op := trimmed<std::string_view>(
                "alpha_operator",
                literal("alpha_operator_literal", "\u03B1", "alpha")
            );
            binder := trimmed<std::string_view>(
                "alpha_binder",
                balanced_group('(', ')', "alpha_binder_group", "alpha_parameters")
            );
            arrow := trimmed<std::string_view>(
                "alpha_arrow",
                fat_arrow_parser("alpha_arrow_token")
            );
            payload := trimmed<std::string_view>(
                "alpha_payload",
                line_expression_surface(
                    "alpha_payload_surface",
                    "alpha_payload_expression"
                )
            );

            series_keyword_r := expect(cursor, input, session, start, series_keyword, "series keyword expected", "series keyword expected");            if series_keyword_r.outcome != scan_signal::accept { return series_keyword_r; }
            alpha_op_r := expect(cursor, input, session, start, alpha_op, "pure2_alpha_expression", "alpha operator expected");
            if alpha_op_r.outcome != scan_signal::accept { return alpha_op_r; }

            binder_r := expect_diff(cursor, input, session, start, binder, "pure2_alpha_expression", "alpha binder group incomplete", "alpha binder group expected");
            if binder_r.outcome != scan_signal::accept { return binder_r; }

            arrow_r := expect(cursor, input, session, start, arrow, "alpha arrow '=>' expected", "alpha arrow '=>' expected");            if arrow_r.outcome != scan_signal::accept { return arrow_r; }
            payload_r := expect_map(cursor, input, session, start, payload, "pure2_alpha_expression",
                :(result: scan_result<std::string_view>) -> std::string_view = {
                    if result.message == "expression group incomplete" {
                        return "alpha payload incomplete";
                    }
                    return "alpha payload expected";
                }
            );
            if payload_r.outcome != scan_signal::accept { return payload_r; }
            total := cursor - start;

            emit_trace(
                session,
                "pure2_alpha_expression",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_transition_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            receiver := trimmed<std::string_view>(
                "transition_receiver",
                identifier_parser()
            );
            keyword := trimmed<std::string_view>(
                "transition_keyword",
                keyword_parser("transition")
            );
            source_name := trimmed<std::string_view>(
                "transition_source_name",
                string_literal_parser("transition_source_string")
            );
            target_name := trimmed<std::string_view>(
                "transition_target_name",
                string_literal_parser("transition_target_string")
            );
            coordinates := trimmed<std::string_view>(
                "transition_coordinates",
                pure2_coords_literal()
            );

            receiver_r := expect(cursor, input, session, start, receiver, "transition receiver expected", "transition receiver expected");            if receiver_r.outcome != scan_signal::accept { return receiver_r; }
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition member access expected"
                );
            }
            if input[cursor] != '.' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition member access expected"
                );
            }
            cursor = cursor + 1;

            keyword_r := expect(cursor, input, session, start, keyword, "transition keyword expected", "transition keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument list incomplete"
                );
            }
            if input[cursor] != '(' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument list expected"
                );
            }

            group_start := cursor;
            cursor = cursor + 1;

            source_name_r := expect(cursor, input, session, start, source_name, "transition source expected", "transition source expected");            if source_name_r.outcome != scan_signal::accept { return source_name_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument separator expected"
                );
            }
            if input[cursor] != ',' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument separator expected"
                );
            }
            cursor = cursor + 1;

            target_name_r := expect(cursor, input, session, start, target_name, "transition target expected", "transition target expected");            if target_name_r.outcome != scan_signal::accept { return target_name_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument separator expected"
                );
            }
            if input[cursor] != ',' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument separator expected"
                );
            }
            cursor = cursor + 1;

            coordinates_r := expect_trace(cursor, input, session, start, coordinates, "pure2_transition_expression");
            if coordinates_r.outcome != scan_signal::accept { return coordinates_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument list incomplete"
                );
            }
            if input[cursor] != ')' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument list incomplete"
                );
            }
            cursor = cursor + 1;

            emit_trace(
                session,
                "pure2_transition_expression",
                start,
                cursor,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::group,
                group_start,
                cursor,
                "transition_arguments"
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start),
                cursor - start
            );
        }
    );
}

grad_candidate_at: (input: std::string_view, cursor: int) -> bool = {
    remaining: std::string_view = input.substr(cursor);
    return remaining.starts_with("grad(");
}

pure2_grad_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "grad_keyword",
                keyword_parser("grad")
            );
            open_paren := trimmed<std::string_view>(
                "grad_open_paren",
                open_paren_parser()
            );
            comma := trimmed<std::string_view>(
                "grad_comma",
                comma_parser()
            );
            close_paren := trimmed<std::string_view>(
                "grad_close_paren",
                close_paren_parser()
            );
            expr := trimmed<std::string_view>(
                "grad_expression",
                identifier_parser()
            );
            var := trimmed<std::string_view>(
                "grad_variable",
                identifier_parser()
            );

            keyword_r := expect(cursor, input, session, start, keyword, "grad keyword expected", "grad keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            open_paren_r := expect(cursor, input, session, start, open_paren, "'(' expected after grad", "'(' expected after grad");            if open_paren_r.outcome != scan_signal::accept { return open_paren_r; }
            expr_r := expect(cursor, input, session, start, expr, "expression expected in grad", "expression expected in grad");            if expr_r.outcome != scan_signal::accept { return expr_r; }
            comma_r := expect(cursor, input, session, start, comma, "',' expected in grad", "',' expected in grad");            if comma_r.outcome != scan_signal::accept { return comma_r; }
            var_r := expect(cursor, input, session, start, var, "variable expected in grad", "variable expected in grad");            if var_r.outcome != scan_signal::accept { return var_r; }
            close_paren_r := expect(cursor, input, session, start, close_paren, "')' expected to close grad", "')' expected to close grad");            if close_paren_r.outcome != scan_signal::accept { return close_paren_r; }
            emit_trace(
                session,
                "pure2_grad_expression",
                start,
                cursor,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start),
                cursor - start
            );
        }
    );
}

project_grad_expression_feature_stream: (input: std::string_view, inout session: scan_session) -> scan_result<std::string_view> = {
    expression := pure2_grad_expression();
    return expression(input, 0, session);
}

purity_contract_candidate_at: (input: std::string_view, cursor: int) -> bool = {
    remaining: std::string_view = input.substr(cursor);
    return remaining.starts_with("[[") && (
        remaining.starts_with("[[pure") ||
        remaining.starts_with("[[contiguous") ||
        remaining.starts_with("[[non_aliasing") ||
        remaining.starts_with("[[strided")
    );
}

pure2_purity_contract: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            open_bracket := trimmed<std::string_view>(
                "purity_open_bracket",
                double_bracket_open_parser()
            );

            contract_keyword := trimmed<std::string_view>(
                "purity_contract_keyword",
                :(
                    input: std::string_view,
                    start: int,
                    inout session: scan_session
                ) -> scan_result<std::string_view> = {
                    if keyword_or_prefix_at(input, start, "pure") {
                        return accept_result<std::string_view>("pure", 4);
                    }
                    if keyword_or_prefix_at(input, start, "contiguous") {
                        return accept_result<std::string_view>("contiguous", 11);
                    }
                    if keyword_or_prefix_at(input, start, "non_aliasing") {
                        return accept_result<std::string_view>("non_aliasing", 12);
                    }
                    if keyword_or_prefix_at(input, start, "strided") {
                        return accept_result<std::string_view>("strided", 7);
                    }
                    return reject_result<std::string_view>("unknown purity contract");
                }
            );

            close_bracket := trimmed<std::string_view>(
                "purity_close_bracket",
                double_bracket_close_parser()
            );

            open_bracket_r := expect(cursor, input, session, start, open_bracket, "'[[' expected for purity contract", "'[[' expected for purity contract");            if open_bracket_r.outcome != scan_signal::accept { return open_bracket_r; }
            contract_keyword_r := expect(cursor, input, session, start, contract_keyword, "pure, contiguous, non_aliasing, or strided expected", "pure, contiguous, non_aliasing, or strided expected");            if contract_keyword_r.outcome != scan_signal::accept { return contract_keyword_r; }
            close_bracket_r := expect(cursor, input, session, start, close_bracket, "']]' expected to close purity contract", "']]' expected to close purity contract");            if close_bracket_r.outcome != scan_signal::accept { return close_bracket_r; }
            emit_trace(
                session,
                "pure2_purity_contract",
                start,
                cursor,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::keyword,
                start,
                cursor,
                "purity_contract"
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start),
                cursor - start
            );
        }
    );
}

project_purity_contract_feature_stream: (input: std::string_view, inout session: scan_session) -> scan_result<std::string_view> = {
    contract := pure2_purity_contract();
    return contract(input, 0, session);
}

