                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_manifold_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "manifold_decl_keyword",
                keyword_parser("manifold")
            );
            name := trimmed<std::string_view>(
                "manifold_decl_name",
                identifier_parser()
            );
            assignment := trimmed<std::string_view>(
                "manifold_decl_assignment",
                equals_parser("manifold_decl_equals")
            );
            initializer := pure2_atlas_literal();

            keyword_result := keyword(input, cursor, session);
            if keyword_result.outcome != scan_signal::accept {
                total := cursor - start + keyword_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_manifold_declaration",
                    start,
                    total,
                    keyword_result.outcome,
                    "manifold keyword expected"
                );
            }
            cursor = cursor + keyword_result.consumed;

            name_result := name(input, cursor, session);
            if name_result.outcome != scan_signal::accept {
                total := cursor - start + name_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_manifold_declaration",
                    start,
                    total,
                    name_result.outcome,
                    "manifold name expected"
                );
            }
            cursor = cursor + name_result.consumed;

            assignment_result := assignment(input, cursor, session);
            if assignment_result.outcome != scan_signal::accept {
                total := cursor - start + assignment_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_manifold_declaration",
                    start,
                    total,
                    assignment_result.outcome,
                    "manifold '=' expected"
                );
            }
            cursor = cursor + assignment_result.consumed;

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_manifold_declaration",
                    start,
                    total,
                    scan_signal::need_more,
                    "manifold initializer expected"
                );
            }

            if !keyword_or_prefix_at(input, cursor, "atlas") {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_manifold_declaration",
                    start,
                    total,
                    scan_signal::reject,
                    "manifold initializer expected"
                );
            }

            initializer_result := initializer(input, cursor, session);
            total := cursor - start + initializer_result.consumed;
            if initializer_result.outcome != scan_signal::accept {
                emit_trace(
                    session,
                    "pure2_manifold_declaration",
                    start,
                    clamp_stop(input, start, total),
                    initializer_result.outcome
                );
                if initializer_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        initializer_result.message
                    );
                }
                return reject_result<std::string_view>(
                    initializer_result.message,
                    total,
                );
            }

            emit_trace(
                session,
                "pure2_manifold_declaration",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_tag_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            name := trimmed<std::string_view>(
                "tag_decl_name",
                identifier_parser()
            );
            separator := trimmed<std::string_view>(
                "tag_decl_separator",
                colon_parser("tag_decl_colon")
            );
            type_name := trimmed<std::string_view>(
                "tag_decl_type",
                keyword_parser("int")
            );
            assignment := trimmed<std::string_view>(
                "tag_decl_assignment",
                equals_parser("tag_decl_equals")
            );
            initializer := trimmed<std::string_view>(
                "tag_decl_initializer",
                integer_parser()
            );
            terminator := trimmed<std::string_view>(
                "tag_decl_terminator",
                semicolon_parser("tag_decl_semicolon")
            );

            name_result := name(input, cursor, session);
            if name_result.outcome != scan_signal::accept {
                total := cursor - start + name_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_tag_declaration",
                    start,
                    total,
                    name_result.outcome,
                    "tag name expected"
                );
            }
            cursor = cursor + name_result.consumed;

            separator_result := separator(input, cursor, session);
            if separator_result.outcome != scan_signal::accept {
                total := cursor - start + separator_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_tag_declaration",
                    start,
                    total,
                    separator_result.outcome,
                    "tag ':' expected"
                );
            }
            cursor = cursor + separator_result.consumed;

            type_result := type_name(input, cursor, session);
            if type_result.outcome != scan_signal::accept {
                total := cursor - start + type_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_tag_declaration",
                    start,
                    total,
                    type_result.outcome,
                    "tag type 'int' expected"
                );
            }
            cursor = cursor + type_result.consumed;

            assignment_result := assignment(input, cursor, session);
            if assignment_result.outcome != scan_signal::accept {
                total := cursor - start + assignment_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_tag_declaration",
                    start,
                    total,
                    assignment_result.outcome,
                    "tag '=' expected"
                );
            }
            cursor = cursor + assignment_result.consumed;

            initializer_result := initializer(input, cursor, session);
            if initializer_result.outcome != scan_signal::accept {
                total := cursor - start + initializer_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_tag_declaration",
                    start,
                    total,
                    initializer_result.outcome,
                    "tag integer initializer expected"
                );
            }
            cursor = cursor + initializer_result.consumed;

            terminator_result := terminator(input, cursor, session);
            total := cursor - start + terminator_result.consumed;
            if terminator_result.outcome != scan_signal::accept {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_tag_declaration",
                    start,
                    total,
                    terminator_result.outcome,
                    "tag ';' expected"
                );
            }

            stop := start + total;
            emit_trace(
                session,
                "pure2_tag_declaration",
                start,
                stop,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::surface,
                start,
                stop,
                "bootstrap_tag_declaration"
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_top_level_surface: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            surface: parser_of<std::string_view> = ();

            if keyword_or_prefix_at(input, cursor, "chart") {
                surface = pure2_chart_definition();
            }
            else if keyword_or_prefix_at(input, cursor, "manifold") {
                surface = pure2_manifold_declaration();
            }
            else if keyword_or_prefix_at(input, cursor, "atlas") {
                surface = pure2_atlas_literal();
            }
            else if keyword_or_prefix_at(input, cursor, "coords") {
                surface = pure2_coords_literal();
            }
            else if transition_candidate_at(input, cursor) {
                surface = pure2_transition_expression();
            }
            else if join_candidate_at(input, cursor) {
                surface = pure2_join_expression();
            }
            else if tag_declaration_candidate_at(input, cursor) {
                surface = pure2_tag_declaration();
            }
            else {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_top_level_surface",
                    start,
                    0,
                    scan_signal::reject,
                    "top-level surface expected"
                );
            }

            surface_result := surface(input, cursor, session);
            total := cursor - start + surface_result.consumed;
            if surface_result.outcome != scan_signal::accept {
                emit_trace(
                    session,
                    "pure2_top_level_surface",
                    start,
                    clamp_stop(input, start, total),
                    surface_result.outcome
                );
                if surface_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        surface_result.message
                    );
                }
                return reject_result<std::string_view>(
                    surface_result.message,
                    total
                );
            }

            emit_trace(
                session,
                "pure2_top_level_surface",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_translation_unit: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            while true {
                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    emit_trace(
                        session,
                        "pure2_translation_unit",
                        start,
                        cursor,
                        scan_signal::accept
                    );
                    record_feature(
                        session,
                        feature_kind::group,
                        start,
                        cursor,
                        "translation_unit"
                    );
                    return accept_result<std::string_view>(
                        input.substr(start, cursor - start),
                        cursor - start
                    );
                }

                surface := pure2_top_level_surface();
                surface_result := surface(input, cursor, session);
                total := cursor - start + surface_result.consumed;
                if surface_result.outcome != scan_signal::accept {
                    emit_trace(
                        session,
                        "pure2_translation_unit",
                        start,
                        clamp_stop(input, start, total),
                        surface_result.outcome
                    );
                    if surface_result.outcome == scan_signal::need_more {
                        return need_more_result<std::string_view>(
                            total,
                            surface_result.message
                        );
                    }
                    return reject_result<std::string_view>(
                        surface_result.message,
                        total
                    );
                }

                cursor = cursor + surface_result.consumed;
            }
        }
    );
}

