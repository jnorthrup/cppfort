            keyword_r := expect(cursor, input, session, start, keyword, "manifold keyword expected", "manifold keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            name_r := expect(cursor, input, session, start, name, "manifold name expected", "manifold name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            assignment_r := expect(cursor, input, session, start, assignment, "manifold '=' expected", "manifold '=' expected");            if assignment_r.outcome != scan_signal::accept { return assignment_r; }
