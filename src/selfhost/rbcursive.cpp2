pure2_chart_contains_clause: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "chart_contains_keyword",
                literal("chart_contains_literal", "contains", "contains")
            );
            subject := trimmed<std::string_view>(
                "chart_contains_subject",
                identifier_parser()
            );
            relation := trimmed<std::string_view>(
                "chart_contains_relation",
                comparison_operator_parser("chart_contains_relation_token")
            );
            rhs := trimmed<std::string_view>(
                "chart_contains_rhs",
                scalar_literal_parser(
                    "chart_contains_scalar_rhs_surface",
                    "chart_contains_scalar_rhs"
                )
            );

            keyword_r := expect(cursor, input, session, start, keyword, "contains keyword expected", "contains keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            subject_r := expect(cursor, input, session, start, subject, "contains subject expected", "contains subject expected");            if subject_r.outcome != scan_signal::accept { return subject_r; }
            relation_r := expect(cursor, input, session, start, relation, "contains comparator expected", "contains comparator expected");            if relation_r.outcome != scan_signal::accept { return relation_r; }
            rhs_r := expect_map(cursor, input, session, start, rhs, "pure2_chart_contains_clause",
                :(result: scan_result<std::string_view>) -> std::string_view = {
                    if result.message == "scalar fractional digits expected" {
                        return "contains scalar fractional digits expected";
                    }
                    return "contains rhs expected";
                }
            );
            if rhs_r.outcome != scan_signal::accept { return rhs_r; }
            total := cursor - start;

            emit_trace(
                session,
                "pure2_chart_contains_clause",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

