// rbcursive.cpp2 - Pure cpp2 scanner combinator nucleus
// Keep the bootstrap surface honest: valid pure2, feature stream first,
// diagnostics side-channel explicit, retained tree deferred.

// ============================================================================
// COARSE RESULT SIGNAL
// ============================================================================

scan_signal: @enum type = {
    accept;
    need_more;
    reject;
}

// ============================================================================
// LOW-LEVEL SCAN CLASSIFICATION
// Mirrored after the TrikeShed JSON split: lexical facts first, structural facts
// separately, richer interpretation later.
// ============================================================================

delimiter_event: @enum type = {
    unchanged;
    group_open;
    group_close;
    value_delim;
}

lexer_event: @enum type = {
    unchanged;
    whitespace;
    identifier;
    digit;
    sign;
    quote;
    escape;
    utf_continuation;
}

trace_trait: @flag_enum<u8> type = {
    debug;
    backtracking;
    skipper;
}

feature_kind: @enum type = {
    group;
    identifier;
    integer;
    scalar;
    relation;
    operator_token;
    keyword;
    surface;
}

diagnostic_severity: @enum type = {
    error;
    incomplete;
}

// ============================================================================
// FEATURE + DIAGNOSTIC SIDE CHANNEL
// ============================================================================

trace_event: @struct type = {
    rule: std::string = ();
    start: int = 0;
    stop: int = 0;
    outcome: scan_signal = ();
    traits: trace_trait = ();
}

feature_record: @struct type = {
    kind: feature_kind = ();
    start: int = 0;
    stop: int = 0;
    semantic: std::string = ();
}

diagnostic_record: @struct type = {
    rule: std::string = ();
    start: int = 0;
    stop: int = 0;
    severity: diagnostic_severity = ();
    message: std::string = ();
}

scan_result: @struct <T: type> type = {
    outcome: scan_signal = ();
    value: std::optional<T> = ();
    consumed: int = 0;
    message: std::string = ();
}

scan_session: @struct type = {
    traces: std::vector<trace_event> = ();
    features: std::vector<feature_record> = ();
    diagnostics: std::vector<diagnostic_record> = ();
    active_traits: trace_trait = ();

    note_trace: (inout this, rule: std::string_view, start: int, stop: int, outcome: scan_signal) = {
        rule_text: std::string = rule;
        event: trace_event = (rule_text, start, stop, outcome, active_traits);
        traces.push_back(event);
    }

    note_feature: (
        inout this,
        kind: feature_kind,
        start: int,
        stop: int,
        semantic: std::string_view = ""
    ) = {
        semantic_text: std::string = semantic;
        feature: feature_record = (kind, start, stop, semantic_text);
        features.push_back(feature);
    }

    note_diagnostic: (
        inout this,
        rule: std::string_view,
        start: int,
        stop: int,
        severity: diagnostic_severity,
        message: std::string_view
    ) = {
        rule_text: std::string = rule;
        message_text: std::string = message;
        diagnostic: diagnostic_record = (rule_text, start, stop, severity, message_text);
        diagnostics.push_back(diagnostic);
    }
}

predicate: type == std::function<(ch: char) -> bool>;

parser_of: <T: type> type == std::function<
    (input: std::string_view, start: int, inout session: scan_session) -> scan_result<T>
>;

// ============================================================================
// COIN SORTER — rules-first grammar engine
// A rule is a slot: predicate + parser. Input falls through slots until match.
// ============================================================================

// Coin sorter dispatch: try each peek, run matched parser
// peek[i] and parse[i] are parallel arrays — first peek match wins
sort_dispatch: (
    peeks: std::vector<std::function<(input: std::string_view, cursor: int) -> bool>>,
    parses: std::vector<parser_of<std::string_view>>,
    rule_name: std::string_view
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        cursor := start;
        ws := skip_ws()(input, cursor, session);
        cursor = cursor + ws.consumed;

        i: int = 0;
        while i < peeks$.ssize() {
            if peeks$[unchecked_narrow<std::size_t>(i)](input, cursor) {
                result := parses$[unchecked_narrow<std::size_t>(i)](input, cursor, session);
                if result.outcome == scan_signal::accept {
                    total := cursor - start + result.consumed;
                    emit_trace(session, rule_name$, start, start + total, scan_signal::accept);
                    return accept_result<std::string_view>(
                        input.substr(start, total), total
                    );
                }
                total := cursor - start + result.consumed;
                return surface_failure_result<std::string_view>(
                    input, session, rule_name$, start, total,
                    result.outcome, result.message
                );
            }
            i += 1;
        }

        emit_trace(session, rule_name$, start, cursor, scan_signal::reject);
        return reject_result<std::string_view>(
            "no matching slot in " + std::string(rule_name$),
            cursor - start
        );
    };
}

emit_trace: (
    inout session: scan_session,
    rule: std::string_view,
    start: int,
    stop: int,
    outcome: scan_signal
) = {
    session.note_trace(rule, start, stop, outcome);
}

record_feature: (
    inout session: scan_session,
    kind: feature_kind,
    start: int,
    stop: int,
    semantic: std::string_view = ""
) = {
    session.note_feature(kind, start, stop, semantic);
}

record_diagnostic: (
    inout session: scan_session,
    rule: std::string_view,
    start: int,
    stop: int,
    severity: diagnostic_severity,
    message: std::string_view
) = {
    session.note_diagnostic(rule, start, stop, severity, message);
}

diagnostic_for_outcome: (
    outcome: scan_signal
) -> diagnostic_severity = {
    if outcome == scan_signal::need_more {
        return diagnostic_severity::incomplete;
    }
    return diagnostic_severity::error;
}

clamp_stop: (
    input: std::string_view,
    start: int,
    consumed: int
) -> int = {
    stop := start + consumed;
    if stop < start {
        return start;
    }
    if stop > input.ssize() {
        return input.ssize();
    }
    return stop;
}

record_surface_failure: (
    input: std::string_view,
    inout session: scan_session,
    rule: std::string_view,
    start: int,
    consumed: int,
    outcome: scan_signal,
    message: std::string_view
) = {
    if outcome == scan_signal::accept {
        return;
    }

    stop := clamp_stop(input, start, consumed);
    record_diagnostic(
        session,
        rule,
        start,
        stop,
        diagnostic_for_outcome(outcome),
        message
    );
}

surface_failure_result: <T: type>(
    input: std::string_view,
    inout session: scan_session,
    rule: std::string_view,
    start: int,
    consumed: int,
    outcome: scan_signal,
    message: std::string_view
) -> scan_result<T> = {
    record_surface_failure(
        input,
        session,
        rule,
        start,
        consumed,
        outcome,
        message
    );

    emit_trace(
        session,
        rule,
        start,
        clamp_stop(input, start, consumed),
        outcome
    );

    if outcome == scan_signal::need_more {
        return need_more_result<T>(consumed, message);
    }

    return reject_result<T>(message, consumed);
}

accept_result: <T: type>(
    value: T,
    consumed: int,
    message: std::string_view = ""
) -> scan_result<T> = {
    text: std::string = message;
    return (scan_signal::accept, value, consumed, text);
}

need_more_result: <T: type>(
    consumed: int,
    message: std::string_view = ""
) -> scan_result<T> = {
    text: std::string = message;
    empty: std::optional<T> = ();
    return (scan_signal::need_more, empty, consumed, text);
}

reject_result: <T: type>(
    message: std::string_view,
    consumed: int = 0
) -> scan_result<T> = {
    text: std::string = message;
    empty: std::optional<T> = ();
    return (scan_signal::reject, empty, consumed, text);
}

// ============================================================================
// BYTE CLASSIFIERS
// ============================================================================

is_space: (ch: char) -> bool =
    ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r';

is_digit: (ch: char) -> bool =
    ch >= '0' && ch <= '9';

is_upper: (ch: char) -> bool =
    ch >= 'A' && ch <= 'Z';

is_lower: (ch: char) -> bool =
    ch >= 'a' && ch <= 'z';

is_identifier_head: (ch: char) -> bool =
    is_upper(ch) || is_lower(ch) || ch == '_';

is_identifier_tail: (ch: char) -> bool =
    is_identifier_head(ch) || is_digit(ch);

classify_delimiter_event: (ch: char) -> delimiter_event = {
    if ch == '(' || ch == '[' || ch == '{' {
        return delimiter_event::group_open;
    }
    if ch == ')' || ch == ']' || ch == '}' {
        return delimiter_event::group_close;
    }
    if ch == ',' {
        return delimiter_event::value_delim;
    }
    return delimiter_event::unchanged;
}

classify_lexer_event: (ch: char) -> lexer_event = {
    if is_space(ch) {
        return lexer_event::whitespace;
    }
    if is_identifier_head(ch) {
        return lexer_event::identifier;
    }
    if is_digit(ch) {
        return lexer_event::digit;
    }
    if ch == '+' || ch == '-' {
        return lexer_event::sign;
    }
    if ch == '"' {
        return lexer_event::quote;
    }
    if ch == '\\' {
        return lexer_event::escape;
    }
    if ch >= '\x80' {
        return lexer_event::utf_continuation;
    }
    return lexer_event::unchanged;
}

starts_with_at: (
    input: std::string_view,
    start: int,
    token: std::string_view
) -> bool = {
    if start < 0 || start > input.ssize() {
        return false;
    }
    if start + token.ssize() > input.ssize() {
        return false;
    }
    return input.substr(start, token.ssize()) == token;
}

keyword_or_prefix_at: (
    input: std::string_view,
    start: int,
    token: std::string_view
) -> bool = {
    if start < 0 || start > input.ssize() {
        return false;
    }

    remaining := input.ssize() - start;
    if remaining >= token.ssize() {
        if !starts_with_at(input, start, token) {
            return false;
        }

        next := start + token.ssize();
        if next >= input.ssize() {
            return true;
        }
        return !is_identifier_tail(input[next]);
    }

    return token.substr(0, remaining) == input.substr(start, remaining);
}

alpha_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !keyword_or_prefix_at(input, start, "series") {
        return false;
    }

    cursor := start + 6;
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return false;
    }

    alpha_str: std::string_view = "\u03B1";
    if cursor + alpha_str.ssize() > input.ssize() {
        return false;
    }
    return input.substr(cursor, alpha_str.ssize()) == alpha_str;
}

join_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return false;
    }
    return input[cursor] == 'j';
}

indexed_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return false;
    }

    if input[cursor] != 'j' {
        return false;
    }

    cursor = cursor + 1;
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return false;
    }

    return input[cursor] == '(';
}

transition_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '.' {
        return false;
    }

    return keyword_or_prefix_at(input, cursor + 1, "transition");
}

lowered_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '.' {
        return false;
    }

    return keyword_or_prefix_at(input, cursor + 1, "lowered");
}

slice_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '[' {
        return false;
    }

    search := cursor + 1;
    while search < input.ssize() {
        if input[search] == ']' {
            return false;
        }
        if input[search] == '.' && search + 1 < input.ssize() && input[search + 1] == '.' {
            return true;
        }
        search = search + 1;
    }

    return false;
}

locate_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '.' {
        return false;
    }

    return keyword_or_prefix_at(input, cursor + 1, "locate");
}

fold_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '.' {
        return false;
    }

    cursor = cursor + 1;
    if cursor + 4 > input.ssize() {
        return false;
    }

    if input[cursor] != 'f' || input[cursor + 1] != 'o' ||
       input[cursor + 2] != 'l' || input[cursor + 3] != 'd' {
        return false;
    }

    cursor = cursor + 4;
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return true;
    }

    return input[cursor] == '(';
}

project_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '.' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 'p' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 'r' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 'o' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 'j' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 'e' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 'c' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != 't' {
        return false;
    }

    cursor = cursor + 1;
    if cursor >= input.ssize() || input[cursor] != '(' {
        return false;
    }

    return true;
}

elementwise_mul_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) && !is_digit(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && (is_identifier_tail(input[cursor]) || is_digit(input[cursor])) {
        cursor = cursor + 1;
    }

    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor + 1 >= input.ssize() {
        return false;
    }
    return input[cursor] == '*' && input[cursor + 1] == '*';
}

elementwise_add_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) && !is_digit(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && (is_identifier_tail(input[cursor]) || is_digit(input[cursor])) {
        cursor = cursor + 1;
    }

    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor + 1 >= input.ssize() {
        return false;
    }
    return input[cursor] == '+' && input[cursor + 1] == '+';
}

indexed_view_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }

    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor + 1 >= input.ssize() {
        return false;
    }
    return input[cursor] == '*' && input[cursor + 1] == '[';
}

dense_view_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if input[start] != 'd' {
        return false;
    }

    cursor := start + 1;
    if cursor + 4 >= input.ssize() {
        return false;
    }

    if input[cursor] != 'e' || input[cursor + 1] != 'n' || 
       input[cursor + 2] != 's' || input[cursor + 3] != 'e' {
        return false;
    }

    cursor = cursor + 4;
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != '(' {
        return false;
    }

    return true;
}

tag_declaration_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return true;
    }
    return input[cursor] == ':';
}

namespace_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != ':' {
        return false;
    }
    cursor = cursor + 1;

    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    return keyword_or_prefix_at(input, cursor, "namespace");
}

struct_annotation_candidate_at: (
    input: std::string_view,
    start: int
) -> bool = {
    if start < 0 || start >= input.ssize() {
        return false;
    }
    if !is_identifier_head(input[start]) {
        return false;
    }

    cursor := start + 1;
    while cursor < input.ssize() && is_identifier_tail(input[cursor]) {
        cursor = cursor + 1;
    }
    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() || input[cursor] != ':' {
        return false;
    }
    cursor = cursor + 1;

    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    if cursor >= input.ssize() {
        return false;
    }
    if input[cursor] != '@' {
        return false;
    }
    cursor = cursor + 1;

    if !keyword_or_prefix_at(input, cursor, "struct") &&
       !keyword_or_prefix_at(input, cursor, "value") &&
       !keyword_or_prefix_at(input, cursor, "basic_value") &&
       !keyword_or_prefix_at(input, cursor, "interface") &&
       !keyword_or_prefix_at(input, cursor, "enum") &&
       !keyword_or_prefix_at(input, cursor, "flag_enum") &&
       !keyword_or_prefix_at(input, cursor, "union") &&
       !keyword_or_prefix_at(input, cursor, "regex") &&
       !keyword_or_prefix_at(input, cursor, "autodiff") &&
       !keyword_or_prefix_at(input, cursor, "cpp1_rule_of_zero") {
        return false;
    }
    if keyword_or_prefix_at(input, cursor, "struct") {
        cursor = cursor + 6;
    }
    else if keyword_or_prefix_at(input, cursor, "interface") {
        cursor = cursor + 9;
    }
    else if keyword_or_prefix_at(input, cursor, "enum") {
        cursor = cursor + 4;
    }
    else if keyword_or_prefix_at(input, cursor, "flag_enum") {
        cursor = cursor + 9;
    }
    else if keyword_or_prefix_at(input, cursor, "union") {
        cursor = cursor + 5;
    }
    else if keyword_or_prefix_at(input, cursor, "regex") {
        cursor = cursor + 5;
    }
    else if keyword_or_prefix_at(input, cursor, "autodiff") {
        cursor = cursor + 8;
    }
    else if keyword_or_prefix_at(input, cursor, "cpp1_rule_of_zero") {
        cursor = cursor + 17;
    }
    else if keyword_or_prefix_at(input, cursor, "basic_value") {
        cursor = cursor + 11;
    }
    else {
        cursor = cursor + 5;
    }

    while cursor < input.ssize() && is_space(input[cursor]) {
        cursor = cursor + 1;
    }

    while cursor < input.ssize() && input[cursor] == '@' {
        cursor = cursor + 1;

        if !keyword_or_prefix_at(input, cursor, "print") {
            return false;
        }
        cursor = cursor + 5;

        while cursor < input.ssize() && is_space(input[cursor]) {
            cursor = cursor + 1;
        }
    }

    if cursor >= input.ssize() {
        return true;
    }

    if input[cursor] == '<' {
        return true;
    }

    return keyword_or_prefix_at(input, cursor, "type");
}

// ============================================================================
// PRIMITIVE PARSERS
// ============================================================================

skip_ws: () -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        cursor := start;
        while true {
            while cursor < input.ssize() && is_space(input[cursor]) {
                cursor = cursor + 1;
            }

            if cursor + 1 < input.ssize() &&
               input[cursor] == '/' &&
               input[cursor + 1] == '/' {
                cursor = cursor + 2;
                while cursor < input.ssize() &&
                      input[cursor] != '\n' &&
                      input[cursor] != '\r' {
                    cursor = cursor + 1;
                }
                continue;
            }

            break;
        }

        emit_trace(session, "skip_ws", start, cursor, scan_signal::accept);
        return accept_result<std::string_view>(
            input.substr(start, cursor - start),
            cursor - start
        );
    };
}

take_while_1: (
    rule: std::string_view,
    pred: predicate
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start >= input.ssize() {
            emit_trace(session, rule$, start, start, scan_signal::need_more);
            return need_more_result<std::string_view>(0, "input exhausted");
        }

        cursor := start;
        while cursor < input.ssize() && pred$(input[cursor]) {
            cursor = cursor + 1;
        }

        if cursor == start {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("predicate rejected at head");
        }

        emit_trace(session, rule$, start, cursor, scan_signal::accept);
        return accept_result<std::string_view>(
            input.substr(start, cursor - start),
            cursor - start
        );
    };
}

literal: (
    rule: std::string_view,
    token: std::string_view,
    semantic: std::string_view = ""
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start + token$.ssize() > input.ssize() {
            emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
            return need_more_result<std::string_view>(0, "literal needs more input");
        }

        if !starts_with_at(input, start, token$) {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("literal mismatch");
        }

        stop := start + token$.ssize();
        label: std::string_view = semantic$;
        if label.empty() {
            label = token$;
        }

        emit_trace(session, rule$, start, stop, scan_signal::accept);
        record_feature(session, feature_kind::keyword, start, stop, label);
        return accept_result<std::string_view>(
            input.substr(start, token$.ssize()),
            token$.ssize()
        );
    };
}

arrow_parser: (
    rule: std::string_view = "arrow"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start + 2 > input.ssize() {
            emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
            return need_more_result<std::string_view>(0, "arrow token expected");
        }

        if !starts_with_at(input, start, "->") {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("arrow token expected");
        }

        stop := start + 2;
        emit_trace(session, rule$, start, stop, scan_signal::accept);
        return accept_result<std::string_view>(
            input.substr(start, 2),
            2
        );
    };
}

fat_arrow_parser: (
    rule: std::string_view = "fat_arrow"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start + 2 > input.ssize() {
            emit_trace(session, rule$, start, input.ssize(), scan_signal::need_more);
            return need_more_result<std::string_view>(0, "fat arrow token expected");
        }

        if !starts_with_at(input, start, "=>") {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("fat arrow token expected");
        }

        stop := start + 2;
        emit_trace(session, rule$, start, stop, scan_signal::accept);
        record_feature(session, feature_kind::keyword, start, stop, "=>");
        return accept_result<std::string_view>(
            input.substr(start, 2),
            2
        );
    };
}

equals_parser: (
    rule: std::string_view = "equals"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start >= input.ssize() {
            emit_trace(session, rule$, start, start, scan_signal::need_more);
            return need_more_result<std::string_view>(0, "assignment token expected");
        }

        if input[start] != '=' {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("assignment token expected");
        }

        stop := start + 1;
        emit_trace(session, rule$, start, stop, scan_signal::accept);
        return accept_result<std::string_view>(
            input.substr(start, 1),
            1
        );
    };
}

double_equals_parser: (
    rule: std::string_view = "double_equals"
) -> parser_of<std::string_view> = {
    return :(
        input: std::string_view,
        start: int,
        inout session: scan_session
    ) -> scan_result<std::string_view> = {
        if start + 1 >= input.ssize() {
            emit_trace(session, rule$, start, start, scan_signal::need_more);
            return need_more_result<std::string_view>(0, "synonym token '==' expected");
        }

        if input[start] != '=' || input[start + 1] != '=' {
            emit_trace(session, rule$, start, start, scan_signal::reject);
            return reject_result<std::string_view>("synonym token '==' expected");
        }

        stop := start + 2;
        emit_trace(session, rule$, start, stop, scan_signal::accept);
        return accept_result<std::string_view>(
            input.substr(start, 2),
            2
        );
    };
}

