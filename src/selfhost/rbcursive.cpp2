                input.substr(start, total),
                total
            );
        }
    );
}

slice_bound_surface: (
    rule: std::string_view,
    semantic: std::string_view
) -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            round_depth := 0;
            square_depth := 0;
            brace_depth := 0;
            stop := start;
            saw_payload := false;

            while cursor < input.ssize() {
                ch := input[cursor];

                if cursor + 1 < input.ssize() && ch == '.' && input[cursor + 1] == '.' {
                    break;
                }

                if ch == ']' && square_depth == 0 {
                    break;
                }

                if (ch == '\n' || ch == '\r') &&
                   round_depth == 0 &&
                   square_depth == 0 &&
                   brace_depth == 0 {
                    break;
                }

                if ch == '}' &&
                   round_depth == 0 &&
                   square_depth == 0 &&
                   brace_depth == 0 {
                    break;
                }

                if !is_space(ch) {
                    saw_payload = true;
                    stop = cursor + 1;
                }

                if ch == '(' {
                    round_depth = round_depth + 1;
                }
                else if ch == ')' {
                    if round_depth == 0 {
                        break;
                    }
                    round_depth = round_depth - 1;
                }
                else if ch == '[' {
                    square_depth = square_depth + 1;
                }
                else if ch == ']' {
                    if square_depth == 0 {
                        break;
                    }
                    square_depth = square_depth - 1;
                }
                else if ch == '{' {
                    brace_depth = brace_depth + 1;
                }
                else if ch == '}' {
                    if brace_depth == 0 {
                        break;
                    }
                    brace_depth = brace_depth - 1;
                }

                cursor = cursor + 1;
            }

            consumed := cursor - start;
            if round_depth != 0 || square_depth != 0 || brace_depth != 0 {
                emit_trace(session, rule$, start, cursor, scan_signal::need_more);
                return need_more_result<std::string_view>(
                    consumed,
                    "slice bound group incomplete"
                );
            }

            if !saw_payload {
                outcome := scan_signal::reject;
                if cursor >= input.ssize() {
                    outcome = scan_signal::need_more;
                }

                emit_trace(session, rule$, start, cursor, outcome);
                if outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        consumed,
                        "slice bound expression expected"
                    );
                }

                return reject_result<std::string_view>(
                    "slice bound expression expected",
                    consumed
                );
            }

            emit_trace(session, rule$, start, cursor, scan_signal::accept);
            return accept_result<std::string_view>(
                input.substr(start, consumed),
                consumed
            );
        }
    );
}

pure2_slice_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            receiver := trimmed<std::string_view>(
                "slice_receiver",
                identifier_parser()
            );

            receiver_r := expect(cursor, input, session, start, receiver, "slice receiver expected", "slice receiver expected");            if receiver_r.outcome != scan_signal::accept { return receiver_r; }
            if cursor >= input.ssize() || input[cursor] != '[' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_slice_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "slice '[' expected"
                );
            }
            cursor = cursor + 1;
            std::cerr << "DEBUG: after '[' cursor=" << cursor << " remaining='" << input.substr(cursor) << "'\n";
            std::cerr.flush();

            low := slice_bound_surface(
                "slice_low_surface",
                "slice_low_expression"
            );

            low_r := expect(cursor, input, session, start, low, "pure2_slice_expression", "slice low expression expected");
            if low_r.outcome != scan_signal::accept { return low_r; }

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor + 1 >= input.ssize() || input[cursor] != '.' || input[cursor + 1] != '.' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_slice_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "slice range operator '..' expected"
                );
            }
            cursor = cursor + 2;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            high := line_expression_surface(
                "slice_high_surface",
                "slice_high_expression"
            );

            high_r := expect(cursor, input, session, start, high, "pure2_slice_expression", "slice high expression expected");
            if high_r.outcome != scan_signal::accept { return high_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() || input[cursor] != ']' {
                total := cursor - start;
                message: std::string_view = "slice ']' expected";
                if cursor >= input.ssize() {
                    message = "slice ']' expected";
                }
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_slice_expression",
                    start,
                    total,
                    scan_signal::reject,
                    message
                );
            }
            cursor = cursor + 1;

            total := cursor - start;

            emit_trace(
                session,
                "pure2_slice_expression",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_elementwise_mul_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
