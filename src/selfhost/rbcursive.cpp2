            emit_trace(
                session,
                "pure2_manifold_declaration",
                start,
                start + cursor - start + initializer_r.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start + initializer_r.consumed),
                cursor - start + initializer_r.consumed
            );
        }
    );
}

pure2_tag_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            name := trimmed<std::string_view>(
                "tag_decl_name",
                identifier_parser()
            );
            separator := trimmed<std::string_view>(
                "tag_decl_separator",
                colon_parser("tag_decl_colon")
            );
            type_name := trimmed<std::string_view>(
                "tag_decl_type",
                keyword_parser("int")
            );
            assignment := trimmed<std::string_view>(
                "tag_decl_assignment",
                equals_parser("tag_decl_equals")
            );
            initializer := trimmed<std::string_view>(
                "tag_decl_initializer",
                integer_parser()
            );
            terminator := trimmed<std::string_view>(
                "tag_decl_terminator",
                semicolon_parser("tag_decl_semicolon")
            );

            name_r := expect(cursor, input, session, start, name, "tag name expected", "tag name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            separator_r := expect(cursor, input, session, start, separator, "tag ':' expected", "tag ':' expected");            if separator_r.outcome != scan_signal::accept { return separator_r; }
            type_name_r := expect(cursor, input, session, start, type_name, "tag type 'int' expected", "tag type 'int' expected");            if type_name_r.outcome != scan_signal::accept { return type_name_r; }
            assignment_r := expect(cursor, input, session, start, assignment, "tag '=' expected", "tag '=' expected");            if assignment_r.outcome != scan_signal::accept { return assignment_r; }
            initializer_r := expect(cursor, input, session, start, initializer, "tag integer initializer expected", "tag integer initializer expected");            if initializer_r.outcome != scan_signal::accept { return initializer_r; }
            terminator_r := finish_surface(input, session, start, cursor, terminator, "pure2_tag_declaration", "tag ';' expected");
            if terminator_r.outcome != scan_signal::accept { return terminator_r; }
            total := cursor - start + terminator_r.consumed;

            stop := start + total;
            std::cerr << "DEBUG: pure2_tag_declaration recorded, features.size=" << session.features.size() << "\n";
            std::cerr.flush();
            emit_trace(
                session,
                "pure2_tag_declaration",
                start,
                stop,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::surface,
                start,
                stop,
                "bootstrap_tag_declaration"
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_struct_type_parameters: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() || input[start] != '<' {
                return reject_result<std::string_view>("type parameters expected");
            }

            open := trimmed<std::string_view>(
                "type_params_open",
                literal("type_params_open", "<", "<")
            );
            close := trimmed<std::string_view>(
                "type_params_close",
                literal("type_params_close", ">", ">")
            );
            type_keyword := trimmed<std::string_view>(
                "type_param_keyword",
                keyword_parser("type")
            );
            colon_parser_instance := trimmed<std::string_view>(
                "type_param_colon",
                colon_parser("type_param_colon")
            );

            open_result := open(input, start, session);
            if open_result.outcome != scan_signal::accept {
                return open_result;
            }
            cursor := start + open_result.consumed;

            while true {
                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input,
                        session,
                        "pure2_struct_type_parameters",
                        start,
                        total,
                        scan_signal::need_more,
                        "type parameter list incomplete"
                    );
                }

                if input[cursor] == '>' {
                    stop := cursor + 1;
                    emit_trace(session, "pure2_struct_type_parameters", start, stop, scan_signal::accept);
                    record_feature(session, feature_kind::group, start, stop, "struct_type_parameters");
                    return accept_result<std::string_view>(input.substr(start, stop - start), stop - start);
                }

                param_name := trimmed<std::string_view>(
                    "type_param_name",
                    identifier_parser()
                );
                param_name_r := expect(cursor, input, session, start, param_name, "type parameter name expected", "type parameter name expected");                if param_name_r.outcome != scan_signal::accept { return param_name_r; }
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                colon_parser_instance_r := expect(cursor, input, session, start, colon_parser_instance, "type parameter ':' expected", "type parameter ':' expected");                if colon_parser_instance_r.outcome != scan_signal::accept { return colon_parser_instance_r; }
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                type_keyword_r := expect(cursor, input, session, start, type_keyword, "type parameter 'type' expected", "type parameter 'type' expected");                if type_keyword_r.outcome != scan_signal::accept { return type_keyword_r; }
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    total := cursor - start;
                    return surface_failure_result<std::string_view>(
                        input, session, "pure2_struct_type_parameters", start, total,
                        scan_signal::need_more, "type parameter list incomplete"
                    );
                }

                if input[cursor] == ',' {
                    cursor = cursor + 1;
                }
            }
        }
    );
}

pure2_struct_body: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            if start >= input.ssize() || input[start] != '{' {
                return reject_result<std::string_view>("struct body expected");
            }

            cursor := start + 1;
            depth := 1;

            while cursor < input.ssize() && depth > 0 {
                ch := input[cursor];
                if ch == '{' {
                    depth = depth + 1;
                }
                else if ch == '}' {
                    depth = depth - 1;
                }
                else if ch == '"' {
                    cursor = cursor + 1;
                    while cursor < input.ssize() && input[cursor] != '"' {
                        if input[cursor] == '\\' {
                            cursor = cursor + 1;
                        }
                        cursor = cursor + 1;
                    }
                }
                cursor = cursor + 1;
            }

            if depth != 0 {
                return need_more_result<std::string_view>(cursor - start, "struct body incomplete");
            }

            stop := cursor;
            emit_trace(session, "pure2_struct_body", start, stop, scan_signal::accept);
            record_feature(session, feature_kind::group, start, stop, "struct_body");
            return accept_result<std::string_view>(input.substr(start, stop - start), stop - start);
        }
    );
}

pure2_struct_field: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() || input[cursor] == '}' {
                return reject_result<std::string_view>("struct field expected");
            }

            name := trimmed<std::string_view>("struct_field_name", identifier_parser());
            name_r := expect(cursor, input, session, start, name, "struct field name expected", "struct field name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            colon := trimmed<std::string_view>("struct_field_colon", colon_parser("struct_field_colon"));
            colon_r := expect(cursor, input, session, start, colon, "struct field ':' expected", "struct field ':' expected");            if colon_r.outcome != scan_signal::accept { return colon_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input, session, "pure2_struct_field", start, total,
                    scan_signal::need_more, "struct field type expected"
                );
            }

            type_expr := line_expression_surface("struct_field_type_surface", "struct_field_type");
            type_expr_r := expect(cursor, input, session, start, type_expr, "pure2_struct_field", "struct field type expected");
            if type_expr_r.outcome != scan_signal::accept { return type_expr_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            assign := trimmed<std::string_view>("struct_field_assign", equals_parser("struct_field_equals"));
            assign_r := expect(cursor, input, session, start, assign, "struct field '=' expected", "struct field '=' expected");            if assign_r.outcome != scan_signal::accept { return assign_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            init_expr := line_expression_surface("struct_field_init_surface", "struct_field_init");
            init_expr_r := expect(cursor, input, session, start, init_expr, "pure2_struct_field", "struct field initializer expected");
            if init_expr_r.outcome != scan_signal::accept { return init_expr_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            semi := trimmed<std::string_view>("struct_field_semi", semicolon_parser("struct_field_semicolon"));
            semi_r := finish_surface(input, session, start, cursor, semi, "pure2_struct_field", "struct field ';' expected");
            if semi_r.outcome != scan_signal::accept { return semi_r; }
            total := cursor - start + semi_r.consumed;

            stop := start + total;
            emit_trace(session, "pure2_struct_field", start, stop, scan_signal::accept);
            record_feature(session, feature_kind::surface, start, stop, "struct_field");
            return accept_result<std::string_view>(input.substr(start, total), total);
        }
    );
}

pure2_struct_declaration: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;

            name := trimmed<std::string_view>("struct_decl_name", identifier_parser());
            name_r := expect(cursor, input, session, start, name, "struct name expected", "struct name expected");            if name_r.outcome != scan_signal::accept { return name_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            colon := trimmed<std::string_view>("struct_decl_colon", colon_parser("struct_decl_colon"));
            colon_r := expect(cursor, input, session, start, colon, "struct ':' expected", "struct ':' expected");            if colon_r.outcome != scan_signal::accept { return colon_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() || input[cursor] != '@' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input, session, "pure2_struct_declaration", start, total,
                    scan_signal::reject, "struct '@struct' expected"
                );
            }
            cursor = cursor + 1;

            annotation_keyword := choice<std::string_view>(
                "struct_decl_annotation_choice",
                trimmed<std::string_view>("struct_decl_annotation_struct", keyword_parser("struct")),
                choice<std::string_view>(
                    "struct_decl_annotation_choice_tail1",
                    trimmed<std::string_view>("struct_decl_annotation_value", keyword_parser("value")),
                    choice<std::string_view>(
                        "struct_decl_annotation_choice_tail2",
                        trimmed<std::string_view>("struct_decl_annotation_basic_value", keyword_parser("basic_value")),
                        choice<std::string_view>(
                            "struct_decl_annotation_choice_tail3",
                            trimmed<std::string_view>("struct_decl_annotation_interface", keyword_parser("interface")),
                            choice<std::string_view>(
                                "struct_decl_annotation_choice_tail4",
                                trimmed<std::string_view>("struct_decl_annotation_enum", keyword_parser("enum")),
                                choice<std::string_view>(
                                    "struct_decl_annotation_choice_tail5",
                                    trimmed<std::string_view>("struct_decl_annotation_flag_enum", keyword_parser("flag_enum")),
                                    choice<std::string_view>(
                                        "struct_decl_annotation_choice_tail6",
                                        trimmed<std::string_view>("struct_decl_annotation_union", keyword_parser("union")),
                                        choice<std::string_view>(
                                            "struct_decl_annotation_choice_tail7",
                                            trimmed<std::string_view>("struct_decl_annotation_regex", keyword_parser("regex")),
                                            choice<std::string_view>(
                                                "struct_decl_annotation_choice_tail8",
                                                trimmed<std::string_view>("struct_decl_annotation_autodiff", keyword_parser("autodiff")),
                                                trimmed<std::string_view>("struct_decl_annotation_cpp1_rule_of_zero", keyword_parser("cpp1_rule_of_zero"))
                                            )
                                        )
                                    )
                                )
                            )
                        )
                    )
                )
            );
            annotation_r := expect(cursor, input, session, start, annotation_keyword, "pure2_struct_declaration", "struct '@struct', '@value', '@basic_value', '@interface', '@enum', '@flag_enum', '@union', '@regex', '@autodiff', or '@cpp1_rule_of_zero' expected");
            if annotation_r.outcome != scan_signal::accept { return annotation_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            while cursor < input.ssize() && input[cursor] == '@' {
                cursor = cursor + 1;

                helper_keyword := trimmed<std::string_view>("struct_decl_helper_print", keyword_parser("print"));
                helper_keyword_r := expect(cursor, input, session, start, helper_keyword, "struct helper annotation expected", "struct helper annotation expected");                if helper_keyword_r.outcome != scan_signal::accept { return helper_keyword_r; }
                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;
            }

            type_params_consumed := 0;
            if cursor < input.ssize() && input[cursor] == '<' {
                type_params := pure2_type_parameters();
                type_params_r := expect(cursor, input, session, start, type_params, "pure2_struct_declaration", "parse error");                if type_params_r.outcome != scan_signal::accept { return type_params_r; }                cursor = cursor + type_params_consumed;

                ws_result = skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;
            }

            type_keyword := trimmed<std::string_view>("struct_decl_type", keyword_parser("type"));
            type_keyword_r := expect(cursor, input, session, start, type_keyword, "struct 'type' keyword expected", "struct 'type' keyword expected");            if type_keyword_r.outcome != scan_signal::accept { return type_keyword_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            assign := trimmed<std::string_view>("struct_decl_assign", equals_parser("struct_decl_equals"));
            assign_r := expect(cursor, input, session, start, assign, "struct '=' expected", "struct '=' expected");            if assign_r.outcome != scan_signal::accept { return assign_r; }
            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() || input[cursor] != '{' {
                total := cursor - start;
                message: std::string_view = "struct body expected";
                if cursor >= input.ssize() {
                    return surface_failure_result<std::string_view>(
                        input, session, "pure2_struct_declaration", start, total,
                        scan_signal::need_more, message
                    );
                }
                return surface_failure_result<std::string_view>(
                    input, session, "pure2_struct_declaration", start, total,
                    scan_signal::reject, message
                );
            }

            body_start := cursor;
            body := pure2_struct_body();
            body_r := expect(cursor, input, session, start, body, "pure2_struct_declaration", "pure2_struct_declaration");
            if body_r.outcome != scan_signal::accept { return body_r; }

            stop := cursor;
            emit_trace(session, "pure2_struct_declaration", start, stop, scan_signal::accept);
            record_feature(session, feature_kind::surface, start, stop, "struct_declaration");
            return accept_result<std::string_view>(input.substr(start, stop - start), stop - start);
        }
    );
}

pure2_top_level_surface: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            surface: parser_of<std::string_view> = ();

            if keyword_or_prefix_at(input, cursor, "chart") {
                surface = pure2_chart_definition();
            }
            else if keyword_or_prefix_at(input, cursor, "manifold") {
                surface = pure2_manifold_declaration();
            }
            else if keyword_or_prefix_at(input, cursor, "atlas") {
                surface = pure2_atlas_literal();
            }
            else if keyword_or_prefix_at(input, cursor, "coords") {
                surface = pure2_coords_literal();
            }
            else if series_literal_candidate_at(input, cursor) {
                surface = pure2_series_literal();
            }
            else if cursor_type_candidate_at(input, cursor) {
                surface = pure2_cursor_type();
            }
            else if alpha_candidate_at(input, cursor) {
                surface = pure2_alpha_expression();
            }
            else if transition_candidate_at(input, cursor) {
                surface = pure2_transition_expression();
            }
            else if lowered_candidate_at(input, cursor) {
                surface = pure2_lowered_method_call();
            }
            else if locate_candidate_at(input, cursor) {
                surface = pure2_atlas_locate_expression();
            }
            else if fold_candidate_at(input, cursor) {
                surface = pure2_fold_expression();
            }
            else if project_candidate_at(input, cursor) {
                surface = pure2_chart_project_expression();
            }
            else if join_candidate_at(input, cursor) {
                surface = pure2_join_expression();
            }
            else if indexed_candidate_at(input, cursor) {
                surface = pure2_indexed_expression();
            }
            else if slice_candidate_at(input, cursor) {
                surface = pure2_slice_expression();
            }
            else if elementwise_mul_candidate_at(input, cursor) {
                surface = pure2_elementwise_mul_expression();
            }
            else if elementwise_add_candidate_at(input, cursor) {
                surface = pure2_elementwise_add_expression();
            }
            else if indexed_view_candidate_at(input, cursor) {
                surface = pure2_indexed_view_expression();
            }
            else if dense_view_candidate_at(input, cursor) {
                surface = pure2_dense_view_expression();
            }
            else if grad_candidate_at(input, cursor) {
                surface = pure2_grad_expression();
            }
            else if purity_contract_candidate_at(input, cursor) {
                surface = pure2_purity_contract();
            }
            else if struct_annotation_candidate_at(input, cursor) {
                surface = pure2_struct_declaration();
            }
            else if namespace_candidate_at(input, cursor) {
                surface = pure2_namespace_declaration();
            }
            else if tag_declaration_candidate_at(input, cursor) {
                surface = pure2_tag_declaration();
            }
            else if function_declaration_candidate_at(input, cursor) {
                surface = pure2_function_declaration();
            }
            else if keyword_or_prefix_at(input, cursor, "type") {
                surface = pure2_type_declaration();
            }
            else if contract_precondition_candidate_at(input, cursor) {
                surface = pure2_precondition();
            }
            else if contract_postcondition_candidate_at(input, cursor) {
                surface = pure2_postcondition();
            }
            else if keyword_or_prefix_at(input, cursor, "inspect") {
                surface = pure2_inspect_expression();
            }
            else if keyword_or_prefix_at(input, cursor, "$") {
                surface = pure2_string_interpolation();
            }
            else {
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_top_level_surface",
                    start,
                    0,
                    scan_signal::reject,
                    "top-level surface expected"
                );
            }

            surface_r := finish_trace(input, session, start, cursor, surface, "pure2_top_level_surface");
            if surface_r.outcome != scan_signal::accept { return surface_r; }

            emit_trace(
                session,
                "pure2_top_level_surface",
                start,
                start + cursor - start + surface_r.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start + surface_r.consumed),
                cursor - start + surface_r.consumed
            );
        }
    );
}

pure2_translation_unit: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            while true {
                ws_result := skip_ws()(input, cursor, session);
                cursor = cursor + ws_result.consumed;

                if cursor >= input.ssize() {
                    emit_trace(
                        session,
                        "pure2_translation_unit",
                        start,
                        cursor,
                        scan_signal::accept
                    );
                    record_feature(
                        session,
                        feature_kind::group,
                        start,
                        cursor,
                        "translation_unit"
                    );
                    return accept_result<std::string_view>(
                        input.substr(start, cursor - start),
                        cursor - start
                    );
                }

                surface := pure2_top_level_surface();
                surface_r := expect_trace(cursor, input, session, start, surface, "pure2_translation_unit");
                if surface_r.outcome != scan_signal::accept { return surface_r; }
            }
        }
    );
}

