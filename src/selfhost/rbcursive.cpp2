    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "manifold_decl_keyword",
                keyword_parser("manifold")
            );
            name := trimmed<std::string_view>(
                "manifold_decl_name",
                identifier_parser()
            );
            assignment := trimmed<std::string_view>(
                "manifold_decl_assignment",
                equals_parser("manifold_decl_equals")
            );
