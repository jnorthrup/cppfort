pure2_join_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            lhs := trimmed<std::string_view>(
                "join_expression_lhs",
                identifier_parser()
            );
            join := trimmed<std::string_view>(
                "join_expression_operator",
                join_operator_parser("join_expression_operator_token")
            );
            rhs := trimmed<std::string_view>(
                "join_expression_rhs",
                identifier_parser()
            );

            lhs_result := lhs(input, cursor, session);
            if lhs_result.outcome != scan_signal::accept {
                total := cursor - start + lhs_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_join_expression",
                    start,
                    total,
                    lhs_result.outcome,
                    "join lhs expected"
                );
            }
            cursor = cursor + lhs_result.consumed;

            join_result := join(input, cursor, session);
            if join_result.outcome != scan_signal::accept {
                total := cursor - start + join_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_join_expression",
                    start,
                    total,
                    join_result.outcome,
                    "join operator expected"
                );
            }
            cursor = cursor + join_result.consumed;

            rhs_result := rhs(input, cursor, session);
            if rhs_result.outcome != scan_signal::accept {
                total := cursor - start + rhs_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_join_expression",
                    start,
                    total,
                    rhs_result.outcome,
                    "join rhs expected"
                );
            }
            cursor = cursor + rhs_result.consumed;

            while cursor < input.ssize() &&
                  (input[cursor] == ' ' || input[cursor] == '\t') {
                cursor = cursor + 1;
            }

            if cursor < input.ssize() &&
               input[cursor] != '\n' &&
               input[cursor] != '\r' &&
               input[cursor] != '}' &&
               input[cursor] != ')' &&
               input[cursor] != ']' &&
               input[cursor] != ',' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_join_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "join tail unexpected"
                );
            }

            total := cursor - start;
            emit_trace(
                session,
                "pure2_join_expression",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

pure2_transition_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            receiver := trimmed<std::string_view>(
                "transition_receiver",
                identifier_parser()
            );
            keyword := trimmed<std::string_view>(
                "transition_keyword",
                keyword_parser("transition")
            );
            source_name := trimmed<std::string_view>(
                "transition_source_name",
                string_literal_parser("transition_source_string")
            );
            target_name := trimmed<std::string_view>(
                "transition_target_name",
                string_literal_parser("transition_target_string")
            );
            coordinates := trimmed<std::string_view>(
                "transition_coordinates",
                pure2_coords_literal()
            );

            receiver_result := receiver(input, cursor, session);
            if receiver_result.outcome != scan_signal::accept {
                total := cursor - start + receiver_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    receiver_result.outcome,
                    "transition receiver expected"
                );
            }
            cursor = cursor + receiver_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition member access expected"
                );
            }
            if input[cursor] != '.' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition member access expected"
                );
            }
            cursor = cursor + 1;

            keyword_result := keyword(input, cursor, session);
            if keyword_result.outcome != scan_signal::accept {
                total := cursor - start + keyword_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    keyword_result.outcome,
                    "transition keyword expected"
                );
            }
            cursor = cursor + keyword_result.consumed;

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument list incomplete"
                );
            }
            if input[cursor] != '(' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument list expected"
                );
            }

            group_start := cursor;
            cursor = cursor + 1;

            source_result := source_name(input, cursor, session);
            if source_result.outcome != scan_signal::accept {
                total := cursor - start + source_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    source_result.outcome,
                    "transition source expected"
                );
            }
            cursor = cursor + source_result.consumed;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument separator expected"
                );
            }
            if input[cursor] != ',' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument separator expected"
                );
            }
            cursor = cursor + 1;

            target_result := target_name(input, cursor, session);
            if target_result.outcome != scan_signal::accept {
                total := cursor - start + target_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    target_result.outcome,
                    "transition target expected"
                );
            }
            cursor = cursor + target_result.consumed;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument separator expected"
                );
            }
            if input[cursor] != ',' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument separator expected"
                );
            }
            cursor = cursor + 1;

            coordinate_result := coordinates(input, cursor, session);
            total := cursor - start + coordinate_result.consumed;
            if coordinate_result.outcome != scan_signal::accept {
                emit_trace(
                    session,
                    "pure2_transition_expression",
                    start,
                    clamp_stop(input, start, total),
                    coordinate_result.outcome
                );
                if coordinate_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(
                        total,
                        coordinate_result.message
                    );
                }
                return reject_result<std::string_view>(
                    coordinate_result.message,
                    total
                );
            }
            cursor = cursor + coordinate_result.consumed;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;
            if cursor >= input.ssize() {
                total = cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "transition argument list incomplete"
                );
            }
            if input[cursor] != ')' {
                total = cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_transition_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "transition argument list incomplete"
                );
            }
            cursor = cursor + 1;

            emit_trace(
                session,
                "pure2_transition_expression",
                start,
                cursor,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::group,
                group_start,
                cursor,
                "transition_arguments"
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start),
                cursor - start
            );
        }
    );
}

pure2_chart_contains_clause: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            keyword := trimmed<std::string_view>(
                "chart_contains_keyword",
                literal("chart_contains_literal", "contains", "contains")
            );
            subject := trimmed<std::string_view>(
                "chart_contains_subject",
                identifier_parser()
            );
            relation := trimmed<std::string_view>(
                "chart_contains_relation",
                comparison_operator_parser("chart_contains_relation_token")
            );
            rhs := trimmed<std::string_view>(
                "chart_contains_rhs",
                scalar_literal_parser(
                    "chart_contains_scalar_rhs_surface",
                    "chart_contains_scalar_rhs"
                )
            );

            keyword_result := keyword(input, cursor, session);
            if keyword_result.outcome != scan_signal::accept {
                total := cursor - start + keyword_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_contains_clause",
                    start,
                    total,
                    keyword_result.outcome,
                    "contains keyword expected"
                );
            }
            cursor = cursor + keyword_result.consumed;

            subject_result := subject(input, cursor, session);
            if subject_result.outcome != scan_signal::accept {
                total := cursor - start + subject_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_contains_clause",
                    start,
                    total,
                    subject_result.outcome,
                    "contains subject expected"
                );
            }
            cursor = cursor + subject_result.consumed;

            relation_result := relation(input, cursor, session);
            if relation_result.outcome != scan_signal::accept {
                total := cursor - start + relation_result.consumed;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_contains_clause",
                    start,
                    total,
                    relation_result.outcome,
                    "contains comparator expected"
                );
            }
            cursor = cursor + relation_result.consumed;

            rhs_result := rhs(input, cursor, session);
            total := cursor - start + rhs_result.consumed;
            if rhs_result.outcome != scan_signal::accept {
                message: std::string_view = "contains rhs expected";
                if rhs_result.message == "scalar fractional digits expected" {
                    message = "contains scalar fractional digits expected";
                }

                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_chart_contains_clause",
                    start,
                    total,
                    rhs_result.outcome,
                    message
                );
            }

            emit_trace(
                session,
                "pure2_chart_contains_clause",
                start,
                start + total,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, total),
                total
            );
        }
    );
}

