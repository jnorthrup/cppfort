pure2_coords_element: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            head := choice<std::string_view>(
                "coords_element_head",
                scalar_literal_parser("coords_element_scalar"),
                identifier_parser()
            );

            head_result := head(input, cursor, session);
            if head_result.outcome != scan_signal::accept {
                total := cursor - start + head_result.consumed;
                message: std::string_view = "coords element expected";
                if head_result.message == "scalar fractional digits expected" {
                    message = "coords scalar fractional digits expected";
                }

                emit_trace(
                    session,
                    "pure2_coords_element",
                    start,
                    clamp_stop(input, start, total),
                    head_result.outcome
                );
                if head_result.outcome == scan_signal::need_more {
                    return need_more_result<std::string_view>(total, message);
                }
                return reject_result<std::string_view>(message, total);
            }
            cursor = cursor + head_result.consumed;

            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() ||
               input[cursor] == ',' ||
               input[cursor] == ']' ||
               classify_delimiter_event(input[cursor]) == delimiter_event::group_close {
                total := cursor - start;
                emit_trace(
                    session,
                    "pure2_coords_element",
                    start,
                    start + total,
                    scan_signal::accept
                );
                return accept_result<std::string_view>(
                    input.substr(start, total),
                    total
                );
            }

            tail := bracket_element_tail_surface(
                "coords_element_tail_surface",
                "coords_element_tail",
                "coords element tail expected",
                "coords element tail incomplete"
            );
            tail_r := finish_trace(input, session, start, cursor, tail, "pure2_coords_element");
            if tail_r.outcome != scan_signal::accept { return tail_r; }

            emit_trace(
                session,
                "pure2_coords_element",
                start,
                start + cursor - start + tail_r.consumed,
                scan_signal::accept
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start + tail_r.consumed),
                cursor - start + tail_r.consumed
            );
        }
    );
}

pure2_coords_literal: () -> parser_of<std::string_view> = {
