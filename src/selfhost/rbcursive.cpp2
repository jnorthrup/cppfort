pure2_fold_expression: () -> parser_of<std::string_view> = {
    return with_traits<std::string_view>(
        trace_trait::debug,
        :(
            input: std::string_view,
            start: int,
            inout session: scan_session
        ) -> scan_result<std::string_view> = {
            cursor := start;
            receiver := trimmed<std::string_view>(
                "fold_receiver",
                identifier_parser()
            );

            receiver_r := expect(cursor, input, session, start, receiver, "fold receiver expected", "fold receiver expected");            if receiver_r.outcome != scan_signal::accept { return receiver_r; }
            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "fold method access expected"
                );
            }
            if input[cursor] != '.' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "fold method access expected"
                );
            }
            cursor = cursor + 1;

            keyword := trimmed<std::string_view>(
                "fold_keyword",
                keyword_parser("fold")
            );

            keyword_r := expect(cursor, input, session, start, keyword, "fold keyword expected", "fold keyword expected");            if keyword_r.outcome != scan_signal::accept { return keyword_r; }
            ws_result := skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "fold call expected"
                );
            }
            if input[cursor] != '(' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "fold call expected"
                );
            }
            cursor = cursor + 1;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "fold init argument expected"
                );
            }

            init_expr := trimmed<std::string_view>(
                "fold_init_surface",
                line_expression_surface(
                    "fold_init_surface",
                    "fold_init"
                )
            );
            init_expr_r := expect(cursor, input, session, start, init_expr, "pure2_fold_expression", "fold init argument expected");
            if init_expr_r.outcome != scan_signal::accept { return init_expr_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "fold argument separator expected"
                );
            }
            if input[cursor] != ',' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "fold argument separator expected"
                );
            }
            cursor = cursor + 1;

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "fold accumulator argument expected"
                );
            }

            acc_expr := trimmed<std::string_view>(
                "fold_accumulator_surface",
                line_expression_surface(
                    "fold_accumulator_surface",
                    "fold_accumulator"
                )
            );
            acc_expr_r := expect(cursor, input, session, start, acc_expr, "pure2_fold_expression", "fold accumulator argument expected");
            if acc_expr_r.outcome != scan_signal::accept { return acc_expr_r; }

            ws_result = skip_ws()(input, cursor, session);
            cursor = cursor + ws_result.consumed;

            if cursor >= input.ssize() {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::need_more,
                    "fold call incomplete"
                );
            }
            if input[cursor] != ')' {
                total := cursor - start;
                return surface_failure_result<std::string_view>(
                    input,
                    session,
                    "pure2_fold_expression",
                    start,
                    total,
                    scan_signal::reject,
                    "fold call incomplete"
                );
            }
            cursor = cursor + 1;

            emit_trace(
                session,
                "pure2_fold_expression",
                start,
                cursor,
                scan_signal::accept
            );
            record_feature(
                session,
                feature_kind::surface,
                start,
                cursor,
                "fold_call"
            );
            return accept_result<std::string_view>(
                input.substr(start, cursor - start),
                cursor - start
            );
        }
    );
}

project_fold_expression_feature_stream: (
    source: std::string_view,
    inout session: scan_session
) -> scan_result<std::string_view> = {
    expression := pure2_fold_expression();
    return expression(source, 0, session);
}

project_slice_expression_feature_stream: (
    source: std::string_view,
    inout session: scan_session
) -> scan_result<std::string_view> = {
    std::cerr << "DEBUG: project_slice_expression_feature_stream ENTERED\n";
    std::cerr.flush();
    expression := pure2_slice_expression();
    return expression(source, 0, session);
}
