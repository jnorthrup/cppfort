@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies
find_dependency(MLIR REQUIRED CONFIG)

# Provide targets
include("${CMAKE_CURRENT_LIST_DIR}/cppfortTargets.cmake")

# Set variables
set(cppfort_VERSION @PROJECT_VERSION@)
set(cppfort_LIBRARIES cppfort)
set(cppfort_INCLUDE_DIRS "${_IMPORT_PREFIX}/include")

# Check components
check_required_components(cppfort)